---
import Layout from '../layouts/Layout.astro';
import { FORMATIONS } from '../../functions/api/_formations.js';
// 3-team builder uses one formation for now. Imported from the same module
// the Worker validates against, so the pitch layout and the server's slot
// list can never drift apart.
const FORMATION_433 = FORMATIONS['4-3-3'];
---

<Layout title="KroniBola — Match Day" description="Join weekly football pickup games in KL & Selangor. Register online, check match schedules, and secure your spot." activeTab="home">
  <!-- Header -->
  <header class="header">
    <div class="container header-inner">
      <div class="brand">
        <img src="/logo-v2.png" alt="KroniBola" class="brand-logo" />
        <div>
          <h1 class="brand-name">KRONI<span class="neon-text">BOLA</span></h1>
          <p class="brand-tag">EST. 2025</p>
        </div>
      </div>
      <button class="admin-btn" onclick="window.location.href='/admin'" aria-label="Admin panel">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </button>
    </div>
  </header>

  <main class="container">
    <!-- Intro -->
    <div class="intro-section">
      <p class="intro-text">Weekly pickup futsal/football across <strong>KL & Selangor</strong>. No commitments — just register, pay, and play. You're already part of the <strong>KRONI</strong>.</p>
    </div>

    <!-- Loading state -->
    <div id="loadingState" class="loading-state">
      <div class="loader"></div>
      <p>Loading match data...</p>
    </div>

    <!-- No games state -->
    <div id="noGames" style="display:none" class="empty-state">
      <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 7l4.76 3.45l-1.76 5.55h-6l-1.76 -5.55z"/>
        <path d="M12 7v-5"/>
        <path d="M15 16l3 4"/>
        <path d="M16.85 10.45l4.15 -1.45"/>
        <path d="M9 16l-3 4"/>
        <path d="M7.15 10.45l-4.15 -1.45"/>
      </svg>
      <h2>No Open Games</h2>
      <p>Check back later for upcoming matches.</p>
    </div>

    <!-- Desktop: side-by-side | Mobile: stacked -->
    <div class="match-layout">
      <!-- Left: Match cards -->
      <div class="match-layout-left">
        <div id="matchCards" class="match-cards" style="display:none"></div>
      </div>

      <!-- Right: Lineup -->
      <div class="match-layout-right" id="lineupSection" style="display:none">
        <div class="section-header">
          <h2 class="section-title">THE <span class="neon-text">LINEUP</span></h2>
          <span class="lineup-count" id="lineupCount">0 players</span>
        </div>
        <div class="lineup-grid" id="lineupGrid"></div>
        <p class="lineup-empty" id="lineupEmpty" style="display:none">No players yet. Be the first!</p>
        <div class="lineup-locked" id="lineupLocked" style="display:none">
          <div class="lineup-locked-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <p class="lineup-locked-title">Lineup locked</p>
          <p class="lineup-locked-sub" id="lineupLockedSub">Revealed the day before the match. Register now to secure your spot.</p>
        </div>
      </div>
    </div>

    <!-- 3-team 11-a-side builder — shown only when the selected session
         has Format = 3-team-11. Sits below the match cards, full width. -->
    <div id="teamBuilder" style="display:none">
      <div class="tb-head">
        <h2 class="section-title">PICK YOUR <span class="neon-text">POSITION</span></h2>
        <span class="tb-sub" id="tbSub">Tap an open spot on any team</span>
      </div>
      <div class="tb-summary" id="tbSummary"></div>
      <div class="tb-legend">
        <span class="tb-leg"><span class="tb-leg-dot tb-leg-dot--paid"></span> Confirmed</span>
        <span class="tb-leg"><span class="tb-leg-dot tb-leg-dot--pending"></span> Pending payment</span>
        <span class="tb-leg"><span class="tb-leg-dot tb-leg-dot--empty"></span> Open — tap to book</span>
      </div>
      <div class="tb-pitches" id="tbPitches"></div>
    </div>

    <!-- Check Status -->
    <div id="checkStatusSection" style="display:none" class="share-section">
      <button class="btn btn--outline" id="checkStatusBtn" style="width:100%">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        CHECK MY STATUS
      </button>
    </div>

    <!-- WhatsApp Group -->
    <div id="shareSection" style="display:none" class="share-section">
      <a href="https://chat.whatsapp.com/FsLEE1Bko9a9fGXd88UPgS" target="_blank" class="wa-group-banner">
        <div class="wa-group-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
        <div class="wa-group-text">
          <span class="wa-group-label">JOIN OUR WHATSAPP GROUP</span>
          <span class="wa-group-sub">Get match updates & connect with players</span>
        </div>
        <svg class="wa-group-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </main>
</Layout>

<!-- Formation data injected from the shared _formations.js module so the
     pitch layout matches exactly what the Worker validates against. -->
<script is:inline define:vars={{ kbFormation: FORMATION_433 }}>
  window.KB_FORMATION = kbFormation;
</script>

<script>
  const API = '/api';
  const ADMIN_WA = '60126183827';
  let uploadToken = '';

  // Fetch upload token on page load (valid 30 min, auto-refreshed)
  async function fetchUploadToken() {
    try {
      const res = await fetch(`${API}/upload-token`, { method: 'POST' });
      const data = await res.json();
      if (data.token) uploadToken = data.token;
    } catch {}
  }
  fetchUploadToken();
  setInterval(fetchUploadToken, 25 * 60 * 1000); // Refresh every 25 min
  let sessions: any[] = [];
  let currentSession: any = null;
  let players: any[] = [];
  let currentMax = 20;
  // When a player taps an open slot in the 3-team builder, the chosen
  // team + position are stashed here so submitRegistration can include
  // them. Cleared whenever the registration modal opens via any other path.
  let bookingContext: { team: string; position: string; posFull: string } | null = null;

  const TEAM_GAME_FORMAT = '3-team-11';
  const TEAM_KEYS = ['A', 'B', 'C'];

  // --- DOM refs ---
  const loadingEl = document.getElementById('loadingState')!;
  const noGamesEl = document.getElementById('noGames')!;
  const cardsEl = document.getElementById('matchCards')!;
  const lineupEl = document.getElementById('lineupSection')!;
  const shareEl = document.getElementById('shareSection')!;
  const teamBuilderEl = document.getElementById('teamBuilder')!;
  const isTeamGame = (s: any) => !!s && String(s.Format || '').trim() === TEAM_GAME_FORMAT;

  // --- Load sessions ---
  async function init() {
    try {
      const res = await fetch(`${API}/sessions`);
      if (!res.ok) throw new Error('sessions fetch failed');
      const data = await res.json().catch(() => ({}));
      sessions = (data.sessions || []).filter((s: any) => s.Status === 'Open').sort((a: any, b: any) => (a.Date || '').localeCompare(b.Date || ''));

      loadingEl.style.display = 'none';

      if (!sessions.length) {
        noGamesEl.style.display = '';
        return;
      }

      renderMatchCards();
      selectSession(0);
    } catch {
      loadingEl.innerHTML = '<p style="color:var(--red)">Failed to load. Try refreshing.</p>';
    }
  }

  function renderMatchCards() {
    cardsEl.style.display = '';
    cardsEl.innerHTML = sessions.map((s: any, i: number) => `
      <div class="match-card glass ${i === 0 ? 'active' : ''}" data-idx="${i}">
        <div class="mc-top">
          <span class="mc-badge">${s['Session Name']}</span>
          <span class="mc-fee">RM ${s.Fee}</span>
        </div>
        <div class="mc-details">
          <div class="mc-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>${s.Location}</span>
          </div>
          <div class="mc-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>${new Date(s.Date).toLocaleDateString('en-MY', { weekday: 'long' })} · ${s.Date}</span>
          </div>
          <div class="mc-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>${formatTime(s.Time)}</span>
          </div>
        </div>
        <a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(s.Location)}" target="_blank" rel="noopener" class="mc-maps-btn" onclick="event.stopPropagation()">
          <div class="mc-maps-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="mc-maps-text">
            <span class="mc-maps-label">View on Google Maps</span>
            <span class="mc-maps-loc">${s.Location}</span>
          </div>
          <svg class="mc-maps-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <div class="mc-countdown" id="countdown-${i}">--:--:--</div>
        <div class="mc-slots">
          <div class="mc-slots-header">
            <span class="mc-slots-label" id="slotsLabel-${i}">0 / ${s['Max Players'] || 20}</span>
            <span class="mc-spots" id="spots-${i}"></span>
          </div>
          <div class="progress-track"><div class="progress-fill" id="bar-${i}" style="width:0%"></div></div>
          <div class="mc-recent" id="recent-${i}" style="display:none" aria-live="polite">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
            </svg>
            <span class="mc-recent-text"></span>
          </div>
        </div>
        <button class="btn btn--primary mc-register" data-idx="${i}" data-format="${s.Format || ''}" style="width:100%">${s.Format === TEAM_GAME_FORMAT ? 'PICK YOUR POSITION' : 'REGISTER NOW'}</button>
        <div class="mc-actions">
          <button type="button" class="mc-action-btn mc-share" data-idx="${i}" aria-label="Share this match">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span>Share</span>
          </button>
          <button type="button" class="mc-action-btn mc-cal-google" data-idx="${i}" aria-label="Add to Google Calendar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Google</span>
          </button>
          <button type="button" class="mc-action-btn mc-cal-apple" data-idx="${i}" aria-label="Add to Apple Calendar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 5-2.5 5-6.24 0-4.5-4-7.76-6-7.76-1.25 0-2 .5-3 .5s-1.75-.5-3-.5c-2 0-6 3.26-6 7.76 0 3.74 2 6.24 5 6.24 1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c1 .5 2 2 2 3.5-1.5 0-3-1-3.5-2.5C9 2 10 2 10 2z"/></svg>
            <span>Apple</span>
          </button>
        </div>
      </div>
    `).join('');

    // Card click to select session
    cardsEl.querySelectorAll('.match-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.mc-register') || target.closest('.mc-maps-btn') || target.closest('.mc-share')) return;
        selectSession(parseInt((card as HTMLElement).dataset.idx!));
      });
    });

    // Register button handlers
    cardsEl.querySelectorAll('.mc-register').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        selectSession(idx);
        // Team games have no single "register" action — the player picks a
        // position on the pitch. Scroll them to the builder instead.
        if ((btn as HTMLElement).dataset.format === TEAM_GAME_FORMAT) {
          teamBuilderEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          openRegistration();
        }
      });
    });

    // Share button handlers — open the share modal for that specific match.
    cardsEl.querySelectorAll('.mc-share').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        openShareModal(sessions[idx]);
      });
    });

    startCountdowns();
  }

  function selectSession(idx: number) {
    currentSession = sessions[idx];
    currentMax = parseInt(currentSession['Max Players']) || 20;
    // Fresh session selection — drop any stale team-builder booking context
    // so a normal "Register" click can't carry over an old team/position.
    bookingContext = null;

    // Update active card
    cardsEl.querySelectorAll('.match-card').forEach((c, i) => {
      c.classList.toggle('active', i === idx);
    });

    // Show/hide car plate field based on session requirement
    const carPlateGroup = document.getElementById('carPlateGroup')!;
    const regCarPlate = document.getElementById('regCarPlate') as HTMLInputElement;
    if (currentSession['Require Car Plate'] === 'Yes') {
      carPlateGroup.style.display = '';
      const saved = localStorage.getItem('kronibola_carplate');
      if (saved && !regCarPlate.value) regCarPlate.value = saved;
    } else {
      carPlateGroup.style.display = 'none';
    }

    // Toggle between the standard lineup and the 3-team position builder.
    if (isTeamGame(currentSession)) {
      lineupEl.style.display = 'none';
      teamBuilderEl.style.display = '';
    } else {
      lineupEl.style.display = '';
      teamBuilderEl.style.display = 'none';
    }
    shareEl.style.display = '';
    loadPlayers(currentSession.Date);
  }

  async function loadPlayers(date: string) {
    try {
      const res = await fetch(`${API}/players?date=${encodeURIComponent(date)}`);
      const data = await res.json();
      players = data.players || [];

      // Activity-proof chip on the active card (server returns aggregate
      // count for the queried date — no per-player timestamps).
      const recent = typeof data.recentJoins24h === 'number' ? data.recentJoins24h : 0;
      const activeIdx = sessions.findIndex((s: any) => s.Date === date);
      sessions.forEach((_: any, i: number) => {
        const chip = document.getElementById(`recent-${i}`);
        if (!chip) return;
        if (i === activeIdx && recent > 0) {
          const txt = chip.querySelector('.mc-recent-text');
          if (txt) txt.textContent = `${recent} joined in last 24h`;
          chip.style.display = '';
        } else {
          chip.style.display = 'none';
        }
      });

      // Update all card slot counters
      sessions.forEach((s: any, i: number) => {
        const max = parseInt(s['Max Players']) || 20;
        const active = players.filter((p: any) =>
          String(p['Session Date']) === s.Date && ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])
        ).length;
        // Only update if this is the matching session
        const sessionPlayers = data.players?.filter((p: any) => String(p['Session Date']) === s.Date) || [];
        const count = sessionPlayers.filter((p: any) => ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])).length;
        updateSlots(i, count, max, s.Date);
      });

      const paid = players.filter((p: any) => p['Payment Status'] === 'Paid');
      const nonRejected = players.filter((p: any) => p['Payment Status'] !== 'Rejected');
      const activeCount = players.filter((p: any) => ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])).length;

      // Update register button text
      const isFull = activeCount >= currentMax;
      cardsEl.querySelectorAll('.mc-register').forEach((btn) => {
        // Team-game buttons keep their "PICK YOUR POSITION" label — the
        // waitlist/full concept doesn't apply per-button there.
        if ((btn as HTMLElement).dataset.format === TEAM_GAME_FORMAT) return;
        btn.textContent = isFull ? 'JOIN WAITLIST' : 'REGISTER NOW';
      });

      // 3-team games render the position builder instead of the lineup.
      // The builder always shows (no "revealed the day before" lock — the
      // whole point is letting players claim a spot ahead of time).
      if (isTeamGame(currentSession)) {
        renderTeamBuilder(players, date);
        return;
      }

      // Lineup is hidden until the day before the match to encourage early
      // registration. The count in the section header and the player cards
      // are both suppressed — slot bar/labels on session cards also enter
      // a soft "tier" mode so players can't reverse-engineer how full a
      // game is.
      const lineupCountEl = document.getElementById('lineupCount')!;
      if (shouldRevealLineup(date)) {
        lineupCountEl.textContent = `${paid.length} confirmed · ${nonRejected.length} total`;
      } else {
        lineupCountEl.textContent = 'revealed the day before';
      }

      renderLineup(players, date);
    } catch {}
  }

  // --- 3-TEAM POSITION BUILDER ---
  // Renders 3 pitches for a Format=3-team-11 session. Each slot is keyed by
  // (Team, Position); a player occupying it shows their initial + name, an
  // empty slot is tappable to open the booking modal pre-filled with that
  // team + position.
  function renderTeamBuilder(list: any[], sessionDate: string) {
    const formation = (window as any).KB_FORMATION || [];
    const pitchesEl = document.getElementById('tbPitches')!;
    const summaryEl = document.getElementById('tbSummary')!;
    const teamColors: Record<string, string> = { A: '#00FF41', B: '#00c4ff', C: '#ff9500' };

    // Index occupied slots: "TEAM|POSITION" → player row. Paid/Pending/
    // Overdue occupy a slot; Rejected frees it.
    const occupied: Record<string, any> = {};
    let filled = 0;
    list.forEach((p: any) => {
      if (String(p['Session Date']) !== sessionDate) return;
      if (!['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])) return;
      const t = String(p.Team || '').trim().toUpperCase();
      const pos = String(p.Position || '').trim().toUpperCase();
      if (!t || !pos) return;
      occupied[`${t}|${pos}`] = p;
      filled++;
    });

    const totalSlots = TEAM_KEYS.length * formation.length;
    summaryEl.innerHTML = `
      <div class="tb-stat"><div class="tb-stat-num">${totalSlots}</div><div class="tb-stat-label">Slots</div></div>
      <div class="tb-stat"><div class="tb-stat-num" style="color:var(--neon)">${filled}</div><div class="tb-stat-label">Filled</div></div>
      <div class="tb-stat"><div class="tb-stat-num" style="color:var(--text-secondary)">${totalSlots - filled}</div><div class="tb-stat-label">Open</div></div>`;

    pitchesEl.innerHTML = TEAM_KEYS.map((teamKey) => {
      const color = teamColors[teamKey] || '#00FF41';
      let teamFilled = 0;
      const slots = formation.map((pos: any) => {
        const player = occupied[`${teamKey}|${pos.id}`];
        let state = 'empty';
        let inner = pos.label;
        let nameLine = `<span class="tb-slot-name">${esc(pos.full)}</span>`;
        if (player) {
          teamFilled++;
          state = player['Payment Status'] === 'Paid' ? 'paid' : 'pending';
          inner = (String(player['Player Name'] || '?')[0] || '?').toUpperCase();
          nameLine = `<span class="tb-slot-name">${esc(player['Player Name'] || '')}</span>`;
        }
        return `<div class="tb-slot tb-slot--${state}" style="left:${pos.x}%;top:${pos.y}%;--tb-color:${color}"
                     data-team="${teamKey}" data-pos="${esc(pos.id)}" data-pos-full="${esc(pos.full)}"
                     data-state="${state}" ${player ? `data-player="${esc(player['Player Name'] || '')}"` : ''}>
          <div class="tb-slot-dot">${esc(inner)}</div>
          ${nameLine}
        </div>`;
      }).join('');
      const pct = Math.round((teamFilled / formation.length) * 100);
      return `<div class="tb-pitch-card">
        <div class="tb-pitch-head">
          <span class="tb-team-dot" style="background:${color}"></span>
          <span class="tb-team-name" style="color:${color}">TEAM ${teamKey}</span>
          <span class="tb-pitch-count">${teamFilled}/${formation.length}</span>
        </div>
        <div class="tb-progress"><div class="tb-progress-fill" style="width:${pct}%;background:${color}"></div></div>
        <div class="tb-pitch">
          <div class="tb-lines">
            <div class="tb-pl tb-pl-outline"></div>
            <div class="tb-pl tb-pl-halfway"></div>
            <div class="tb-pl tb-pl-circle"></div>
            <div class="tb-pl tb-pl-box-top"></div>
            <div class="tb-pl tb-pl-box-bot"></div>
          </div>
          ${slots}
        </div>
      </div>`;
    }).join('');
  }

  // Tap handler for the builder — delegated on the pitches container.
  document.getElementById('tbPitches')!.addEventListener('click', (e) => {
    const slot = (e.target as HTMLElement).closest('.tb-slot') as HTMLElement | null;
    if (!slot) return;
    if (slot.dataset.state !== 'empty') return; // taken — not bookable
    bookingContext = {
      team: slot.dataset.team || '',
      position: slot.dataset.pos || '',
      posFull: slot.dataset.posFull || '',
    };
    openRegistration();
  });

  function esc(s: any): string {
    return String(s == null ? '' : s).replace(/[&<>"']/g, (c) => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c
    ));
  }

  // Lineup reveals when the match is within 2 days (today, tomorrow,
  // day-after-tomorrow, or already past). Comparison done in Malaysia
  // time so the cutover happens at local midnight regardless of where
  // the viewer is.
  function shouldRevealLineup(matchDateStr: string): boolean {
    if (!matchDateStr) return true;
    const todayStr = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Kuala_Lumpur' });
    const today = new Date(todayStr + 'T00:00:00+08:00').getTime();
    const match = new Date(matchDateStr + 'T00:00:00+08:00').getTime();
    const diffDays = Math.round((match - today) / (1000 * 60 * 60 * 24));
    // Reveal on match-eve (1 day before), match-day, and any past sessions
    // (in case someone lands on a closed game's view).
    return diffDays <= 1;
  }

  function updateSlots(idx: number, count: number, max: number, sessionDate?: string) {
    const label = document.getElementById(`slotsLabel-${idx}`);
    const spots = document.getElementById(`spots-${idx}`);
    const bar = document.getElementById(`bar-${idx}`);
    if (!label || !spots || !bar) return;

    const left = Math.max(max - count, 0);
    const pct = Math.min(count / max, 1) * 100;
    const full = left <= 0;

    // While the lineup is locked (more than a day from the match), suppress
    // the exact numbers and show a soft status tier instead. Admin + players
    // on match eve / match day still see the precise count.
    const softMode = sessionDate ? !shouldRevealLineup(sessionDate) : false;

    if (softMode) {
      // Label: keep capacity visible since it's on the session card already
      // (e.g. "15 slots"), but drop the "registered" count.
      label.textContent = `${max} slots`;
      // Spots: tiered copy driven by fill percentage.
      //   0%       → "Just opened"
      //   1–40%    → "Slots open"
      //   41–75%   → "Filling fast"
      //   76–99%   → "Almost full"
      //   100%     → "FULL"
      let tier = 'Slots open';
      if (full) tier = 'FULL';
      else if (pct === 0) tier = 'Just opened';
      else if (pct > 75) tier = 'Almost full';
      else if (pct > 40) tier = 'Filling fast';
      spots.textContent = tier;
      spots.className = `mc-spots ${full ? 'mc-spots--full' : ''}`;
      // Hide the progress bar entirely while locked. Even snapped to coarse
      // buckets, a visible bar still tells players how full the game is —
      // doubling up with the tier text and partly defeating the point of
      // hiding the lineup. Tier label alone is enough urgency signal.
      bar.style.width = '0%';
      bar.className = `progress-fill progress-fill--hidden ${full ? 'progress-fill--full' : ''}`;
      return;
    }

    label.textContent = `${count} / ${max}`;
    spots.textContent = full ? 'FULL' : `${left} left`;
    spots.className = `mc-spots ${full ? 'mc-spots--full' : ''}`;
    bar.style.width = `${pct}%`;
    bar.className = `progress-fill ${full ? 'progress-fill--full' : ''}`;
  }

  function renderLineup(list: any[], sessionDate: string) {
    const grid = document.getElementById('lineupGrid')!;
    const empty = document.getElementById('lineupEmpty')!;
    const locked = document.getElementById('lineupLocked')!;

    // If we're more than a day out from the match, hide the names and show
    // the locked placeholder instead. Goal is to nudge players to register
    // earlier rather than waiting and checking the list.
    if (!shouldRevealLineup(sessionDate)) {
      grid.innerHTML = '';
      grid.style.display = 'none';
      empty.style.display = 'none';
      locked.style.display = '';
      // Update the sub-copy with the actual reveal date so it's concrete.
      const revealSub = document.getElementById('lineupLockedSub');
      if (revealSub && sessionDate) {
        const revealDate = new Date(new Date(sessionDate + 'T00:00:00+08:00').getTime() - 24 * 60 * 60 * 1000);
        const revealStr = revealDate.toLocaleDateString('en-MY', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'Asia/Kuala_Lumpur' });
        revealSub.textContent = `Names revealed ${revealStr} (the day before). Register now to secure your spot.`;
      }
      return;
    }

    locked.style.display = 'none';
    grid.style.display = '';

    const order: Record<string, number> = { Paid: 1, Pending: 2, Overdue: 3, Waitlist: 4 };
    const filtered = list.filter((p: any) => p['Payment Status'] !== 'Rejected');
    const sorted = [...filtered].sort((a, b) => (order[a['Payment Status']] || 5) - (order[b['Payment Status']] || 5));

    if (!sorted.length) { grid.innerHTML = ''; empty.style.display = ''; return; }
    empty.style.display = 'none';

    const colors = ['#00FF41', '#00c4ff', '#ff9500', '#e040fb', '#ff5252', '#40c4ff', '#69f0ae', '#ffd740'];

    grid.innerHTML = sorted.map((p, i) => {
      const name = p['Player Name'] || '?';
      const initials = name.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);
      const status = p['Payment Status'] || 'Pending';
      const color = colors[i % colors.length];
      return `<div class="player-card">
        <div class="player-avatar" style="background:${color}20;color:${color};border-color:${color}40">${initials}</div>
        <span class="player-name">${name}</span>
        <span class="badge badge--${status.toLowerCase()}">${status}</span>
      </div>`;
    }).join('');
  }

  // --- Countdown ---
  function formatTime(raw: string): string {
    if (!raw) return '—';
    // Format "830pm-10pm" → "8:30 PM – 10:00 PM", "5pm-630pm" → "5:00 PM – 6:30 PM"
    const parts = raw.split('-').map(s => s.trim());
    const formatted = parts.map(p => {
      const m = p.match(/^(\d{1,2}):?(\d{2})?\s*(am|pm)?$/i);
      if (!m) return p;
      let hrs = parseInt(m[1]);
      let mins = parseInt(m[2] || '0');
      const period = (m[3] || '').toLowerCase();
      // Handle "830" as 8:30
      if (!m[2] && hrs > 24) { mins = hrs % 100; hrs = Math.floor(hrs / 100); }
      const suffix = period || (hrs >= 12 ? 'pm' : 'am');
      const displayHr = hrs > 12 ? hrs - 12 : (hrs === 0 ? 12 : hrs);
      return `${displayHr}:${String(mins).padStart(2, '0')} ${suffix.toUpperCase()}`;
    });
    return formatted.join(' – ');
  }

  function parseTime(timeStr: string): { hours: number; minutes: number } | null {
    if (!timeStr) return null;
    // Take the start time (before any dash): "830pm-10pm" → "830pm"
    const start = timeStr.split('-')[0].trim();
    // Match patterns: "830pm", "8:30pm", "8.30pm", "8:30 PM", "20:30", "8pm"
    const match = start.match(/^(\d{1,2})[:.]?(\d{2})?\s*(am|pm)?$/i);
    if (!match) return null;
    let hours = parseInt(match[1]);
    const minutes = parseInt(match[2] || '0');
    const period = (match[3] || '').toLowerCase();
    // Handle "830" as 8:30, not 830
    if (!match[2] && hours > 24) {
      return { hours: Math.floor(hours / 100), minutes: hours % 100 };
    }
    if (period === 'pm' && hours < 12) hours += 12;
    if (period === 'am' && hours === 12) hours = 0;
    return { hours, minutes };
  }

  function startCountdowns() {
    setInterval(() => {
      sessions.forEach((s: any, i: number) => {
        const el = document.getElementById(`countdown-${i}`);
        if (!el) return;
        const time = parseTime(s.Time);
        if (!time) { el.textContent = s.Time || '--:--'; return; }
        const target = new Date(`${s.Date}T${String(time.hours).padStart(2, '0')}:${String(time.minutes).padStart(2, '0')}:00`);
        const diff = target.getTime() - Date.now();
        if (isNaN(diff)) { el.textContent = s.Time || '--:--'; return; }
        if (diff <= 0) { el.textContent = 'MATCH TIME!'; el.classList.add('live'); return; }
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const sec = Math.floor((diff % 60000) / 1000);
        el.textContent = d > 0 ? `${d}d ${h}h ${m}m ${sec}s` : `${h}h ${m}m ${sec}s`;
      });
    }, 1000);
  }

  // --- Registration modal ---
  const modal = document.getElementById('regModal')!;
  const steps = [
    document.getElementById('step1')!,
    document.getElementById('step2')!,
    document.getElementById('step2w')!,
    document.getElementById('step3')!,
  ];
  const dots = document.querySelectorAll('.step-dot');

  function openRegistration() {
    modal.style.display = '';
    // Show the position-context banner when this open came from a
    // team-builder slot tap; hide it for normal registrations.
    const ctxEl = document.getElementById('bookingCtx')!;
    if (bookingContext) {
      document.getElementById('bookingCtxDot')!.textContent = bookingContext.position;
      document.getElementById('bookingCtxPos')!.textContent = bookingContext.posFull;
      document.getElementById('bookingCtxTeam')!.textContent =
        `Team ${bookingContext.team} · ${currentSession?.['Session Name'] || ''}`;
      ctxEl.style.display = '';
    } else {
      ctxEl.style.display = 'none';
    }
    showStep(1);
  }

  function showStep(n: number) {
    steps.forEach((s) => s.classList.remove('active'));
    dots.forEach((d, i) => {
      d.classList.remove('active', 'done');
      if (i + 1 < n) d.classList.add('done');
      if (i + 1 === n) d.classList.add('active');
    });

    if (n === 1) steps[0].classList.add('active');
    else if (n === 2) {
      // Team-builder bookings always go to payment — the slot was a discrete
      // open spot, there's no waitlist concept per position.
      const active = players.filter((p: any) => ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status']));
      if (!bookingContext && active.length >= currentMax) {
        steps[2].classList.add('active'); // waitlist
      } else {
        steps[1].classList.add('active'); // payment
        document.getElementById('payFeeLabel')!.textContent = `Fee: RM ${currentSession?.Fee || 10}`;
      }
    }
    else if (n === 3) steps[3].classList.add('active');
  }

  document.getElementById('modalClose')!.addEventListener('click', () => modal.style.display = 'none');
  document.getElementById('modalDone')!.addEventListener('click', () => { modal.style.display = 'none'; location.reload(); });
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

  document.getElementById('toStep2')!.addEventListener('click', () => {
    const name = (document.getElementById('regName') as HTMLInputElement).value.trim();
    const countrySel = document.getElementById('regCountry') as HTMLSelectElement;
    const phoneInput = document.getElementById('regPhone') as HTMLInputElement;
    const errEl = document.getElementById('regError')!;
    if (!name) { showErr(errEl, 'Please enter your nickname.'); return; }
    const phoneCheck = (window as any).KB_PHONE.buildAndValidate(countrySel, phoneInput);
    if (!phoneCheck.valid) { showErr(errEl, phoneCheck.error); return; }
    const phone = phoneCheck.e164;

    // Validate car plate if required
    if (currentSession && currentSession['Require Car Plate'] === 'Yes') {
      const plate = (document.getElementById('regCarPlate') as HTMLInputElement).value.replace(/\s/g, '').toUpperCase();
      if (!plate) { showErr(errEl, 'Car plate number is required.'); return; }
      if (plate.length < 2 || plate.length > 10 || !/^[A-Z0-9]+$/.test(plate) || !/[A-Z]/.test(plate) || !/[0-9]/.test(plate)) {
        showErr(errEl, 'Invalid car plate. Must be 2-10 alphanumeric characters with at least 1 letter and 1 digit.'); return;
      }
    }

    if (players.some((p: any) => p['Player Name'].toLowerCase().trim() === name.toLowerCase())) {
      showErr(errEl, `"${name}" is already taken!`); return;
    }

    // Team-builder bookings: cheap pre-check against the players list we
    // already loaded. Catches the common "tapped a while ago, slot filled
    // since" case before the user pays. Sub-second races still hit the
    // server-side guard in register.js.
    if (bookingContext) {
      const taken = players.some((p: any) =>
        String(p.Team || '').trim().toUpperCase() === bookingContext!.team &&
        String(p.Position || '').trim().toUpperCase() === bookingContext!.position &&
        ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])
      );
      if (taken) {
        showErr(errEl, `${bookingContext.posFull} on Team ${bookingContext.team} was just taken — close this and pick another open spot.`);
        return;
      }
    }

    errEl.style.display = 'none';
    showStep(2);
  });

  let isSubmitting = false;
  async function submitRegistration() {
    if (isSubmitting) return;
    isSubmitting = true;
    // Disable both confirm buttons
    const step3Btn = document.getElementById('toStep3') as HTMLButtonElement;
    const wlBtn = document.getElementById('confirmWaitlist') as HTMLButtonElement;
    if (step3Btn) { step3Btn.disabled = true; step3Btn.textContent = 'SUBMITTING...'; }
    if (wlBtn) { wlBtn.disabled = true; wlBtn.textContent = 'SUBMITTING...'; }

    const name = (document.getElementById('regName') as HTMLInputElement).value.trim();
    const countrySel = document.getElementById('regCountry') as HTMLSelectElement;
    const phoneInput = document.getElementById('regPhone') as HTMLInputElement;
    const phoneCheck = (window as any).KB_PHONE.buildAndValidate(countrySel, phoneInput);
    const phone = phoneCheck.valid ? phoneCheck.e164 : '';
    const carPlate = (document.getElementById('regCarPlate') as HTMLInputElement).value.replace(/\s/g, '').toUpperCase();
    const errEl = document.getElementById('regError')!;

    try {
      const regBody: any = { date: currentSession.Date, name, phone, fee: currentSession.Fee, sessionName: currentSession['Session Name'] };
      if (carPlate) regBody.carPlate = carPlate;
      // Team-builder booking — send the chosen slot so the server can
      // validate it and guard against a concurrent claim.
      if (bookingContext) { regBody.team = bookingContext.team; regBody.position = bookingContext.position; }
      const res = await fetch(`${API}/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(regBody),
      });
      const data = await res.json().catch(() => ({}));
      if (data.success) {
        const wl = data.status === 'Waitlist';
        const doneTitle = document.getElementById('doneTitle')!;
        const doneSub = document.getElementById('doneSub')!;
        if (wl) {
          doneTitle.innerHTML = 'ON THE <span style="color:var(--blue)">WAITLIST</span>';
          doneSub.textContent = "We'll notify you when a slot opens.";
        } else {
          doneTitle.innerHTML = "YOU'RE <span class='neon-text'>IN!</span>";
          doneSub.textContent = 'Slot confirmed. See you on the pitch!';
        }
        // Populate receipt
        const refCode = data.refCode || '—';
        document.getElementById('rcptRef')!.textContent = refCode;
        document.getElementById('rcptName')!.textContent = name;
        document.getElementById('rcptSession')!.textContent = currentSession['Session Name'];
        document.getElementById('rcptDate')!.textContent = `${currentSession.Date} · ${currentSession.Time}`;
        document.getElementById('rcptStatus')!.textContent = wl ? 'Waitlist' : 'Pending';
        document.getElementById('rcptFee')!.textContent = `RM ${currentSession.Fee}`;

        const msg = wl
          ? `Hi Admin, I've joined the WAITLIST for ${currentSession['Session Name']} on ${currentSession.Date} at ${currentSession.Location}.\n\nName: ${name}\nRef: ${refCode}\n\nPlease notify me if a slot opens up.`
          : `Hi Admin, I've registered and paid for ${currentSession['Session Name']} on ${currentSession.Date} at ${currentSession.Location}.\n\nName: ${name}\nRef: ${refCode}\nFee: RM ${currentSession.Fee}\n\nReceipt uploaded on the app. Please verify my payment.`;
        (document.getElementById('waBtn') as HTMLAnchorElement).href = `https://wa.me/${ADMIN_WA}?text=${encodeURIComponent(msg)}`;

        // Save car plate to localStorage for auto-fill
        if (carPlate) localStorage.setItem('kronibola_carplate', carPlate);

        // Upload receipt (mandatory for non-waitlist)
        if (receiptData) {
          const uploadStatus = document.getElementById('uploadStatus')!;
          uploadStatus.style.display = '';
          uploadStatus.innerHTML = '<div class="alert alert--info" style="font-size:0.78rem">Uploading receipt...</div>';
          try {
            // Ensure we have an upload token
            if (!uploadToken) await fetchUploadToken();
            const uploadRes = await fetch(`${API}/upload-receipt`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ refCode, playerName: name, imageData: receiptData.base64, mimeType: receiptData.mimeType, uploadToken }),
            });
            const uploadData = await uploadRes.json().catch(() => ({}));
            if (!uploadRes.ok || !uploadData.success) {
              const msg = uploadData.error || 'Receipt upload failed.';
              uploadStatus.innerHTML = `<div class="alert alert--error" style="font-size:0.78rem">${msg} Your slot is saved — you can resend via Check Status.</div>`;
            } else {
              uploadStatus.style.display = 'none';
            }
          } catch {
            uploadStatus.innerHTML = '<div class="alert alert--error" style="font-size:0.78rem">Receipt upload failed (network). Your slot is saved — you can resend via Check Status.</div>';
          }
          receiptData = null;
        }

        showStep(3);
      } else if (data.error === 'position_taken') {
        // Lost the race for this slot. Send them back to step 1 with a
        // clear message and refresh the pitch so the taken slot shows
        // filled. The receipt (if uploaded) wasn't tied to a saved row.
        showStep(1);
        showErr(errEl, data.message || 'That position was just taken — please pick another open spot.');
        if (currentSession) loadPlayers(currentSession.Date);
        isSubmitting = false;
        if (step3Btn) { step3Btn.disabled = false; step3Btn.textContent = 'CONFIRM'; }
        if (wlBtn) { wlBtn.disabled = false; wlBtn.textContent = 'JOIN WAITLIST'; }
      } else {
        showErr(errEl, data.error || 'Registration failed.');
        isSubmitting = false;
        if (step3Btn) { step3Btn.disabled = false; step3Btn.textContent = 'CONFIRM'; }
        if (wlBtn) { wlBtn.disabled = false; wlBtn.textContent = 'JOIN WAITLIST'; }
      }
    } catch {
      showErr(errEl, 'Network error.');
      isSubmitting = false;
      if (step3Btn) { step3Btn.disabled = false; step3Btn.textContent = 'CONFIRM'; }
      if (wlBtn) { wlBtn.disabled = false; wlBtn.textContent = 'JOIN WAITLIST'; }
    }
  }

  document.getElementById('toStep3')!.addEventListener('click', () => {
    if (!receiptData) {
      const uploadStatus = document.getElementById('uploadStatus')!;
      uploadStatus.style.display = '';
      uploadStatus.innerHTML = '<div class="alert alert--error" style="font-size:0.78rem">Please upload your payment receipt before confirming.</div>';
      document.getElementById('uploadArea')!.style.borderColor = 'var(--red)';
      setTimeout(() => { document.getElementById('uploadArea')!.style.borderColor = ''; }, 3000);
      return;
    }
    submitRegistration();
  });
  document.getElementById('confirmWaitlist')!.addEventListener('click', submitRegistration);

  // Share
  // Add to Calendar — Google + Apple (.ics) handlers attached via event
  // delegation on the match-cards container. Uses sessions[idx] from the
  // clicked card so the buttons work even when not the active session.
  function calendarDateRange(s: any): { startDT: string; endDT: string } {
    const time = parseTime(s.Time);
    const dateStr = String(s.Date || '').replace(/\//g, '-');
    let startDT = dateStr.replace(/-/g, '');
    let endDT = startDT;
    if (time) {
      const hh = String(time.hours).padStart(2, '0');
      const mm = String(time.minutes).padStart(2, '0');
      startDT += `T${hh}${mm}00`;
      const endH = String((time.hours + 2) % 24).padStart(2, '0');
      endDT += `T${endH}${mm}00`;
    }
    return { startDT, endDT };
  }

  cardsEl.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const gBtn = target.closest('.mc-cal-google') as HTMLElement | null;
    const aBtn = target.closest('.mc-cal-apple') as HTMLElement | null;
    if (!gBtn && !aBtn) return;
    e.stopPropagation();
    const idx = parseInt(((gBtn || aBtn) as HTMLElement).dataset.idx!);
    const s = sessions[idx];
    if (!s) return;
    const { startDT, endDT } = calendarDateRange(s);
    if (gBtn) {
      const url = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(s['Session Name'])}&dates=${startDT}/${endDT}&location=${encodeURIComponent(s.Location || '')}&details=${encodeURIComponent('KroniBola match')}`;
      window.open(url, '_blank');
      return;
    }
    // Apple — generate an .ics download for this match.
    const safeDate = String(s.Date || 'match').replace(/[^a-zA-Z0-9-]/g, '');
    const ics = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//KroniBola//EN',
      'BEGIN:VEVENT',
      `DTSTART:${startDT}`,
      `DTEND:${endDT}`,
      `SUMMARY:${s['Session Name'] || 'KroniBola match'}`,
      `LOCATION:${s.Location || ''}`,
      'DESCRIPTION:KroniBola match',
      `URL:${location.origin}`,
      'END:VEVENT',
      'END:VCALENDAR',
    ].join('\r\n');
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `kronibola-${safeDate}.ics`;
    link.click();
    URL.revokeObjectURL(link.href);
  });

  // --- Receipt upload ---
  let receiptData: { base64: string; mimeType: string } | null = null;

  const receiptFile = document.getElementById('receiptFile') as HTMLInputElement;
  const uploadPreview = document.getElementById('uploadPreview') as HTMLImageElement;
  const uploadPlaceholder = document.getElementById('uploadPlaceholder')!;
  const uploadArea = document.getElementById('uploadArea')!;

  receiptFile.addEventListener('change', () => {
    const file = receiptFile.files?.[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { alert('File too large. Max 5MB.'); return; }

    const reader = new FileReader();
    reader.onload = () => {
      const result = reader.result as string;
      receiptData = { base64: result, mimeType: file.type };
      uploadPreview.src = result;
      uploadPreview.style.display = '';
      uploadPlaceholder.style.display = 'none';
      uploadArea.classList.add('has-file');
    };
    reader.readAsDataURL(file);
  });

  // --- Share match modal -------------------------------------------------
  // Surfaced from the share button on each match card. Builds a friendly
  // text payload for WhatsApp/clipboard, and lazily generates a 9:16
  // story-format image for Instagram (Web Share API on mobile, download
  // fallback on desktop). The modal lives in Layout.astro alongside the
  // other modals so it inherits the same slide-up sheet styling.
  const shareModal = document.getElementById('shareModal')!;
  const sharePreview = document.getElementById('sharePreview')!;
  const shareSub = document.getElementById('shareSub')!;
  const shareIgSub = document.getElementById('shareIgSub')!;
  const shareCopyTitle = document.getElementById('shareCopyTitle')!;
  let currentShareSession: any = null;

  document.getElementById('shareClose')!.addEventListener('click', () => { shareModal.style.display = 'none'; });
  shareModal.addEventListener('click', (e) => { if (e.target === shareModal) shareModal.style.display = 'none'; });

  function buildShareText(s: any): string {
    const dateStr = (() => {
      try {
        return new Date(s.Date + 'T00:00:00+08:00').toLocaleDateString('en-MY', {
          weekday: 'long', day: 'numeric', month: 'long', timeZone: 'Asia/Kuala_Lumpur',
        });
      } catch { return s.Date; }
    })();
    const lines = [
      `⚽ ${s['Session Name'] || 'KroniBola'} — Game On!`,
      '',
      `📅 ${dateStr}`,
      `⏰ ${formatTime(s.Time || '')}`,
      `📍 ${s.Location || ''}`,
      `💰 RM ${s.Fee}/pax`,
      '',
      'Register here 👉 https://kronibola.com',
    ];
    return lines.filter(Boolean).join('\n');
  }

  function openShareModal(s: any) {
    currentShareSession = s;
    sharePreview.textContent = buildShareText(s);
    shareSub.textContent = s['Session Name'] ? `${s['Session Name']} · ${s.Date}` : 'Tell your friends 👇';
    shareCopyTitle.textContent = 'Copy link & details';
    shareIgSub.textContent = 'Generates a story image';
    shareModal.style.display = '';
  }

  document.getElementById('shareWa')!.addEventListener('click', () => {
    if (!currentShareSession) return;
    const text = buildShareText(currentShareSession);
    window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank', 'noopener');
  });

  document.getElementById('shareCopy')!.addEventListener('click', async () => {
    if (!currentShareSession) return;
    const btn = document.getElementById('shareCopy') as HTMLButtonElement;
    try {
      await navigator.clipboard.writeText(buildShareText(currentShareSession));
      btn.classList.add('share-option--copied');
      shareCopyTitle.textContent = 'Copied!';
      setTimeout(() => {
        btn.classList.remove('share-option--copied');
        shareCopyTitle.textContent = 'Copy link & details';
      }, 1800);
    } catch {
      shareCopyTitle.textContent = 'Copy failed — long-press the preview';
    }
  });

  // --- Instagram story image generation ---
  // Renders a 1080x1920 canvas with the match details + KB branding, then
  // hands the resulting Blob to the Web Share API (mobile share sheet
  // includes Instagram). Desktop browsers fall back to a download.
  function loadImage(src: string): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = src;
    });
  }

  function wrapText(ctx: CanvasRenderingContext2D, text: string, maxWidth: number, maxLines: number): string[] {
    if (!text) return [];
    const words = text.split(/\s+/);
    const lines: string[] = [];
    let line = '';
    for (const word of words) {
      const test = line ? `${line} ${word}` : word;
      if (ctx.measureText(test).width > maxWidth && line) {
        lines.push(line);
        line = word;
        if (lines.length === maxLines - 1) {
          // Last allowed line — append remaining as truncated
          const rest = words.slice(words.indexOf(word)).join(' ');
          let tail = rest;
          while (ctx.measureText(tail + '…').width > maxWidth && tail.length) tail = tail.slice(0, -1);
          lines.push(tail + (tail.length < rest.length ? '…' : ''));
          return lines;
        }
      } else {
        line = test;
      }
    }
    if (line) lines.push(line);
    return lines;
  }

  async function generateStoryImage(s: any): Promise<Blob> {
    const W = 1080, H = 1920;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d')!;

    // Background — dark with a subtle neon glow at the top
    const bgGrad = ctx.createLinearGradient(0, 0, 0, H);
    bgGrad.addColorStop(0, '#0a1505');
    bgGrad.addColorStop(0.45, '#080808');
    bgGrad.addColorStop(1, '#000000');
    ctx.fillStyle = bgGrad;
    ctx.fillRect(0, 0, W, H);

    // Top neon strip
    ctx.fillStyle = '#00FF41';
    ctx.fillRect(0, 0, W, 12);

    // Radial glow behind the title
    const glow = ctx.createRadialGradient(W / 2, 700, 50, W / 2, 700, 700);
    glow.addColorStop(0, 'rgba(0,255,65,0.18)');
    glow.addColorStop(1, 'rgba(0,255,65,0)');
    ctx.fillStyle = glow;
    ctx.fillRect(0, 0, W, H);

    // Logo (best-effort — silent fallback if image fails to load)
    try {
      const logo = await loadImage('/logo-v2.png');
      const lw = 160; const lh = 160;
      ctx.drawImage(logo, (W - lw) / 2, 200, lw, lh);
    } catch {}

    ctx.textAlign = 'center';

    // Brand wordmark
    ctx.fillStyle = '#a0a0a0';
    ctx.font = 'bold 38px system-ui, -apple-system, sans-serif';
    ctx.fillText('KRONIBOLA', W / 2, 410);

    // MATCH DAY label
    ctx.fillStyle = '#00FF41';
    ctx.font = 'bold 56px system-ui, -apple-system, sans-serif';
    ctx.fillText('⚽  MATCH DAY  ⚽', W / 2, 530);

    // Session name (uppercase, with simple wrap)
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 96px system-ui, -apple-system, sans-serif';
    const sessionName = String(s['Session Name'] || 'KRONIBOLA').toUpperCase();
    const sessionLines = wrapText(ctx, sessionName, 940, 2);
    let y = 700;
    for (const line of sessionLines) { ctx.fillText(line, W / 2, y); y += 110; }

    // Date — day of week (large) + numeric date (smaller)
    let dayName = ''; let dateNum = '';
    try {
      const d = new Date(s.Date + 'T00:00:00+08:00');
      dayName = d.toLocaleDateString('en-MY', { weekday: 'long', timeZone: 'Asia/Kuala_Lumpur' }).toUpperCase();
      dateNum = d.toLocaleDateString('en-MY', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Asia/Kuala_Lumpur' });
    } catch { dayName = s.Date || ''; dateNum = ''; }

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 78px system-ui, -apple-system, sans-serif';
    ctx.fillText(dayName, W / 2, 1010);
    ctx.fillStyle = '#a0a0a0';
    ctx.font = '54px system-ui, -apple-system, sans-serif';
    ctx.fillText(dateNum, W / 2, 1085);

    // Time
    ctx.fillStyle = '#00FF41';
    ctx.font = 'bold 70px system-ui, -apple-system, sans-serif';
    ctx.fillText(formatTime(s.Time || ''), W / 2, 1230);

    // Location (wrapped)
    ctx.fillStyle = '#ffffff';
    ctx.font = '46px system-ui, -apple-system, sans-serif';
    const locLines = wrapText(ctx, `📍 ${s.Location || ''}`, 940, 2);
    y = 1340;
    for (const line of locLines) { ctx.fillText(line, W / 2, y); y += 64; }

    // Fee
    ctx.fillStyle = '#00FF41';
    ctx.font = 'bold 84px system-ui, -apple-system, sans-serif';
    ctx.fillText(`RM ${s.Fee}/PAX`, W / 2, 1560);

    // Bottom CTA
    ctx.fillStyle = '#a0a0a0';
    ctx.font = '40px system-ui, -apple-system, sans-serif';
    ctx.fillText('Register at', W / 2, 1750);
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 64px system-ui, -apple-system, sans-serif';
    ctx.fillText('kronibola.com', W / 2, 1830);

    return new Promise<Blob>((resolve, reject) => {
      canvas.toBlob((blob) => blob ? resolve(blob) : reject(new Error('toBlob failed')), 'image/jpeg', 0.92);
    });
  }

  document.getElementById('shareIg')!.addEventListener('click', async () => {
    if (!currentShareSession) return;
    const btn = document.getElementById('shareIg') as HTMLButtonElement;
    btn.disabled = true;
    shareIgSub.textContent = 'Generating image…';
    try {
      const blob = await generateStoryImage(currentShareSession);
      const safeDate = String(currentShareSession.Date || 'match').replace(/[^a-zA-Z0-9-]/g, '');
      const file = new File([blob], `kronibola-${safeDate}.jpg`, { type: 'image/jpeg' });
      const shareData: any = {
        files: [file],
        title: `KroniBola — ${currentShareSession['Session Name'] || 'Match'}`,
        text: buildShareText(currentShareSession),
      };
      // Web Share API with files works on most modern mobile browsers and
      // surfaces Instagram in the share sheet. Desktop typically lacks
      // file sharing — fall back to a download in that case.
      if ((navigator as any).canShare && (navigator as any).canShare(shareData)) {
        try {
          await (navigator as any).share(shareData);
          shareIgSub.textContent = 'Shared!';
        } catch (err: any) {
          // User cancelled, or share aborted — silent reset
          shareIgSub.textContent = err && err.name === 'AbortError' ? 'Generates a story image' : 'Share cancelled';
        }
      } else {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = file.name;
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        setTimeout(() => URL.revokeObjectURL(url), 5000);
        shareIgSub.textContent = 'Downloaded — open Instagram and post as story';
      }
    } catch {
      shareIgSub.textContent = 'Could not generate image. Try Copy instead.';
    } finally {
      btn.disabled = false;
      setTimeout(() => { shareIgSub.textContent = 'Generates a story image'; }, 6000);
    }
  });

  // --- Check Status Modal ---
  const statusModal = document.getElementById('statusModal')!;
  document.getElementById('checkStatusBtn')!.addEventListener('click', () => { statusModal.style.display = ''; });
  document.getElementById('statusClose')!.addEventListener('click', () => { statusModal.style.display = 'none'; });
  statusModal.addEventListener('click', (e) => { if (e.target === statusModal) statusModal.style.display = 'none'; });

  document.getElementById('statusCheck')!.addEventListener('click', async () => {
    const countrySel = document.getElementById('statusCountry') as HTMLSelectElement;
    const phoneInput = document.getElementById('statusPhone') as HTMLInputElement;
    const result = document.getElementById('statusResult')!;
    const phoneCheck = (window as any).KB_PHONE.buildAndValidate(countrySel, phoneInput);
    if (!phoneCheck.valid) { result.innerHTML = `<div class="alert alert--error">${phoneCheck.error}</div>`; return; }
    const phone = phoneCheck.e164;

    result.innerHTML = '<div class="loading-sm"><div class="loader-sm"></div>Checking…</div>';

    try {
      const res = await fetch(`${API}/status?phone=${encodeURIComponent(phone)}`);
      if (!res.ok) throw new Error('status fetch failed');
      const data = await res.json().catch(() => ({}));
      const regs = data.registrations || [];

      if (!regs.length) {
        result.innerHTML = '<div class="alert alert--info">No registrations found for this number.</div>';
        return;
      }

      result.innerHTML = regs.map((r: any) => {
        const statusClass = (r.status || 'pending').toLowerCase();
        const needsReceipt = ['Pending', 'Overdue'].includes(r.status);
        const refCode = r.refCode || '';
        return `<div class="status-card">
          <div class="status-card-header">
            <span class="status-card-name">${r.name}</span>
            <span class="badge badge--${statusClass}">${r.status}</span>
          </div>
          <div class="status-card-details">
            <strong>${r.sessionName}</strong><br>
            ${r.date} · ${r.time} · ${r.location}<br>
            Fee: RM ${r.fee}${refCode ? ` · Ref: ${refCode}` : ''}
            ${r.carPlate || r.requireCarPlate ? `
              <div class="status-carplate" style="margin-top:0.5rem;display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap">
                <span style="font-size:0.78rem;color:var(--text-muted)">🚗 Car Plate:</span>
                <input type="text" class="form-input status-plate-input" value="${r.carPlate || ''}" placeholder="e.g. ABC1234" data-ref="${refCode}" data-date="${r.date}" data-name="${r.name}" style="flex:1;min-width:100px;max-width:160px;padding:0.35rem 0.6rem;font-size:0.78rem;text-transform:uppercase" />
                <button class="btn btn--primary btn--sm status-plate-save" style="padding:0.3rem 0.8rem;font-size:0.7rem">Save</button>
              </div>
            ` : ''}
          </div>
          ${needsReceipt ? `
            <div class="status-pay">
              <p class="status-pay-label">Pay via Maybank MAE — RM ${r.fee}</p>
              <img src="/pay.webp" alt="Payment QR" class="status-pay-qr" loading="lazy" />
              <a href="https://www.maybank2u.com.my" target="_blank" rel="noopener" class="btn btn--mae" style="width:100%">Open Maybank MAE</a>
            </div>
            <div class="status-upload" style="margin-top:0.6rem">
              <label class="upload-area-mini" data-ref="${refCode}" data-name="${r.name}">
                <input type="file" accept="image/*" class="status-receipt-input" style="display:none" />
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Upload payment receipt</span>
              </label>
              <div class="status-upload-result" style="display:none"></div>
            </div>
          ` : ''}
        </div>`;
      }).join('');

      // Save latest car plate to localStorage for auto-fill
      const latestPlate = regs.find((r: any) => r.carPlate);
      if (latestPlate) localStorage.setItem('kronibola_carplate', latestPlate.carPlate);

      // Handle car plate save from status cards
      result.querySelectorAll('.status-plate-save').forEach((btn: Element) => {
        btn.addEventListener('click', async () => {
          const saveBtn = btn as HTMLButtonElement;
          const input = saveBtn.parentElement!.querySelector('.status-plate-input') as HTMLInputElement;
          const refCode = input.dataset.ref || '';
          const plate = input.value.replace(/\s/g, '').toUpperCase();
          if (!plate) { alert('Please enter a car plate number'); return; }
          // Re-read the phone the user entered for the status lookup. The
          // server requires it to verify the requester owns the row before
          // accepting the plate change. Sends E.164 for new data; the
          // server's fuzzy match handles legacy stored formats too.
          const _countrySel = document.getElementById('statusCountry') as HTMLSelectElement;
          const _phoneInput = document.getElementById('statusPhone') as HTMLInputElement;
          const _phoneCheck = (window as any).KB_PHONE.buildAndValidate(_countrySel, _phoneInput);
          const phoneForAuth = _phoneCheck.valid ? _phoneCheck.e164 : _phoneInput.value.replace(/[-\s]/g, '');

          saveBtn.disabled = true;
          saveBtn.textContent = '...';
          try {
            const res = await fetch(`${API}/update-plate`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ refCode, carPlate: plate, phone: phoneForAuth }),
            });
            const data = await res.json();
            if (data.success) {
              saveBtn.textContent = 'Saved!';
              saveBtn.style.background = 'var(--neon)';
              saveBtn.style.color = '#000';
              input.value = data.carPlate;
              localStorage.setItem('kronibola_carplate', data.carPlate);
              setTimeout(() => { saveBtn.textContent = 'Save'; saveBtn.style.background = ''; saveBtn.style.color = ''; saveBtn.disabled = false; }, 2000);
            } else {
              alert(data.error || 'Failed to update');
              saveBtn.textContent = 'Save';
              saveBtn.disabled = false;
            }
          } catch {
            alert('Connection error. Please try again.');
            saveBtn.textContent = 'Save';
            saveBtn.disabled = false;
          }
        });
      });

      // Handle receipt uploads from status cards. Guard against the
      // known iOS Safari quirk where the file `change` event can fire
      // twice on the same selection — without this we'd POST the same
      // receipt twice and the admin would see duplicate Telegram messages.
      result.querySelectorAll('.status-receipt-input').forEach((input: Element) => {
        let uploading = false;
        input.addEventListener('change', async () => {
          if (uploading) return;
          const fileInput = input as HTMLInputElement;
          const file = fileInput.files?.[0];
          if (!file) return;
          if (file.size > 5 * 1024 * 1024) { alert('File too large. Max 5MB.'); return; }

          uploading = true;
          fileInput.disabled = true;

          const label = fileInput.closest('.upload-area-mini') as HTMLElement;
          const refCode = label.dataset.ref || 'UNKNOWN';
          const playerName = label.dataset.name || 'Player';
          const resultDiv = label.parentElement!.querySelector('.status-upload-result') as HTMLElement;

          resultDiv.style.display = '';
          resultDiv.innerHTML = '<span style="color:var(--neon);font-size:0.75rem">Uploading...</span>';

          const reader = new FileReader();
          reader.onload = async () => {
            try {
              const res = await fetch(`${API}/upload-receipt`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refCode, playerName, imageData: reader.result, mimeType: file.type, uploadToken }),
              });
              const data = await res.json();
              if (data.success) {
                resultDiv.innerHTML = '<span style="color:var(--neon);font-size:0.75rem">✓ Receipt uploaded!</span>';
                label.style.display = 'none';
                // leave uploading=true on success so any stray second
                // change event is swallowed even if the user re-enables
                // the input via dev tools or a flaky mobile browser
              } else {
                resultDiv.innerHTML = '<span style="color:var(--red);font-size:0.75rem">Upload failed. Try again.</span>';
                uploading = false;
                fileInput.disabled = false;
              }
            } catch {
              resultDiv.innerHTML = '<span style="color:var(--red);font-size:0.75rem">Upload failed. Try again.</span>';
              uploading = false;
              fileInput.disabled = false;
            }
          };
          reader.readAsDataURL(file);
        });
      });
    } catch { result.innerHTML = '<div class="alert alert--error">Failed to check. Try again.</div>'; }
  });

  // Show check status section when sessions load
  const checkSection = document.getElementById('checkStatusSection')!;

  // --- Phone lookup on registration (auto-fill name) ---
  const regCountrySel = document.getElementById('regCountry') as HTMLSelectElement;
  const regPhoneInput = document.getElementById('regPhone') as HTMLInputElement;
  const regNameInput = document.getElementById('regName') as HTMLInputElement;
  let lookupTimeout: any;

  function tryAutoFill() {
    clearTimeout(lookupTimeout);
    // Build a candidate E.164 — auto-fill only when the input parses
    // cleanly, otherwise wait for the user to finish typing.
    const check = (window as any).KB_PHONE.buildAndValidate(regCountrySel, regPhoneInput);
    if (!check.valid) return;
    const phone = check.e164;
    lookupTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`${API}/status?phone=${encodeURIComponent(phone)}`);
        const data = await res.json();
        if (data.knownName && !regNameInput.value) {
          regNameInput.value = data.knownName;
          regNameInput.style.borderColor = 'var(--neon)';
          setTimeout(() => { regNameInput.style.borderColor = ''; }, 2000);
        }
      } catch {}
    }, 500);
  }
  regPhoneInput.addEventListener('input', tryAutoFill);
  regCountrySel.addEventListener('change', tryAutoFill);

  function showErr(el: HTMLElement, msg: string) {
    el.style.display = '';
    el.innerHTML = `<div class="alert alert--error">${msg}</div>`;
  }

  init();

  // Show check status after init
  setTimeout(() => { checkSection.style.display = ''; }, 500);
</script>

<style is:global>
  /* Global helpers — used by dynamically injected markup */
  .loader-sm {
    width: 16px; height: 16px; border: 2px solid var(--border);
    border-top-color: var(--neon); border-radius: 50%;
    animation: spin-sm 0.8s linear infinite;
    display: inline-block; vertical-align: middle;
  }
  .loading-sm {
    text-align: center; padding: 1rem;
    color: var(--text-muted); font-size: 0.82rem;
  }
  .loading-sm .loader-sm { margin-right: 0.5rem; }
  @keyframes spin-sm { to { transform: rotate(360deg); } }
</style>

<style>
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(6,6,6,0.92); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding-top: env(safe-area-inset-top, 0px);
  }
  .header::after {
    content: ''; position: absolute; bottom: 0; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.15), transparent);
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 0; }
  .brand { display: flex; align-items: center; gap: 0.7rem; }
  .brand-logo { width: 40px; height: 40px; border-radius: 10px; }
  .brand-name { font-size: 1.2rem; font-weight: 800; letter-spacing: 0.05em; line-height: 1; }
  .brand-tag { font-size: 0.58rem; color: var(--text-muted); letter-spacing: 0.2em; font-weight: 600; }
  .admin-btn {
    width: 44px; height: 44px; border-radius: 10px; border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; color: var(--text-muted);
    background: none; cursor: pointer; transition: all 0.2s; -webkit-tap-highlight-color: transparent;
  }
  .admin-btn:hover { border-color: var(--neon); color: var(--neon); }

  /* Loading */
  .intro-section {
    padding: 0.8rem 0 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .intro-text {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-weight: 300;
    text-align: center;
  }
  .intro-text strong {
    color: var(--neon);
    font-weight: 500;
  }

  .loading-state { text-align: center; padding: 4rem 0; color: var(--text-muted); }
  .loader {
    width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--neon);
    border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .empty-state { text-align: center; padding: 4rem 0; }
  .empty-icon { width: 56px; height: 56px; display: block; margin: 0 auto 1rem; color: var(--text-muted); opacity: 0.7; }
  .empty-state h2 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .empty-state p { color: var(--text-muted); font-size: 0.88rem; }

  /* Match Cards — use :global for JS-generated content */
  .match-cards { margin: 1.2rem 0; display: flex; flex-direction: column; gap: 0.6rem; }

  /* Desktop master-detail layout */
  .match-layout { display: block; }

  @media (min-width: 900px) {
    .container { max-width: 1100px; }

    .match-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .match-layout-right {
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      scrollbar-width: thin;
    }

    .match-layout-right::-webkit-scrollbar { width: 3px; }
    .match-layout-right::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 2px; }
  }

  :global(.match-card) {
    padding: 1.5rem; cursor: pointer; transition: all 0.3s ease;
    position: relative; overflow: hidden;
    border-left: 3px solid var(--border);
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(24px);
    border: 1px solid var(--border);
    border-radius: 20px;
    border-left: 3px solid var(--border);
  }

  /* Inactive: hide expanded content */
  :global(.match-card .mc-countdown),
  :global(.match-card .mc-slots),
  :global(.match-card .mc-register),
  :global(.match-card .mc-maps-btn),
  :global(.match-card .mc-actions) {
    display: none !important;
  }

  /* Secondary action row (active card only).
     Layout: Share spans full width on its own row above the calendar
     pair so it reads as the next-most-important CTA after REGISTER.
     Calendar buttons (Google + Apple) split row 2 evenly. */
  :global(.match-card.active .mc-actions) {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem; margin-top: 0.5rem;
  }
  :global(.match-card .mc-share) { grid-column: 1 / -1; }

  :global(.match-card .mc-action-btn) {
    min-width: 0;
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.4rem; height: 40px; padding: 0 0.7rem;
    background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    color: var(--text-muted); border-radius: 11px;
    font-family: 'Space Grotesk', sans-serif; font-size: 0.72rem;
    font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.1s, box-shadow 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  :global(.match-card .mc-action-btn:hover) {
    color: var(--text); background: rgba(255,255,255,0.08);
    border-color: var(--border-light);
  }
  :global(.match-card .mc-action-btn:active) { transform: scale(0.97); }
  :global(.match-card .mc-action-btn span) {
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* Share button: always neon-tinted (not just on hover) so it stands
     out as the secondary CTA after REGISTER. Slightly larger height
     than the calendar pair below + a subtle neon-glow on hover. */
  :global(.match-card .mc-share) {
    height: 44px;
    background: rgba(0,255,65,0.1);
    border-color: rgba(0,255,65,0.4);
    color: var(--neon);
    font-size: 0.78rem;
  }
  :global(.match-card .mc-share:hover) {
    background: rgba(0,255,65,0.2);
    border-color: rgba(0,255,65,0.6);
    box-shadow: 0 0 20px rgba(0,255,65,0.15);
  }

  [data-theme="light"] :global(.match-card .mc-action-btn) {
    background: rgba(0,0,0,0.03);
    border-color: var(--border);
    color: var(--text-secondary);
  }
  [data-theme="light"] :global(.match-card .mc-action-btn:hover) {
    background: rgba(0,0,0,0.06);
    color: var(--text);
  }

  :global(.match-card .mc-details) { margin-bottom: 0; }

  :global(.match-card:not(.active)) {
    padding: 1rem 1.2rem;
  }

  :global(.match-card:not(.active) .mc-top) { margin-bottom: 0.4rem; }
  :global(.match-card:not(.active) .mc-details) { gap: 0.25rem; }
  :global(.match-card:not(.active) .mc-row) { font-size: 0.75rem; }
  :global(.match-card:not(.active) .mc-badge) { font-size: 0.62rem; padding: 0.2rem 0.6rem; }
  :global(.match-card:not(.active) .mc-fee) { font-size: 0.9rem; }

  :global(.match-card:not(.active):hover) {
    background: rgba(0,255,65,0.03);
    border-left-color: rgba(0,255,65,0.4);
    border-color: rgba(0,255,65,0.1);
  }

  /* Active: full hero card */
  :global(.match-card.active) {
    padding: 1.5rem;
    border-left: 4px solid var(--neon);
    background: linear-gradient(135deg, rgba(0,255,65,0.05) 0%, rgba(14,14,14,0.95) 40%, rgba(0,196,255,0.02) 100%);
    box-shadow: 0 0 40px rgba(0,255,65,0.06), inset 0 1px 0 rgba(0,255,65,0.1);
    border-color: rgba(0,255,65,0.15);
    animation: cardIn 0.35s ease;
  }

  :global(.match-card.active)::after {
    content: ''; position: absolute; top: -20px; right: -20px;
    width: 140px; height: 140px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,255,65,0.07), transparent 70%);
    pointer-events: none;
  }

  :global(.match-card.active .mc-countdown),
  :global(.match-card.active .mc-register),
  :global(.match-card.active .mc-maps-btn) {
    display: flex !important;
  }
  :global(.match-card.active .mc-slots) {
    display: block !important;
  }

  :global(.match-card.active .mc-register) {
    display: flex !important;
    width: 100%;
  }

  :global(.match-card.active .mc-details) { margin-bottom: 1.2rem; }

  @keyframes cardIn { from { opacity: 0.5; transform: scale(0.98); } to { opacity: 1; transform: none; } }

  :global(.mc-top) { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  :global(.mc-badge) {
    background: var(--neon); color: #000; padding: 0.3rem 0.9rem; border-radius: 8px;
    font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
  }
  :global(.mc-fee) { font-family: 'Space Grotesk', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--text); }

  :global(.mc-details) { display: flex; flex-direction: column; gap: 0.5rem; }
  :global(.mc-row) { display: flex; align-items: center; gap: 0.6rem; font-size: 0.88rem; color: var(--text-secondary); }
  :global(.mc-row svg) { color: var(--neon); flex-shrink: 0; opacity: 0.7; }

  :global(.mc-countdown) {
    text-align: center; font-family: 'Space Grotesk', monospace; font-size: 2rem; font-weight: 700;
    color: var(--neon); padding: 0.8rem 0; letter-spacing: 0.05em;
    text-shadow: 0 0 30px var(--neon-glow);
    background: radial-gradient(ellipse at center, rgba(0,255,65,0.06), transparent 70%);
    border-radius: 12px; margin-bottom: 1rem;
  }
  :global(.mc-countdown.live) { animation: pulse 1s infinite; color: var(--orange); }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

  :global(.mc-slots) { margin-bottom: 1.2rem; }
  :global(.mc-slots-header) { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
  :global(.mc-slots-label) { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); letter-spacing: 0.08em; }
  :global(.mc-spots) { font-size: 0.78rem; font-weight: 700; color: var(--neon); }
  :global(.mc-spots--full) { color: var(--orange); }

  :global(.progress-track) { width: 100%; height: 6px; background: rgba(255,255,255,0.06); border-radius: 100px; overflow: hidden; }
  :global(.progress-fill) {
    height: 100%; background: linear-gradient(90deg, var(--neon-dim), var(--neon)); border-radius: 100px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 12px var(--neon-glow);
    position: relative;
  }
  :global(.progress-fill::after) {
    content: ''; position: absolute; right: 0; top: -1px; bottom: -1px; width: 10px;
    background: var(--neon); border-radius: 50%; box-shadow: 0 0 8px var(--neon);
  }
  :global(.progress-fill--full) { background: linear-gradient(90deg, #cc7a00, var(--orange)); box-shadow: 0 0 12px rgba(255,149,0,0.3); }
  :global(.progress-fill--full::after) { background: var(--orange); box-shadow: 0 0 8px var(--orange); }

  /* Activity-proof chip — surfaces momentum next to the REGISTER CTA.
     Shown only on the active card when recentJoins24h > 0. */
  :global(.mc-recent) {
    margin-top: 0.7rem;
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: rgba(255, 149, 0, 0.08);
    border: 1px solid rgba(255, 149, 0, 0.22);
    border-radius: 100px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--orange);
    letter-spacing: 0.02em;
  }
  :global(.mc-recent svg) { flex-shrink: 0; }
  [data-theme="light"] :global(.mc-recent) {
    background: rgba(232, 120, 0, 0.07);
    border-color: rgba(232, 120, 0, 0.25);
  }
  /* When the lineup is locked we set the fill to .progress-fill--hidden.
     Use :has() to also collapse the surrounding track so no empty grey
     line is left behind — players shouldn't be able to read fullness. */
  :global(.progress-track:has(.progress-fill--hidden)) { visibility: hidden; height: 0; margin: 0; }

  :global(.mc-maps-btn) {
    display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 1rem;
    background: rgba(0,255,65,0.04); border: 1px solid rgba(0,255,65,0.12);
    border-radius: 14px; text-decoration: none; color: inherit;
    margin-bottom: 1rem; transition: all 0.25s; cursor: pointer;
  }
  :global(.mc-maps-btn:hover) {
    background: rgba(0,255,65,0.08); border-color: rgba(0,255,65,0.25);
    transform: translateX(2px);
  }
  :global(.mc-maps-icon) {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(0,255,65,0.1); display: flex; align-items: center; justify-content: center;
    color: var(--neon); flex-shrink: 0;
  }
  :global(.mc-maps-text) { flex: 1; min-width: 0; }
  :global(.mc-maps-label) { display: block; font-size: 0.72rem; font-weight: 700; color: var(--neon); letter-spacing: 0.04em; }
  :global(.mc-maps-loc) { display: block; font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.mc-maps-arrow) { color: var(--text-muted); flex-shrink: 0; transition: transform 0.2s; }
  :global(.mc-maps-btn:hover .mc-maps-arrow) { transform: translateX(3px); color: var(--neon); }

  /* Lineup */
  .section-header { display: flex; justify-content: space-between; align-items: center; margin: 1.5rem 0 1rem; }
  .section-title { font-size: 1.2rem; }
  .lineup-count { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; letter-spacing: 0.08em; }

  :global(.lineup-grid) { display: grid; grid-template-columns: repeat(auto-fill, minmax(95px, 1fr)); gap: 0.5rem; }
  :global(.player-card) {
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
    padding: 0.9rem 0.4rem; background: rgba(255,255,255,0.02);
    border: 1px solid var(--border); border-radius: 16px;
    transition: all 0.25s; position: relative; overflow: hidden;
  }
  :global(.player-card::before) {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(0,255,65,0.04), transparent 70%);
    opacity: 0; transition: opacity 0.25s;
  }
  :global(.player-card:hover) { transform: translateY(-3px); border-color: var(--border-light); }
  :global(.player-card:hover::before) { opacity: 1; }
  :global(.player-avatar) {
    width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 800; border: 2px solid;
    font-family: 'Space Grotesk', sans-serif; position: relative; z-index: 1;
  }
  :global(.player-name) {
    font-size: 0.68rem; font-weight: 600; color: var(--text-secondary); text-align: center;
    line-height: 1.2; max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    position: relative; z-index: 1;
  }

  .lineup-empty { text-align: center; padding: 2rem; color: var(--text-muted); font-style: italic; font-size: 0.88rem; }

  /* ===== 3-TEAM POSITION BUILDER ===== */
  #teamBuilder { margin: 1.4rem 0 0.5rem; }
  .tb-head { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .tb-sub { font-size: 0.74rem; color: var(--text-muted); }
  .tb-summary { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.5rem; margin-bottom: 0.7rem; }
  .tb-stat { background: rgba(0,255,65,0.03); border: 1px solid var(--border); border-radius: 12px; padding: 0.6rem; text-align: center; }
  .tb-stat-num { font-family: 'Space Grotesk', sans-serif; font-size: 1.3rem; font-weight: 700; line-height: 1; }
  .tb-stat-label { font-size: 0.58rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 3px; }
  .tb-legend { display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; padding: 0.55rem 0.8rem; margin-bottom: 0.9rem;
    background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 12px; font-size: 0.68rem; color: var(--text-secondary); }
  .tb-leg { display: flex; align-items: center; gap: 0.35rem; }
  .tb-leg-dot { width: 13px; height: 13px; border-radius: 50%; flex-shrink: 0; }
  .tb-leg-dot--paid { background: var(--neon); }
  .tb-leg-dot--pending { background: var(--orange); }
  .tb-leg-dot--empty { border: 1.5px dashed var(--text-muted); }

  .tb-pitches { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 720px) { .tb-pitches { grid-template-columns: repeat(3,1fr); } }

  .tb-pitch-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 0.8rem; overflow: hidden; }
  .tb-pitch-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.6rem; }
  .tb-team-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .tb-team-name { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.04em; }
  .tb-pitch-count { margin-left: auto; font-size: 0.72rem; color: var(--text-secondary); font-weight: 600; }
  .tb-progress { height: 4px; background: rgba(255,255,255,0.06); border-radius: 100px; overflow: hidden; margin-bottom: 0.6rem; }
  .tb-progress-fill { height: 100%; border-radius: 100px; transition: width 0.4s; }

  .tb-pitch {
    position: relative; width: 100%; aspect-ratio: 3 / 4; border-radius: 12px; overflow: hidden;
    background: repeating-linear-gradient(0deg, #0c2912 0, #0c2912 11.11%, #0a1f0e 11.11%, #0a1f0e 22.22%);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .tb-lines { position: absolute; inset: 0; }
  .tb-pl { position: absolute; }
  .tb-pl-outline { inset: 4%; border: 1.5px solid rgba(255,255,255,0.12); border-radius: 3px; }
  .tb-pl-halfway { left: 4%; right: 4%; top: 50%; border-top: 1.5px solid rgba(255,255,255,0.12); }
  .tb-pl-circle { left: 50%; top: 50%; width: 26%; aspect-ratio: 1; transform: translate(-50%,-50%);
    border: 1.5px solid rgba(255,255,255,0.12); border-radius: 50%; }
  .tb-pl-box-top { left: 26%; right: 26%; top: 4%; height: 15%; border: 1.5px solid rgba(255,255,255,0.12); border-top: none; }
  .tb-pl-box-bot { left: 26%; right: 26%; bottom: 4%; height: 15%; border: 1.5px solid rgba(255,255,255,0.12); border-bottom: none; }

  .tb-slot {
    position: absolute; transform: translate(-50%,-50%); width: 60px;
    display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: default;
  }
  .tb-slot--empty { cursor: pointer; }
  .tb-slot-dot {
    width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.8rem; transition: transform 0.15s, box-shadow 0.15s;
  }
  .tb-slot--empty:active .tb-slot-dot { transform: scale(0.92); }
  .tb-slot-name {
    font-size: 0.58rem; font-weight: 600; max-width: 60px; text-align: center;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .tb-slot--empty .tb-slot-dot {
    background: rgba(0,0,0,0.25); border: 1.5px dashed rgba(255,255,255,0.3); color: rgba(255,255,255,0.45);
  }
  .tb-slot--empty:hover .tb-slot-dot { border-color: var(--tb-color); color: var(--tb-color); box-shadow: 0 0 0 4px rgba(255,255,255,0.04); }
  .tb-slot--empty .tb-slot-name { color: rgba(255,255,255,0.35); }
  .tb-slot--paid .tb-slot-dot {
    background: color-mix(in srgb, var(--tb-color) 22%, #000); border: 2px solid var(--tb-color); color: var(--tb-color);
  }
  .tb-slot--paid .tb-slot-name { color: #fff; }
  .tb-slot--pending .tb-slot-dot {
    background: rgba(255,149,0,0.18); border: 2px solid var(--orange); color: var(--orange);
  }
  .tb-slot--pending .tb-slot-name { color: var(--orange); }

  /* Booking context banner inside the registration modal */
  .booking-ctx {
    display: flex; align-items: center; gap: 0.6rem; padding: 0.65rem 0.8rem;
    border-radius: 12px; margin-bottom: 1rem;
    background: rgba(0,255,65,0.05); border: 1px solid rgba(0,255,65,0.2);
  }
  .booking-ctx-dot {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.78rem;
    background: rgba(0,255,65,0.15); color: var(--neon); border: 2px solid var(--neon);
  }
  .booking-ctx-pos { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.92rem; color: var(--text); }
  .booking-ctx-team { font-size: 0.72rem; color: var(--text-secondary); }

  /* Locked lineup placeholder — shown until 2 days before the match to
     nudge players to register early without being able to scout the list. */
  .lineup-locked {
    text-align: center;
    padding: 2.2rem 1.2rem;
    background: rgba(0,255,65,0.03);
    border: 1px dashed rgba(0,255,65,0.18);
    border-radius: 14px;
  }
  .lineup-locked-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; border-radius: 50%;
    background: rgba(0,255,65,0.08); border: 1px solid rgba(0,255,65,0.22);
    color: var(--neon); margin-bottom: 0.7rem;
  }
  .lineup-locked-title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700;
    font-size: 0.92rem; letter-spacing: 0.06em; text-transform: uppercase;
    margin: 0 0 0.35rem; color: var(--neon);
  }
  .lineup-locked-sub {
    margin: 0; font-size: 0.78rem; line-height: 1.5;
    color: var(--text-secondary); max-width: 32ch; margin-inline: auto;
  }

  /* Share */
  .share-section { margin: 1.5rem 0 2rem; }

  :global(.upload-area-mini) {
    display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 0.8rem;
    background: rgba(0,255,65,0.04); border: 1.5px dashed rgba(0,255,65,0.2);
    border-radius: 10px; cursor: pointer; transition: all 0.2s;
    font-size: 0.78rem; color: var(--neon); font-weight: 600;
  }
  :global(.upload-area-mini:hover) { background: rgba(0,255,65,0.08); border-color: var(--neon); }

  /* Inline payment block inside status cards — shown for Pending/Overdue so
     promoted waitlist players (and anyone who forgot to pay) can scan the QR
     without backing out to the registration modal. */
  :global(.status-pay) {
    margin-top: 0.7rem; padding: 0.8rem;
    background: rgba(0,255,65,0.03); border: 1px solid rgba(0,255,65,0.15);
    border-radius: 12px; text-align: center;
  }
  :global(.status-pay-label) {
    font-size: 0.72rem; font-weight: 600; color: var(--text-muted);
    margin: 0 0 0.55rem; letter-spacing: 0.04em;
  }
  :global(.status-pay-qr) {
    display: block; width: 100%; max-width: 220px; height: auto;
    margin: 0 auto 0.6rem;
    border-radius: 12px; border: 1px solid var(--border);
  }

  :global(.wa-group-banner) {
    display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem;
    background: linear-gradient(135deg, rgba(37,211,102,0.08), rgba(37,211,102,0.02));
    border: 1px solid rgba(37,211,102,0.2); border-radius: 16px;
    text-decoration: none; color: inherit; transition: all 0.25s;
  }
  :global(.wa-group-banner:hover) {
    background: rgba(37,211,102,0.12); border-color: rgba(37,211,102,0.35);
    transform: translateX(2px);
  }
  :global(.wa-group-icon) {
    width: 40px; height: 40px; border-radius: 12px;
    background: rgba(37,211,102,0.15); display: flex; align-items: center; justify-content: center;
    color: #25D366; flex-shrink: 0;
  }
  :global(.wa-group-text) { flex: 1; min-width: 0; }
  :global(.wa-group-label) { display: block; font-size: 0.75rem; font-weight: 700; color: #25D366; letter-spacing: 0.04em; }
  :global(.wa-group-sub) { display: block; font-size: 0.7rem; color: var(--text-muted); }
  :global(.wa-group-arrow) { color: var(--text-muted); flex-shrink: 0; transition: transform 0.2s; }
  :global(.wa-group-banner:hover .wa-group-arrow) { transform: translateX(3px); color: #25D366; }

  /* ===== LIGHT THEME OVERRIDES ===== */

  /* Header */
  :global([data-theme="light"]) .header {
    background: rgba(246,246,242,0.92);
    border-bottom-color: var(--border);
  }

  :global([data-theme="light"]) .header::after {
    background: linear-gradient(90deg, transparent, rgba(0,134,58,0.1), transparent);
  }

  :global([data-theme="light"]) .brand-name {
    color: var(--text);
  }

  :global([data-theme="light"]) .admin-btn {
    border-color: var(--border);
    color: var(--text-muted);
  }

  :global([data-theme="light"]) .admin-btn:hover {
    border-color: var(--neon);
    color: var(--neon);
  }

  /* Match cards */
  :global([data-theme="light"] .match-card) {
    background: #ffffff;
    border-color: var(--border);
    border-left-color: var(--border);
  }

  :global([data-theme="light"] .match-card:not(.active):hover) {
    background: rgba(0,134,58,0.03);
    border-left-color: var(--neon);
    border-color: rgba(0,134,58,0.15);
  }

  :global([data-theme="light"] .match-card.active) {
    background: linear-gradient(135deg, rgba(0,134,58,0.04) 0%, #ffffff 40%, rgba(0,144,196,0.02) 100%);
    border-left-color: var(--neon);
    border-color: rgba(0,134,58,0.15);
    box-shadow: 0 4px 24px rgba(0,134,58,0.06), 0 1px 0 rgba(0,134,58,0.08);
  }

  :global([data-theme="light"] .match-card.active)::after {
    background: radial-gradient(circle, rgba(0,134,58,0.04), transparent 70%);
  }

  /* Match card internals */
  :global([data-theme="light"] .mc-badge) {
    background: var(--neon);
