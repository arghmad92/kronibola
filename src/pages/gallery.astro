---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Photo Gallery — KroniBola" description="Photo gallery from KroniBola football pickup games. Match day moments captured." activeTab="gallery">
  <header class="page-header">
    <div class="container">
      <h1 class="page-title">PHOTO <span class="neon-text">GALLERY</span></h1>
      <p class="page-sub">Highlights from the pitch</p>
    </div>
  </header>

  <main class="container gallery-container">
    <div id="loading" class="loading"><div class="loader"></div></div>
    <div id="galleryGrid" class="gallery-grid"></div>
    <div id="viewAllWrap" style="display:none" class="view-all-wrap">
      <a id="viewAllLink" href="#" target="_blank" rel="noopener" class="btn btn--primary view-all-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        VIEW ALL PHOTOS
      </a>
    </div>
    <p id="empty" style="display:none" class="empty">No photos yet. Check back after game day!</p>
  </main>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">&times;</button>
    <img class="lightbox-img" id="lightboxImg" src="" alt="" />
    <p class="lightbox-caption" id="lightboxCaption"></p>
  </div>
</Layout>

<script>
  async function load() {
    try {
      const res = await fetch('/api/gallery');
      const data = await res.json();
      const photos = data.photos || [];

      document.getElementById('loading')!.style.display = 'none';

      if (!photos.length) {
        document.getElementById('empty')!.style.display = '';
        return;
      }
      document.getElementById('viewAllWrap')!.style.display = '';
      // Wire the "View all photos" link to whatever folder the API is
      // serving. Stops the link from drifting behind FOLDER_ID after a
      // session swap (which it had — it was still pointing at the 19/4
      // session folder).
      const folderUrl = (data && data.folderUrl) || '';
      if (folderUrl) {
        (document.getElementById('viewAllLink') as HTMLAnchorElement).href = folderUrl;
      }

      const grid = document.getElementById('galleryGrid')!;
      grid.innerHTML = photos.map((p: any, i: number) => `
        <div class="gallery-card" data-url="${p.fullUrl || p.url}" data-caption="${p.caption}" style="animation-delay:${i * 0.06}s">
          <div class="gallery-img-wrap">
            <img src="${p.url}" alt="${p.caption}" loading="lazy" />
            <div class="gallery-overlay">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </div>
          </div>
          <div class="gallery-info">
            <p class="gallery-caption">${p.caption}</p>
            ${p.date ? `<p class="gallery-date">${p.date}</p>` : ''}
          </div>
        </div>
      `).join('');

      // Lightbox
      const lightbox = document.getElementById('lightbox')!;
      const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
      const lightboxCaption = document.getElementById('lightboxCaption')!;

      grid.addEventListener('click', (e: Event) => {
        const card = (e.target as HTMLElement).closest('.gallery-card') as HTMLElement | null;
        if (!card) return;
        lightboxImg.src = card.dataset.url || '';
        lightboxCaption.textContent = card.dataset.caption || '';
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      });

      document.getElementById('lightboxClose')!.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e: Event) => { if (e.target === lightbox) closeLightbox(); });
      document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLightbox(); });

      function closeLightbox() {
        lightbox.classList.remove('active');
        document.body.style.overflow = '';
      }
    } catch {
      document.getElementById('loading')!.innerHTML = '<p style="color:var(--red)">Failed to load gallery.</p>';
    }
  }
  load();
</script>

<style is:global>
  .gallery-grid { columns: 2; column-gap: 0.6rem; padding: 1rem 0 2rem; }

  .gallery-card {
    break-inside: avoid; margin-bottom: 0.6rem; border-radius: 16px; overflow: hidden;
    background: var(--card); border: 1px solid var(--border); cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s; animation: cardFade 0.4s ease both;
  }
  .gallery-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,255,65,0.06); border-color: var(--border-light); }
  @keyframes cardFade { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  .gallery-img-wrap { position: relative; overflow: hidden; }
  .gallery-img-wrap img { width: 100%; display: block; transition: transform 0.3s; }
  .gallery-card:hover .gallery-img-wrap img { transform: scale(1.05); }

  .gallery-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.25s; color: var(--neon);
  }
  .gallery-card:hover .gallery-overlay { opacity: 1; }

  .gallery-info { padding: 0.6rem 0.75rem; }
  .gallery-caption { font-size: 0.75rem; font-weight: 500; color: var(--text); line-height: 1.4; }
  .gallery-date { font-size: 0.62rem; color: var(--text-muted); margin-top: 0.15rem; font-weight: 600; }

  .lightbox {
    position: fixed; inset: 0; z-index: 400; background: rgba(0,0,0,0.92); backdrop-filter: blur(16px);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1.5rem; opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .lightbox.active { opacity: 1; pointer-events: auto; }
  .lightbox-close {
    position: absolute; top: 1rem; right: 1rem; background: rgba(255,255,255,0.08);
    border: 1px solid var(--border); color: var(--text); width: 40px; height: 40px;
    border-radius: 12px; font-size: 1.4rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center; transition: all 0.2s; z-index: 1;
  }
  .lightbox-close:hover { background: rgba(255,255,255,0.15); color: var(--neon); }
  .lightbox-img { max-width: 90vw; max-height: 75vh; border-radius: 16px; object-fit: contain; transform: scale(0.95); transition: transform 0.3s; }
  .lightbox.active .lightbox-img { transform: scale(1); }
  .lightbox-caption { margin-top: 1rem; font-size: 0.85rem; color: var(--text-secondary); text-align: center; max-width: 500px; }

  .view-all-wrap { text-align: center; padding: 0.5rem 0 2rem; }
  .view-all-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; }

  @media (max-width: 360px) { .gallery-grid { columns: 1; } }
  @media (min-width: 641px) { .gallery-grid { columns: 3; } }
  @media (min-width: 900px) {
    .gallery-container { max-width: 1100px; }
    .gallery-grid { columns: 4; }
  }
</style>
