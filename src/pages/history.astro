---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Match History — KroniBola" description="Browse past KroniBola football matches, scores, and attendance records." activeTab="history">
  <header class="page-header">
    <div class="container">
      <h1 class="page-title">MATCH <span class="neon-text">HISTORY</span></h1>
      <p class="page-sub">Past games and who played</p>
    </div>
  </header>

  <main class="container">
    <div id="loading" class="loading"><div class="loader"></div></div>
    <div id="historyList" class="history-list"></div>
    <p id="empty" style="display:none" class="empty">No past games yet.</p>
  </main>
</Layout>

<script>
  async function load() {
    try {
      const [sRes, pRes] = await Promise.all([fetch('/api/sessions'), fetch('/api/players')]);
      const sessions = (await sRes.json()).sessions || [];
      const allPlayers = (await pRes.json()).players || [];

      document.getElementById('loading')!.style.display = 'none';

      const closed = sessions.filter((s: any) => s.Status === 'Closed');
      if (!closed.length) { document.getElementById('empty')!.style.display = ''; return; }

      const list = document.getElementById('historyList')!;
      const colors = ['#00FF41', '#00c4ff', '#ff9500', '#e040fb', '#ff5252', '#40c4ff', '#69f0ae', '#ffd740'];

      list.innerHTML = closed.map((s: any, si: number) => {
        const gamePlayers = allPlayers.filter((p: any) => String(p['Session Date']) === s.Date && p['Payment Status'] === 'Paid');
        const avatars = gamePlayers.slice(0, 10).map((p: any, i: number) => {
          const init = (p['Player Name'] || '?')[0].toUpperCase();
          const c = colors[i % colors.length];
          return `<div class="h-avatar" style="background:${c}15;color:${c};border-color:${c}30">${init}</div>`;
        }).join('');
        const extra = gamePlayers.length > 10 ? `<span class="h-more">+${gamePlayers.length - 10}</span>` : '';

        return `<div class="history-card glass" style="animation-delay:${si * 0.08}s">
          <div class="hc-accent"></div>
          <div class="hc-top">
            <div>
              <span class="hc-name">${s['Session Name']}</span>
              <div class="hc-info">
                <span>${s.Location}</span><span class="hc-dot">·</span><span>${s.Time}</span>
              </div>
            </div>
            <div class="hc-right">
              <span class="hc-date">${s.Date}</span>
              <span class="hc-players">${gamePlayers.length} players</span>
            </div>
          </div>
          <div class="hc-avatars">${avatars}${extra}</div>
        </div>`;
      }).join('');
    } catch {
      document.getElementById('loading')!.innerHTML = '<p style="color:var(--red)">Failed to load.</p>';
    }
  }
  load();
</script>

<style>
  .loading { text-align: center; padding: 3rem 0; }
  .loader { width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--neon); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .empty { text-align: center; padding: 3rem; color: var(--text-muted); }

  :global(.history-list) { display: flex; flex-direction: column; gap: 0.7rem; padding: 1.2rem 0 2rem; }

  :global(.history-card) {
    padding: 1.3rem; position: relative; overflow: hidden;
    background: var(--card); backdrop-filter: blur(24px);
    border: 1px solid var(--border); border-radius: 20px;
    animation: fadeUp 0.4s ease both;
  }

  :global(.history-card::before) {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.15), transparent);
  }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  :global(.hc-accent) {
    position: absolute; top: 0; left: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, var(--neon), transparent);
  }

  :global(.hc-top) { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.8rem; gap: 1rem; }
  :global(.hc-name) { font-family: 'Space Grotesk'; font-weight: 700; font-size: 0.95rem; display: block; margin-bottom: 0.2rem; }
  :global(.hc-info) { display: flex; gap: 0.3rem; font-size: 0.75rem; color: var(--text-muted); flex-wrap: wrap; }
  :global(.hc-dot) { color: var(--border-light); }
  :global(.hc-right) { text-align: right; flex-shrink: 0; }
  :global(.hc-date) { font-size: 0.72rem; color: var(--text-secondary); display: block; }
  :global(.hc-players) { font-size: 0.68rem; color: var(--neon); font-weight: 600; }

  :global(.hc-avatars) { display: flex; gap: 0.25rem; align-items: center; flex-wrap: wrap; }
  :global(.h-avatar) {
    width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.62rem; font-weight: 800; border: 1.5px solid; font-family: 'Space Grotesk';
  }
  :global(.h-more) { font-size: 0.7rem; color: var(--text-muted); margin-left: 0.2rem; font-weight: 600; }
</style>
