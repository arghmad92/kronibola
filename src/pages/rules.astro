---
import Layout from '../layouts/Layout.astro';
---

<Layout title="House Rules — KroniBola" activeTab="rules">
  <header class="page-header">
    <div class="container">
      <h1 class="page-title">HOUSE <span class="neon-text">RULES</span></h1>
      <p class="page-sub">Read before you play</p>
    </div>
  </header>

  <main class="container">
    <div class="rules-list">

      <div class="rule-card glass">
        <div class="rule-num">01</div>
        <div class="rule-content">
          <h3>Punctuality</h3>
          <p>Be at the venue <strong>15 minutes</strong> before kick-off. Late arrivals may lose their slot to waitlist players without refund.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">02</div>
        <div class="rule-content">
          <h3>Payment</h3>
          <p>Pay via <strong>Touch 'n Go</strong> within 1 hour of registering. Unpaid slots will be released to the waitlist. <strong>No cash</strong> on game day.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">03</div>
        <div class="rule-content">
          <h3>Cancellations</h3>
          <p>Cancel at least <strong>6 hours</strong> before the game for a full refund. Late cancellations are <strong>non-refundable</strong>.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">04</div>
        <div class="rule-content">
          <h3>Fair Play</h3>
          <p>Play fair, respect all players. <strong>No dangerous tackles</strong>. The admin reserves the right to ban repeat offenders.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">05</div>
        <div class="rule-content">
          <h3>Kit</h3>
          <p><strong>Bibs will be provided</strong> for team split — no need to bring extra shirts. Wear <strong>futsal shoes or boots</strong> depending on the field (indoor/outdoor). Shin guards recommended.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">06</div>
        <div class="rule-content">
          <h3>Hydration</h3>
          <p>Bring your own <strong>water bottle</strong>. We play hard — stay hydrated. No glass bottles on the pitch.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">07</div>
        <div class="rule-content">
          <h3>Communication</h3>
          <p>All announcements via <strong>WhatsApp group</strong>. If you can't make it, notify the admin ASAP — don't ghost.</p>
        </div>
      </div>

      <div class="rule-card glass">
        <div class="rule-num">08</div>
        <div class="rule-content">
          <h3>Team Selection</h3>
          <p>Teams are split <strong>randomly or balanced</strong> by the admin. No cherry-picking. Rotate goalkeepers.</p>
        </div>
      </div>
    </div>

    <div class="cta-card glass">
      <div class="cta-glow"></div>
      <h3>GOT <span class="neon-text">QUESTIONS?</span></h3>
      <p>Message the admin directly on WhatsApp.</p>
      <a href="https://wa.me/60126183827" target="_blank" class="btn btn--wa" style="width:100%">WHATSAPP ADMIN</a>
    </div>
  </main>
</Layout>

<style>
  .rules-list { display: flex; flex-direction: column; gap: 0.6rem; padding: 1.2rem 0; }

  .rule-card {
    padding: 1.2rem; display: flex; gap: 1rem; align-items: flex-start;
    animation: fadeUp 0.35s ease both;
    transition: border-color 0.2s;
  }

  .rule-card:nth-child(1) { animation-delay: 0s; }
  .rule-card:nth-child(2) { animation-delay: 0.05s; }
  .rule-card:nth-child(3) { animation-delay: 0.1s; }
  .rule-card:nth-child(4) { animation-delay: 0.15s; }
  .rule-card:nth-child(5) { animation-delay: 0.2s; }
  .rule-card:nth-child(6) { animation-delay: 0.25s; }
  .rule-card:nth-child(7) { animation-delay: 0.3s; }
  .rule-card:nth-child(8) { animation-delay: 0.35s; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  .rule-card:hover { border-color: var(--border-light); }

  .rule-num {
    font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700;
    color: rgba(0,255,65,0.15); line-height: 1; flex-shrink: 0; min-width: 36px;
    text-align: center;
  }

  .rule-content { flex: 1; }

  .rule-content h3 {
    font-size: 0.92rem; font-family: 'Space Grotesk', sans-serif;
    font-weight: 700; color: var(--text); margin-bottom: 0.3rem;
  }

  .rule-content p {
    font-size: 0.82rem; color: var(--text-secondary); line-height: 1.65; font-weight: 400;
  }

  .rule-content strong { color: var(--neon); font-weight: 600; }

  .cta-card {
    padding: 2rem 1.5rem; text-align: center; margin: 0.5rem 0 2rem;
    position: relative; overflow: hidden;
  }

  .cta-glow {
    position: absolute; top: -40px; left: 50%; transform: translateX(-50%);
    width: 200px; height: 80px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,255,65,0.1), transparent);
    pointer-events: none;
  }

  .cta-card h3 {
    font-size: 1.1rem; margin-bottom: 0.4rem; position: relative;
    font-family: 'Space Grotesk', sans-serif;
  }

  .cta-card p { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 1.2rem; position: relative; }
</style>
