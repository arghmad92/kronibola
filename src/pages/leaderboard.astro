---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leaderboard — KroniBola" description="See the most active KroniBola players ranked by match attendance and reliability." activeTab="leaderboard">
  <header class="page-header">
    <div class="container">
      <h1 class="page-title">LEADER<span class="neon-text">BOARD</span></h1>
      <p class="page-sub">Most reliable ballers</p>
    </div>
  </header>

  <main class="container board-container">
    <div id="loading" class="loading"><div class="loader"></div></div>
    <div id="board"></div>
  </main>
</Layout>

<script>
  async function load() {
    try {
      const res = await fetch('/api/players');
      const data = await res.json();
      const players = (data.players || []).filter((p: any) => p['Payment Status'] === 'Paid');

      document.getElementById('loading')!.style.display = 'none';

      // Group by player name. Phone isn't a reliable identity key since a
      // person often registers for friends using their own phone, which would
      // merge separate players into one record and inflate their count.
      // Names are Title-Cased at registration (see functions/api/register.js),
      // so case/whitespace drift can't split one player into two.
      const nameMap: Record<string, { name: string; count: number }> = {};
      players.forEach((p: any) => {
        const displayName = String(p['Player Name'] || '').trim();
        if (!displayName) return;
        const key = displayName.toLowerCase().replace(/\s+/g, ' ');
        if (!nameMap[key]) nameMap[key] = { name: displayName, count: 0 };
        nameMap[key].count += 1;
      });

      const sorted = Object.values(nameMap)
        .map((v) => [v.name, v.count] as [string, number])
        .sort((a, b) => b[1] - a[1]);
      if (!sorted.length) {
        document.getElementById('board')!.innerHTML = '<p class="empty">No data yet. Play some games!</p>';
        return;
      }

      const colors = ['#00FF41', '#00c4ff', '#ff9500', '#e040fb', '#ff5252', '#40c4ff', '#69f0ae', '#ffd740'];
      const medals = ['&#129351;', '&#129352;', '&#129353;'];

      // MVP section — featured #1 player
      const mvp = sorted[0];
      const mvpName = mvp[0];
      const mvpCount = mvp[1];
      const mvpInitials = mvpName.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);

      document.getElementById('board')!.innerHTML = `
        <div class="mvp-section glass">
          <div class="mvp-glow"></div>
          <div class="mvp-badge">&#11088; MVP</div>
          <div class="mvp-avatar" style="background:#00FF4118;color:#00FF41;border-color:#00FF41">${mvpInitials}</div>
          <div class="mvp-name">${mvpName}</div>
          <div class="mvp-stats">${mvpCount} GAMES</div>
          <div class="mvp-label">MOST ACTIVE PLAYER</div>
        </div>

        <div class="podium-section">
          <div class="podium">
            ${sorted.slice(0, 3).map(([name, count], i) => {
              const init = name.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);
              const c = colors[i];
              const heights = [130, 100, 75];
              const sizes = [56, 48, 44];
              return `<div class="podium-item" style="order:${[1, 0, 2][i]}">
                <div class="podium-avatar" style="width:${sizes[i]}px;height:${sizes[i]}px;background:${c}18;color:${c};border-color:${c};box-shadow:0 0 20px ${c}20">${init}</div>
                <span class="podium-medal">${medals[i]}</span>
                <span class="podium-name">${name}</span>
                <span class="podium-count">${count} games</span>
                <div class="podium-bar" style="height:${heights[i]}px">
                  <div class="podium-bar-inner" style="background:linear-gradient(180deg, ${c}30, ${c}08);border-color:${c}30"></div>
                  <span class="podium-rank">${i + 1}</span>
                </div>
              </div>`;
            }).join('')}
          </div>
        </div>

        ${sorted.length > 3 ? `<div class="rank-section glass">
          <div class="rank-header">
            <span class="rank-header-text">RANK</span>
            <span class="rank-header-text" style="flex:1">PLAYER</span>
            <span class="rank-header-text">GAMES</span>
          </div>
          ${sorted.slice(3).map(([name, count], i) => {
            const init = name.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);
            const c = colors[(i + 3) % colors.length];
            return `<div class="rank-row" style="animation-delay:${i * 0.05}s">
              <span class="rank-num">${i + 4}</span>
              <div class="rank-player">
                <div class="rank-avatar" style="background:${c}15;color:${c};border-color:${c}25">${init}</div>
                <span class="rank-name">${name}</span>
              </div>
              <div class="rank-bar-wrap">
                <div class="rank-bar" style="width:${Math.round(count / sorted[0][1] * 100)}%;background:${c}25"></div>
                <span class="rank-count" style="color:${c}">${count}</span>
              </div>
            </div>`;
          }).join('')}
        </div>` : ''}
      `;
    } catch {
      document.getElementById('loading')!.innerHTML = '<p style="color:var(--red)">Failed to load.</p>';
    }
  }
  load();
</script>

<style>
  .loading { text-align: center; padding: 3rem 0; }
  .loader { width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--neon); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .empty { text-align: center; padding: 3rem; color: var(--text-muted); font-size: 0.88rem; }

  :global(.mvp-section) {
    text-align: center; padding: 2rem 1.5rem; margin: 1rem 0;
    border-color: rgba(0,255,65,0.2); position: relative; overflow: hidden;
    background: linear-gradient(135deg, rgba(0,255,65,0.04), rgba(14,14,14,0.95));
    animation: fadeUp 0.4s ease both;
  }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  :global(.mvp-glow) {
    position: absolute; top: -40px; left: 50%; transform: translateX(-50%);
    width: 200px; height: 100px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,255,65,0.1), transparent);
    pointer-events: none;
  }

  :global(.mvp-badge) {
    display: inline-block; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.15em;
    padding: 0.3rem 0.9rem; border-radius: 8px; margin-bottom: 1rem;
    background: var(--neon); color: #000; position: relative;
  }

  :global(.mvp-avatar) {
    width: 72px; height: 72px; border-radius: 50%; margin: 0 auto 0.8rem;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; font-weight: 800; border: 2.5px solid;
    font-family: 'Space Grotesk'; position: relative;
    box-shadow: 0 0 30px rgba(0,255,65,0.15);
  }

  :global(.mvp-name) {
    font-family: 'Space Grotesk'; font-size: 1.3rem; font-weight: 700;
    margin-bottom: 0.3rem; position: relative;
  }

  :global(.mvp-stats) {
    font-family: 'Space Grotesk'; font-size: 1.1rem; font-weight: 700;
    color: var(--neon); margin-bottom: 0.2rem; position: relative;
    text-shadow: 0 0 20px rgba(0,255,65,0.2);
  }

  :global(.mvp-label) {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
    color: var(--text-muted); position: relative;
  }

  :global(.podium-section) {
    padding: 2rem 0 1.5rem;
    background: radial-gradient(ellipse at 50% 100%, rgba(0,255,65,0.04), transparent 60%);
    border-radius: 20px; margin: 1rem 0;
  }

  :global(.podium) { display: flex; align-items: flex-end; justify-content: center; gap: 0.6rem; }
  :global(.podium-item) { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; flex: 1; max-width: 130px; }
  :global(.podium-avatar) { border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 800; border: 2px solid; font-family: 'Space Grotesk'; }
  :global(.podium-medal) { font-size: 1.5rem; line-height: 1; }
  :global(.podium-name) { font-size: 0.75rem; font-weight: 700; text-align: center; line-height: 1.2; }
  :global(.podium-count) { font-size: 0.65rem; color: var(--text-muted); font-weight: 600; }
  :global(.podium-bar) { width: 100%; border-radius: 10px 10px 0 0; margin-top: 0.4rem; position: relative; }
  :global(.podium-bar-inner) { position: absolute; inset: 0; border-radius: 10px 10px 0 0; border: 1px solid; border-bottom: none; }
  :global(.podium-rank) { position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); font-family: 'Space Grotesk'; font-size: 1.8rem; font-weight: 700; color: rgba(255,255,255,0.08); }

  :global(.rank-section) { padding: 0; margin: 1rem 0 2rem; overflow: hidden; }
  :global(.rank-header) { display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; border-bottom: 1px solid var(--border); }
  :global(.rank-header-text) { font-size: 0.62rem; font-weight: 700; color: var(--text-muted); letter-spacing: 0.12em; text-transform: uppercase; }

  :global(.rank-row) { display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.03); transition: background 0.15s; animation: fadeIn 0.3s ease both; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  :global(.rank-row:last-child) { border-bottom: none; }
  :global(.rank-row:hover) { background: rgba(255,255,255,0.02); }
  :global(.rank-num) { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); min-width: 24px; text-align: center; }
  :global(.rank-player) { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }
  :global(.rank-avatar) { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.68rem; font-weight: 800; border: 1.5px solid; font-family: 'Space Grotesk'; flex-shrink: 0; }
  :global(.rank-name) { font-size: 0.85rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  :global(.rank-bar-wrap) { display: flex; align-items: center; gap: 0.5rem; min-width: 80px; }
  :global(.rank-bar) { height: 4px; border-radius: 2px; transition: width 0.6s ease; min-width: 4px; }
  :global(.rank-count) { font-size: 0.78rem; font-weight: 700; font-family: 'Space Grotesk'; min-width: 20px; text-align: right; }

  @media (max-width: 400px) {
    :global(.podium-item) { max-width: 100px; }
    :global(.podium-avatar) { font-size: 0.82rem !important; }
    :global(.podium-name) { font-size: 0.68rem; }
    :global(.rank-bar-wrap) { min-width: 60px; }
  }

  @media (min-width: 900px) {
    .board-container { max-width: 1100px; }
  }
</style>
