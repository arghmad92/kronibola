    const errEl = document.getElementById('loginError')!;
    if (!username || !pass) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Please enter both username and password.</div>';
      return;
    }
    try {
      const res = await fetch(`${API}/admin/auth`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password: pass }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.success) {
        adminToken = data.token;
        adminSession = {
          username,
          displayName: data.displayName || username,
          isOwner: !!data.isOwner,
          isSuperadmin: !!data.isSuperadmin,
        };
        localStorage.setItem('kb_admin_username', username);
        document.getElementById('loginGate')!.style.display = 'none';
        document.getElementById('adminContent')!.style.display = '';
        document.getElementById('notifyBell')!.style.display = '';
        showLoggedInAs(adminSession.isOwner ? `${adminSession.displayName} (owner)` : adminSession.displayName);
        // Schedule must finish first: loadAllPlayers() cross-references sessionsData
        // to classify dates as Upcoming vs Past. Running them in parallel races,
        // and when players resolves first every game falls into "Past Games".
        await loadSchedule();
        loadAllPlayers(); loadRevenue(); loadNotifs(); loadStats(); loadOrders();
        // Calendar + Admins lazy-load when those tabs are first opened
      } else {
        errEl.style.display = '';
        errEl.innerHTML = `<div class="alert alert--error">${(data && data.error) || 'Invalid username or password.'}</div>`;
      }
    } catch {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Connection error.</div>';
    }
  });

  // Logout — clears the in-memory token and reloads to the login screen.
  // Username stays in localStorage as a convenience for the next sign-in.
  document.getElementById('logoutBtn')!.addEventListener('click', () => {
    adminToken = '';
    adminSession = null;
    hideLoggedInAs();
    document.getElementById('notifyBell')!.style.display = 'none';
    document.getElementById('adminContent')!.style.display = 'none';
    document.getElementById('loginGate')!.style.display = '';
    (document.getElementById('adminPass') as HTMLInputElement).value = '';
  });

  // --- TABS ---
  // Track which lazy-loaded tabs have already fetched so we don't refetch
  // every time the admin clicks back to them — let an explicit Refresh
  // button (or save/cancel actions) trigger reloads.
  const tabsLoaded = { calendar: false, admins: false };
  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      const which = (tab as HTMLElement).dataset.tab || '';
      const panel = document.getElementById(`tab-${which}`);
      if (panel) panel.classList.add('active');
      if (which === 'calendar' && !tabsLoaded.calendar) { tabsLoaded.calendar = true; loadCalendar(); }
      if (which === 'admins' && !tabsLoaded.admins) { tabsLoaded.admins = true; loadAdmins(); }
    });
  });

  // --- SCHEDULE (Card Layout) ---
  async function loadSchedule() {
    try {
      const res = await fetch(`${API}/admin/sessions`, { headers: { Authorization: adminToken } });
      sessionsData = (await res.json()).sessions || [];
      renderSchedule();
    } catch {}
  }

  function renderSchedule() {
    const wrap = document.getElementById('scheduleList')!;
    if (!sessionsData.length) { wrap.innerHTML = '<p class="empty-msg">No games yet. Tap "+ ADD" to create one.</p>'; return; }

    // Sort: Open first, then by date descending. Keep original indices for editing.
    const indexed = sessionsData.map((s: any, i: number) => ({ s, i }));
    indexed.sort((a: any, b: any) => {
      if (a.s.Status === 'Open' && b.s.Status !== 'Open') return -1;
      if (a.s.Status !== 'Open' && b.s.Status === 'Open') return 1;
      return (b.s.Date || '').localeCompare(a.s.Date || '');
    });

    wrap.innerHTML = indexed.map(({ s, i }: any) => {
      const isOpen = s.Status === 'Open';
      return `<div class="admin-card ${isOpen ? '' : 'admin-card--closed'}">
        <div class="ac-header">
          <span class="ac-badge ${isOpen ? 'ac-badge--open' : 'ac-badge--closed'}">${s.Status || 'Open'}</span>
          <div class="ac-actions">
            <button class="ac-btn ac-btn--dup" data-idx="${i}" title="Duplicate">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <button class="ac-btn ac-btn--del" data-idx="${i}" title="Delete">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
        <div class="ac-fields">
          <div class="ac-field">
            <label>Name</label>
            <input class="form-input s-input" data-field="Session Name" data-idx="${i}" value="${s['Session Name'] || ''}" placeholder="e.g. Minifootball" />
          </div>
          <div class="ac-row2">
            <div class="ac-field">
              <label>Date ${s.Date ? `<span class="ac-day">${new Date(s.Date).toLocaleDateString('en-MY', { weekday: 'long' })}</span>` : ''}</label>
              <input class="form-input s-input" type="date" data-field="Date" data-idx="${i}" value="${s.Date || ''}" />
            </div>
            <div class="ac-field">
              <label>Time</label>
              <input class="form-input s-input" data-field="Time" data-idx="${i}" value="${s.Time || ''}" placeholder="e.g. 5pm-7pm" />
            </div>
          </div>
          <div class="ac-field">
            <label>Location</label>
            <input class="form-input s-input" data-field="Location" data-idx="${i}" value="${s.Location || ''}" placeholder="e.g. FootballHub" />
          </div>
          <div class="ac-row3">
            <div class="ac-field">
              <label>Fee (RM)</label>
              <input class="form-input s-input" type="number" data-field="Fee" data-idx="${i}" value="${s.Fee || ''}" />
            </div>
            <div class="ac-field">
              <label>Max Players</label>
              <input class="form-input s-input" type="number" data-field="Max Players" data-idx="${i}" value="${s['Max Players'] || 15}" />
            </div>
            <div class="ac-field">
              <label>Status</label>
              <select class="form-select s-input" data-field="Status" data-idx="${i}">
                <option value="Open" ${s.Status === 'Open' ? 'selected' : ''}>Open</option>
                <option value="Closed" ${s.Status === 'Closed' ? 'selected' : ''}>Closed</option>
              </select>
            </div>
          </div>
          <div class="ac-field">
            <label>Car Plate</label>
            <select class="form-select s-carplate s-input" data-field="Require Car Plate" data-idx="${i}">
              <option value="No" ${s['Require Car Plate'] === 'Yes' ? '' : 'selected'}>Not Required</option>
              <option value="Yes" ${s['Require Car Plate'] === 'Yes' ? 'selected' : ''}>Required</option>
            </select>
          </div>
        </div>
      </div>`;
    }).join('');

    wrap.querySelectorAll('.s-input').forEach(el => {
      el.addEventListener('change', (e) => {
        const t = e.target as HTMLInputElement;
        sessionsData[parseInt(t.dataset.idx!)][t.dataset.field!] = t.value;
      });
    });
    wrap.querySelectorAll('.ac-btn--dup').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).closest('[data-idx]')!.getAttribute('data-idx') || (btn as HTMLElement).dataset.idx!);
        sessionsData.push({ ...sessionsData[idx], Date: '', Status: 'Open' });
        renderSchedule();
      });
    });
    wrap.querySelectorAll('.ac-btn--del').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!confirm('Delete this game?')) return;
        sessionsData.splice(parseInt((btn as HTMLElement).dataset.idx!), 1);
        renderSchedule();
      });
    });
  }

  document.getElementById('autoCloseBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('autoCloseBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'CLOSING...';
    try {
      const res = await fetch(`${API}/cron-autoclose`, { method: 'POST', headers: { Authorization: adminToken } });
      const data = await res.json();
      if (data.success && data.closed > 0) {
        btn.textContent = `CLOSED ${data.closed}`;
        loadSchedule();
      } else {
        btn.textContent = 'NO CHANGES';
      }
      setTimeout(() => { btn.textContent = 'AUTO-CLOSE'; btn.disabled = false; }, 2000);
    } catch { btn.textContent = 'ERROR'; setTimeout(() => { btn.textContent = 'AUTO-CLOSE'; btn.disabled = false; }, 2000); }
  });

  document.getElementById('addSessionBtn')!.addEventListener('click', () => {
    sessionsData.push({ 'Session Name': '', Date: '', Time: '', Location: '', Fee: 10, Status: 'Open', 'Max Players': 15, 'Require Car Plate': 'No' });
    renderSchedule();
  });

  document.getElementById('saveScheduleBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('saveScheduleBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'SAVING...';
    try {
      const res = await fetch(`${API}/admin/sessions`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken }, body: JSON.stringify({ sessions: sessionsData }) });
      if (!res.ok) throw new Error('save failed');
      btn.textContent = 'SAVED!';
      showToast('Schedule saved');
      setTimeout(() => { btn.textContent = 'SAVE SCHEDULE'; btn.disabled = false; }, 2000);
    } catch {
      btn.textContent = 'ERROR';
      btn.disabled = false;
      showToast('Failed to save schedule', 'error');
    }
  });

  // --- PLAYERS (Card Layout) ---
  async function loadAllPlayers() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      allPlayers = (await res.json()).players || [];

      // Union of session dates and registration dates. Using only registration
      // dates would hide freshly-scheduled games that nobody has signed up for
      // yet, making them impossible to open from this tab.
      const playerDates = allPlayers.map((p: any) => p['Session Date']).filter(Boolean);
      const sessionDates = sessionsData.map((s: any) => s.Date).filter(Boolean);
      const dates = [...new Set<string>([...playerDates, ...sessionDates])];

      // Split into open and closed sessions. Dates with registrations but no
      // matching session (orphan data) also fall into "Past Games".
      const openDates = dates.filter(d => sessionsData.some((s: any) => s.Date === d && s.Status === 'Open'));
      const closedDates = dates.filter(d => !openDates.includes(d));

      // Sort each group by date descending (newest first)
      const sortDesc = (a: string, b: string) => b.localeCompare(a);
      openDates.sort(sortDesc);
      closedDates.sort(sortDesc);

      // Build the dropdown label. Append the Session Name (e.g. "Futsal",
      // "7-a-side") so the admin can tell sessions apart at a glance when
      // two dates are close together or when picking from the Past list.
      const labelFor = (d: string) => {
        const s = sessionsData.find((x: any) => x.Date === d);
        const name = s && s['Session Name'] ? String(s['Session Name']).trim() : '';
        return name ? `${d} · ${name}` : d;
      };

      const sel = document.getElementById('filterDate') as HTMLSelectElement;
      let html = '';
      if (openDates.length) {
        html += `<optgroup label="Upcoming">`;
        html += openDates.map(d => `<option value="${d}">${labelFor(d)}</option>`).join('');
        html += `</optgroup>`;
      }
      if (closedDates.length) {
        html += `<optgroup label="Past Games">`;
        html += closedDates.map(d => `<option value="${d}">${labelFor(d)}</option>`).join('');
        html += `</optgroup>`;
      }
      sel.innerHTML = html;

      // Default to first open game, or first closed if none open
      const defaultDate = openDates[0] || closedDates[0];
      if (defaultDate) { sel.value = defaultDate as string; renderPlayers(defaultDate as string); }
    } catch {}
  }

  document.getElementById('refreshPlayersBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('refreshPlayersBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = '...';
    await loadAllPlayers();
    btn.textContent = 'Refresh'; btn.disabled = false;
  });

  document.getElementById('filterDate')!.addEventListener('change', () => {
    renderPlayers((document.getElementById('filterDate') as HTMLSelectElement).value);
    // If the Add Player form is open, re-evaluate whether to show the optional
    // plate field for the newly selected session.
    if (addPlayerBox.style.display !== 'none') syncApPlateRow();
  });

  function renderPlayers(date: string) {
    const wrap = document.getElementById('playersList')!;
    const filtered = allPlayers
      .filter((p: any) => p['Session Date'] === date)
      .sort((a: any, b: any) => {
        // Latest registered first
        const tA = a.Timestamp || '';
        const tB = b.Timestamp || '';
        return tB.localeCompare(tA);
      });
    if (!filtered.length) {
      wrap.innerHTML = '<p class="empty-msg">No players for this game.</p>';
      document.getElementById('carPlateSection')!.style.display = 'none';
      document.getElementById('shareWaSection')!.style.display = 'none';
      return;
    }

    const statusColors: Record<string, string> = { Paid: '#00FF41', Pending: '#ff9500', Overdue: '#ff5722', Waitlist: '#00c4ff', Rejected: '#ff3b30' };

    wrap.innerHTML = filtered.map((p: any, i: number) => {
      const phone = String(p.Phone || '').replace("'", '').trim();
      const ref = p['Ref Code'] || '';
      const refund = p['Refund'] || '';
      const status = p['Payment Status'] || 'Pending';
      const isOverdue = status === 'Overdue';
      const color = statusColors[status] || '#666';
      const playerName = esc(p['Player Name']);
      const initial = (p['Player Name'] || '?')[0].toUpperCase();
      const waMsg = encodeURIComponent(`Hi ${p['Player Name']}, this is regarding your registration (Ref: ${ref}) for the game on ${date}. `);
      const waLink = phone ? `https://wa.me/6${esc(phone)}?text=${waMsg}` : '#';

      return `<div class="player-card-admin ${isOverdue ? 'player-card--overdue' : ''}">
        <div class="pca-top">
          <div class="pca-avatar" style="background:${color}18;color:${color};border-color:${color}40">${esc(initial)}</div>
          <div class="pca-info">
            <span class="pca-name">${playerName}</span>
            <span class="pca-phone">${esc(phone)}</span>
            ${ref ? `<span class="pca-ref">${esc(ref)}</span>` : ''}
          </div>
        </div>
        <div class="pca-controls">
          <div class="pca-field">
            <label>Status</label>
            <select class="form-select p-status" data-name="${playerName}">
              <option value="Pending" ${status === 'Pending' ? 'selected' : ''}>Pending</option>
              <option value="Overdue" ${status === 'Overdue' ? 'selected' : ''}>Overdue</option>
              <option value="Paid" ${status === 'Paid' ? 'selected' : ''}>Paid</option>
              <option value="Waitlist" ${status === 'Waitlist' ? 'selected' : ''}>Waitlist</option>
              <option value="Rejected" ${status === 'Rejected' ? 'selected' : ''}>Rejected</option>
            </select>
          </div>
          <div class="pca-field">
            <label>Refund</label>
            <select class="form-select p-refund" data-name="${playerName}">
              <option value="" ${!refund ? 'selected' : ''}>—</option>
              <option value="Pending Refund" ${refund === 'Pending Refund' ? 'selected' : ''}>Pending</option>
              <option value="Refunded" ${refund === 'Refunded' ? 'selected' : ''}>Done</option>
            </select>
          </div>
          <button type="button" class="pca-save" data-name="${playerName}" title="Save this player">SAVE</button>
          <button type="button" class="pca-save pca-save--danger pca-delete" data-name="${playerName}" title="Delete this player">DELETE</button>
          <a href="${waLink}" target="_blank" class="pca-wa" title="WhatsApp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          </a>
        </div>
      </div>`;
    }).join('');

    // Car plates section
    const carPlateSection = document.getElementById('carPlateSection')!;
    const carPlateList = document.getElementById('carPlateList')!;
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresCarPlate = session && session['Require Car Plate'] === 'Yes';

    if (requiresCarPlate) {
      const activePlayers = filtered.filter((p: any) => ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status']));
      const platesData = activePlayers
        .filter((p: any) => p['Car Plate'])
        .map((p: any) => ({ plate: String(p['Car Plate']).trim(), name: p['Player Name'] }));

      carPlateSection.style.display = '';
      if (platesData.length) {
        carPlateList.innerHTML = platesData.map((d: any, i: number) =>
          `<div class="car-plate-item"><span class="car-plate-num">${i + 1}. ${esc(d.plate)}</span> <span class="car-plate-name">— ${esc(d.name)}</span></div>`
        ).join('');
      } else {
        carPlateList.innerHTML = '<p class="empty-msg">No car plates registered yet.</p>';
      }
    } else {
      carPlateSection.style.display = 'none';
    }

    // Share to WhatsApp section — always show when players exist
    document.getElementById('shareWaSection')!.style.display = '';
  }

  // --- SHARE TO WHATSAPP ---
  function getShareData() {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const session = sessionsData.find((s: any) => s.Date === date);
    if (!session) return null;
    const sessionName = session['Session Name'] || 'Game';
    const time = session.Time || '';
    const loc = session.Location || '';
    const fee = session.Fee || '';
    const max = parseInt(session['Max Players']) || 20;
    const active = allPlayers.filter((p: any) => p['Session Date'] === date && ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])).length;
    const slotsLeft = Math.max(0, max - active);
    const wazeLink = loc ? `https://waze.com/ul?q=${encodeURIComponent(loc)}` : '';
    return { sessionName, date, time, loc, fee, max, active, slotsLeft, wazeLink };
  }

  document.getElementById('shareWaOpen')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `⚽ GAME ON! 🟢\n\n🏟 ${d.sessionName}\n📅 ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}${d.loc ? `\n📍 ${d.loc}` : ''}\n💰 RM${d.fee}/pax\n👥 ${d.max} slots available${d.wazeLink ? `\n🗺️ ${d.wazeLink}` : ''}\n\nRegister now 👉 kronibola.com\n\nFirst come first serve. Jangan lepas! 🔥`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaFilling')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🔥 SLOTS FILLING UP!\n\n🏟 ${d.sessionName}\n📅 ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}${d.loc ? `\n📍 ${d.loc}` : ''}\n👥 Only *${d.slotsLeft} slot${d.slotsLeft !== 1 ? 's' : ''}* left!\n\nDon't miss out 👉 kronibola.com`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaLast')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🚨 LAST *${d.slotsLeft} SLOT${d.slotsLeft !== 1 ? 'S' : ''}*!\n\n🏟 ${d.sessionName} — ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}\n\nSiapa cepat dia dapat 👉 kronibola.com`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaFull')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🔴 GAME FULL!\n\n🏟 ${d.sessionName} — ${d.date}\n👥 ${d.max}/${d.max} players confirmed\n\nWaitlist still open 👉 kronibola.com\nNext game loading soon... ⏳`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  // --- COPY CAR PLATES ---
  document.getElementById('copyPlatesBtn')!.addEventListener('click', () => {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const filtered = allPlayers.filter((p: any) => p['Session Date'] === date && ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status']));
    const plates = filtered.filter((p: any) => p['Car Plate']).map((p: any, i: number) => `${i + 1}. ${String(p['Car Plate']).trim()}`);
    if (!plates.length) { alert('No car plates to copy.'); return; }
    navigator.clipboard.writeText(plates.join('\n')).then(() => {
      const btn = document.getElementById('copyPlatesBtn') as HTMLButtonElement;
      const orig = btn.textContent;
      btn.textContent = `${plates.length} plates copied`;
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  });

  // --- ADD PLAYER MANUALLY ---
  const addPlayerBox = document.getElementById('addPlayerBox')!;

  // Toggle the optional Car Plate row based on the currently selected session.
  // Only shown for plate-required sessions so admin can capture the plate at
  // add time; still optional on submit (admin can skip if unknown — player
  // can fill it in later via the public Check-My-Status flow).
  function syncApPlateRow() {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresPlate = !!(session && session['Require Car Plate'] === 'Yes');
    const row = document.getElementById('apPlateRow') as HTMLElement | null;
    if (!row) return;
    row.style.display = requiresPlate ? '' : 'none';
    if (!requiresPlate) {
      const inp = document.getElementById('apPlate') as HTMLInputElement | null;
      if (inp) inp.value = '';
    }
  }

  document.getElementById('addPlayerBtn')!.addEventListener('click', () => {
    const willShow = addPlayerBox.style.display === 'none';
    addPlayerBox.style.display = willShow ? '' : 'none';
    if (willShow) syncApPlateRow();
  });

  document.getElementById('apConfirm')!.addEventListener('click', async () => {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    if (!date) { alert('Select a game first.'); return; }

    const name = (document.getElementById('apName') as HTMLInputElement).value.trim().replace(/\s+/g, ' ').split(' ').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');
    const phone = (document.getElementById('apPhone') as HTMLInputElement).value.replace(/[-\s]/g, '');
    const status = (document.getElementById('apStatus') as HTMLSelectElement).value;
    const fee = (document.getElementById('apFee') as HTMLInputElement).value;

    if (!name || !phone) { alert('Fill in name and phone.'); return; }

    // Plate field is only shown for plate-required sessions; still optional
    // on submit (admin may not know the plate yet). Validate format when
    // provided; for no-plate sessions we ignore any value entirely.
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresPlate = !!(session && session['Require Car Plate'] === 'Yes');
    let plate = '';
    if (requiresPlate) {
      const plateInput = (document.getElementById('apPlate') as HTMLInputElement).value.replace(/\s/g, '').toUpperCase();
      if (plateInput) {
        if (plateInput.length < 2 || plateInput.length > 10) { alert('Car plate must be 2-10 characters'); return; }
        if (!/^[A-Z0-9]+$/.test(plateInput)) { alert('Car plate must contain only letters and numbers'); return; }
        if (!/[A-Z]/.test(plateInput) || !/[0-9]/.test(plateInput)) { alert('Car plate must contain at least 1 letter and 1 digit'); return; }
        plate = plateInput;
      }
    }

    const timestamp = new Date().toISOString().replace('T', ' ').slice(0, 19);
    const refCode = `KB-${date.slice(5, 7)}${date.slice(8, 10)}-${name[0].toUpperCase()}${Math.random().toString(36).substring(2, 5).toUpperCase()}`;

    const newPlayer = {
      'Session Date': date,
      'Player Name': name,
      Phone: "'" + phone,
      'Payment Status': status,
      Amount: fee,
      Timestamp: timestamp,
      'Ref Code': refCode,
      Refund: '',
      'Car Plate': plate,
    };

    allPlayers.push(newPlayer);
    renderPlayers(date);

    // Clear form
    (document.getElementById('apName') as HTMLInputElement).value = '';
    (document.getElementById('apPhone') as HTMLInputElement).value = '';
    (document.getElementById('apPlate') as HTMLInputElement).value = '';
    addPlayerBox.style.display = 'none';

    // Auto-save. Passing deletes: [] explicitly keeps the new
    // reconcile-based server happy and preserves any concurrent registrations.
    try {
      const res = await fetch(`${API}/admin/players`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ players: allPlayers, deletes: [] }),
      });
      if (res.ok) {
        const data = await res.json().catch(() => ({}));
        if (Array.isArray(data.players)) allPlayers = data.players;
      }
    } catch {}
  });

  document.getElementById('savePlayersBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('savePlayersBtn') as HTMLButtonElement;
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    btn.disabled = true; btn.textContent = 'SAVING...';

    const delNames = new Set<string>();

    const statusMap = new Map<string, string>();
    document.querySelectorAll('.p-status').forEach(sel => statusMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));

    const refundMap = new Map<string, string>();
    document.querySelectorAll('.p-refund').forEach(sel => refundMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));

    const changedPlayers: { name: string; phone: string; oldStatus: string; newStatus: string }[] = [];
    // Collect Ref Codes for the deletions so the server can action them
    // explicitly. Rows missing from the payload are preserved now.
    const deletes: string[] = [];

    const updated = allPlayers.map((p: any) => {
      if (p['Session Date'] === date) {
        if (delNames.has(p['Player Name'])) {
          if (p['Ref Code']) deletes.push(p['Ref Code']);
          return null;
        }
        if (statusMap.has(p['Player Name'])) {
          const ns = statusMap.get(p['Player Name'])!;
          if (ns !== p['Payment Status']) changedPlayers.push({ name: p['Player Name'], phone: String(p.Phone || '').replace("'", '').trim(), oldStatus: p['Payment Status'], newStatus: ns });
          p['Payment Status'] = ns;
        }
        if (refundMap.has(p['Player Name'])) p['Refund'] = refundMap.get(p['Player Name']);
      }
      return p;
    }).filter(Boolean);

    try {
      const res = await fetch(`${API}/admin/players`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken }, body: JSON.stringify({ players: updated, deletes }) });
      if (!res.ok) throw new Error('save failed');
      const data = await res.json().catch(() => ({}));
      allPlayers = Array.isArray(data.players) ? data.players : (updated as any[]);
      renderPlayers(date);
      btn.textContent = 'SAVED!';
      showToast(delNames.size ? `Saved (${delNames.size} removed)` : 'Players saved');
      setTimeout(() => { btn.textContent = 'SAVE CHANGES'; btn.disabled = false; }, 3000);

      if (changedPlayers.length > 0) {
        const session = sessionsData.find((s: any) => s.Date === date);
        changedPlayers.forEach((cp) => {
          const msg = buildNotifyMessage(cp.name, cp.newStatus, date, session);
          enqueueNotify({ name: cp.name, phone: cp.phone, fromStatus: cp.oldStatus, toStatus: cp.newStatus, date, msg });
        });
      }
    } catch {
      btn.textContent = 'ERROR';
      btn.disabled = false;
      showToast('Failed to save players', 'error');
    }
  });

  // --- Per-player save & delete (event delegation on players list) ---
  document.getElementById('playersList')!.addEventListener('click', async (e) => {
    const deleteBtn = (e.target as HTMLElement).closest('.pca-delete') as HTMLButtonElement | null;
    const saveBtn = !deleteBtn ? (e.target as HTMLElement).closest('.pca-save') as HTMLButtonElement | null : null;
    const target = deleteBtn || saveBtn;
    if (!target) return;

    const playerName = target.dataset.name || '';
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const card = target.closest('.player-card-admin') as HTMLElement | null;
    if (!card) return;

    const isDeleted = !!deleteBtn;
    if (isDeleted && !confirm(`Delete ${playerName}? This cannot be undone.`)) return;

    const statusSel = card.querySelector('.p-status') as HTMLSelectElement | null;
    const refundSel = card.querySelector('.p-refund') as HTMLSelectElement | null;

    const newStatus = statusSel ? statusSel.value : '';
    const newRefund = refundSel ? refundSel.value : '';

    // Snapshot previous status BEFORE mutating allPlayers so we can detect a change
    const existing = allPlayers.find((p: any) => p['Session Date'] === date && p['Player Name'] === playerName);
    const oldStatus = existing ? existing['Payment Status'] : '';
    const phone = existing ? String(existing.Phone || '').replace("'", '').trim() : '';

    // Apply the change locally
    const updated = allPlayers
      .map((p: any) => {
        if (p['Session Date'] !== date || p['Player Name'] !== playerName) return p;
        if (isDeleted) return null;
        p['Payment Status'] = newStatus;
        p['Refund'] = newRefund;
        return p;
      })
      .filter(Boolean);

    target.disabled = true;
    const originalLabel = target.textContent || (isDeleted ? 'DELETE' : 'SAVE');
    target.textContent = '…';

    // Deletion must be explicit now — a row missing from the payload is
    // preserved server-side (so a concurrent registration between page load
    // and save doesn't get wiped). List the Ref Code if we're deleting.
    const deletes: string[] = isDeleted && existing && existing['Ref Code'] ? [existing['Ref Code']] : [];

    try {
      const res = await fetch(`${API}/admin/players`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ players: updated, deletes }),
      });
      if (!res.ok) throw new Error('save failed');
      // Server returns the reconciled state — adopt it so any concurrent
      // registrations the admin didn't know about appear on the next render.
      const data = await res.json().catch(() => ({}));
      allPlayers = Array.isArray(data.players) ? data.players : (updated as any[]);
      renderPlayers(date);
      showToast(isDeleted ? `${playerName} removed` : `${playerName} saved`);

      // If status changed, queue a notification in the Notification Center.
      if (!isDeleted && newStatus && newStatus !== oldStatus) {
        const session = sessionsData.find((s: any) => s.Date === date);
        const msg = buildNotifyMessage(playerName, newStatus, date, session);
        enqueueNotify({ name: playerName, phone, fromStatus: oldStatus, toStatus: newStatus, date, msg });
      }
    } catch {
      target.disabled = false;
      target.textContent = originalLabel;
      showToast(`Failed to save ${playerName}`, 'error');
    }
  });

  // --- NOTIFICATIONS LOG ---
  async function loadNotifs() {
    try {
      const res = await fetch(`${API}/admin/notifications`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      renderNotifs(data.logs || []);
