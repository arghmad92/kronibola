  }
  .cal-nav-btn:hover { color: var(--neon); border-color: rgba(0,255,65,0.35); background: rgba(0,255,65,0.05); }
  .cal-nav-btn:active { transform: scale(0.95); }
  .cal-month-label {
    flex: 1; text-align: center; display: flex; flex-direction: column; gap: 0.05rem;
