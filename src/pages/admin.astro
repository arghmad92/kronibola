  function enqueueNotify(item: Omit<NotifyItem, 'id' | 'time'>) {
    if (!item.toStatus) return;
    const newItem: NotifyItem = { ...item, id: 'n' + (notifyIdCounter++), time: Date.now() };
    notifyQueue.push(newItem);
    renderNotifyCenter();
    // Log the notification intent to the sheet (preserves existing audit behaviour).
    logNotification(newItem.name, newItem.phone, newItem.toStatus, newItem.date, newItem.msg);
    // Pulse the bell to draw the eye.
    const bell = document.getElementById('notifyBell');
    if (bell) { bell.classList.remove('notify-bell--pulse'); void bell.offsetHeight; bell.classList.add('notify-bell--pulse'); }
    showToast(`Queued for ${item.name}`);
  }

  function openNotifyCenter() {
    document.getElementById('ncBackdrop')?.classList.add('open');
    const el = document.getElementById('ncenter');
    if (el) { el.classList.add('open'); el.setAttribute('aria-hidden', 'false'); }
    // Refresh time-ago labels when opening.
    document.querySelectorAll<HTMLElement>('.nc-row-time[data-time]').forEach((el) => {
      el.textContent = ncTimeAgo(parseInt(el.dataset.time!, 10));
    });
  }
  function closeNotifyCenter() {
    document.getElementById('ncBackdrop')?.classList.remove('open');
    const el = document.getElementById('ncenter');
    if (el) { el.classList.remove('open'); el.setAttribute('aria-hidden', 'true'); }
  }
  function removeNotifyItem(id: string) {
    const row = document.querySelector(`.nc-row[data-id="${id}"]`);
    if (row) row.classList.add('removing');
    setTimeout(() => {
      notifyQueue = notifyQueue.filter((q) => q.id !== id);
      renderNotifyCenter();
    }, 240);
  }
  function waLinkFor(item: NotifyItem): string | null {
    const cleaned = (item.phone || '').replace(/\D/g, '');
    return cleaned ? `https://wa.me/6${cleaned}?text=${encodeURIComponent(item.msg)}` : null;
  }

  // Wire up the center once, after DOM is ready.
  (function initNotifyCenter() {
    const bell = document.getElementById('notifyBell');
    const closeBtn = document.getElementById('ncClose');
    const backdrop = document.getElementById('ncBackdrop');
    const list = document.getElementById('ncList');
    const sendAll = document.getElementById('ncSendAll');
    const markAll = document.getElementById('ncMarkAll');
    if (!bell || !closeBtn || !backdrop || !list || !sendAll || !markAll) return;

    bell.addEventListener('click', openNotifyCenter);
    closeBtn.addEventListener('click', closeNotifyCenter);
    backdrop.addEventListener('click', closeNotifyCenter);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.getElementById('ncenter')?.classList.contains('open')) closeNotifyCenter();
    });

    list.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!btn) return;
      const id = btn.dataset.id!;
      const action = btn.dataset.action!;
      const item = notifyQueue.find((q) => q.id === id);
      if (!item) return;
      const rowEl = list.querySelector(`.nc-row[data-id="${id}"]`) as HTMLElement | null;
      if (!rowEl) return;

      if (action === 'expand') {
        rowEl.querySelector('.nc-row-preview')?.classList.add('expanded');
        btn.remove();
      } else if (action === 'edit') {
        if (rowEl.classList.contains('editing')) {
          const ta = rowEl.querySelector<HTMLTextAreaElement>('.nc-row-edit');
          if (ta) item.msg = ta.value;
          rowEl.classList.remove('editing');
          const preview = rowEl.querySelector('.nc-row-preview') as HTMLElement | null;
          if (preview) preview.textContent = item.msg;
          btn.innerHTML = '✎ Edit';
        } else {
          rowEl.classList.add('editing');
          btn.innerHTML = '✓ Save';
        }
      } else if (action === 'skip') {
        removeNotifyItem(id);
      } else if (action === 'send') {
        const href = waLinkFor(item);
        if (href) window.open(href, '_blank', 'noopener');
        else showToast(`No phone number for ${item.name}`, 'error');
        removeNotifyItem(id);
      }
    });

    sendAll.addEventListener('click', () => {
      const items = [...notifyQueue];
      if (!items.length) return;
      items.forEach((it, i) => {
        setTimeout(() => {
          const href = waLinkFor(it);
          if (href) window.open(href, '_blank', 'noopener');
          removeNotifyItem(it.id);
        }, i * 400);
      });
      showToast(`Opening ${items.length} WhatsApp message${items.length > 1 ? 's' : ''}…`);
    });
    markAll.addEventListener('click', () => {
      const n = notifyQueue.length;
      if (!n) return;
      notifyQueue = [];
      renderNotifyCenter();
      showToast(`Marked ${n} as sent`);
    });

    // Live time-ago updater (runs every 30s while any items are queued).
    setInterval(() => {
      document.querySelectorAll<HTMLElement>('.nc-row-time[data-time]').forEach((el) => {
        el.textContent = ncTimeAgo(parseInt(el.dataset.time!, 10));
      });
    }, 30_000);

    renderNotifyCenter();
  })();
  let sessionsData: any[] = [];
  let allPlayers: any[] = [];

  // XSS protection — escape HTML in user-supplied data
  function esc(text: any): string {
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
    return String(text || '').replace(/[&<>"']/g, m => map[m]);
  }

  // --- STATS DASHBOARD ---
  async function loadStats() {
    try {
      const [sessRes, plRes] = await Promise.all([
        fetch(`${API}/admin/sessions`, { headers: { Authorization: adminToken } }),
        fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } }),
      ]);
      const sessions = (await sessRes.json()).sessions || [];
      const players = (await plRes.json()).players || [];

      // Only count confirmed players (Paid status, not Rejected/Waitlist)
      const confirmed = players.filter((p: any) => p['Payment Status'] === 'Paid');

      // Sessions played (Closed status)
      const closedSessions = sessions.filter((s: any) => s.Status === 'Closed');
      document.getElementById('statSessions')!.textContent = String(closedSessions.length);

      // Total registrations
      document.getElementById('statTotalPlayers')!.textContent = String(confirmed.length);

      // Group by player name — reused for unique count, MVP, and retention.
      // Phone isn't a reliable identity key since one person often registers
      // for friends using their own phone, which both inflates that person's
      // count and merges multiple different players into one record.
      // Names are Title-Cased at registration (see functions/api/register.js),
      // so case/whitespace drift can't split one player into two.
      const nameCounts: Record<string, { name: string; count: number }> = {};
      for (const p of confirmed) {
        const displayName = String(p['Player Name'] || '').trim();
        if (!displayName) continue;
        const key = displayName.toLowerCase().replace(/\s+/g, ' ');
        if (!nameCounts[key]) nameCounts[key] = { name: displayName, count: 0 };
        nameCounts[key].count++;
      }

      // Unique players
      document.getElementById('statUnique')!.textContent = String(Object.keys(nameCounts).length);

      // Total revenue (sum of Amount for Paid players)
      const totalRev = confirmed.reduce((sum: number, p: any) => sum + (parseFloat(p.Amount) || 0), 0);
      document.getElementById('statRevenue')!.textContent = `RM${totalRev.toLocaleString()}`;

      // Average players per closed session
      if (closedSessions.length > 0) {
        const avg = (confirmed.length / closedSessions.length).toFixed(1);
        document.getElementById('statAvg')!.textContent = avg;
      } else {
        document.getElementById('statAvg')!.textContent = '-';
      }

      // Most active player
      const sorted = Object.values(nameCounts).sort((a, b) => b.count - a.count);
      if (sorted.length > 0) {
        const mvp = sorted[0];
        document.getElementById('statMvp')!.textContent = mvp.name;
        document.getElementById('statMvp')!.title = `${mvp.count} sessions`;
      } else {
        document.getElementById('statMvp')!.textContent = '-';
      }

      // Retention rate (players who came back 2+ times)
      const returning = Object.values(nameCounts).filter(p => p.count >= 2).length;
      const totalUnique = Object.keys(nameCounts).length;
      if (totalUnique > 0) {
        const rate = Math.round((returning / totalUnique) * 100);
        document.getElementById('statRetention')!.textContent = `${rate}%`;
        document.getElementById('statRetention')!.title = `${returning} of ${totalUnique} players returned`;
      }

      // No-shows / Overdue count
      const noshows = players.filter((p: any) => ['Overdue', 'Rejected'].includes(p['Payment Status']));
      document.getElementById('statNoshow')!.textContent = String(noshows.length);

      // Most popular day of week
      const dayCounts: Record<string, number> = {};
      for (const s of closedSessions) {
        const d = new Date(s.Date);
        if (isNaN(d.getTime())) continue;
        const day = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][d.getDay()];
        dayCounts[day] = (dayCounts[day] || 0) + 1;
      }
      const peakDay = Object.entries(dayCounts).sort((a, b) => b[1] - a[1])[0];
      if (peakDay) {
        document.getElementById('statPeakDay')!.textContent = peakDay[0];
        document.getElementById('statPeakDay')!.title = `${peakDay[1]} sessions on ${peakDay[0]}`;
      }
    } catch {
      // Silently fail — stats show "-"
    }
  }

  // --- ORDERS TAB ---
  let allOrders: any[] = [];

  async function loadOrders() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      // Orders are on a separate sheet — use a direct call
      const ordRes = await fetch(`${API}/order-status?phone=_all_admin_`).catch(() => null);
      // Fallback: read from admin endpoint with sheet name override
      // For now, read orders via a simple fetch
    } catch {}
    // Direct sheet read via admin sessions endpoint pattern
    try {
      const res = await fetch(`${API}/admin/orders`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      allOrders = data.orders || [];
      renderOrders();
    } catch {
      document.getElementById('ordersList')!.innerHTML = '<p class="empty-msg">Failed to load orders.</p>';
    }
  }

  function renderOrderSummary() {
    const summary = document.getElementById('orderSummary')!;
    if (!allOrders.length) { summary.innerHTML = ''; return; }

    // Exclude deleted orders from summary
    const activeOrders = allOrders.filter((o: any) => o['Payment Status'] !== 'Deleted');
    const totalOrders = activeOrders.length;
    const totalQty = activeOrders.reduce((s: number, o: any) => s + (parseInt(o.Quantity) || 0), 0);
    const totalRevenue = activeOrders.reduce((s: number, o: any) => s + (parseFloat(o.Total) || 0), 0);
    const pending = activeOrders.filter((o: any) => o['Payment Status'] === 'Pending').length;
    const paid = activeOrders.filter((o: any) => o['Payment Status'] === 'Paid').length;
    const collected = activeOrders.filter((o: any) => o['Payment Status'] === 'Collected').length;
    const deleted = allOrders.filter((o: any) => o['Payment Status'] === 'Deleted').length;

    // Size breakdown — parse "M ×1, L ×2" format (active orders only)
    const sizes: Record<string, number> = {};
    activeOrders.forEach((o: any) => {
      const sizeStr = o.Size || '';
      // Split by comma, then parse each "SIZE ×QTY" pair
      sizeStr.split(',').forEach((part: string) => {
        const trimmed = part.trim();
        const match = trimmed.match(/^(\S+)\s*[×x]\s*(\d+)$/i);
        if (match) {
          sizes[match[1]] = (sizes[match[1]] || 0) + parseInt(match[2], 10);
        } else if (trimmed) {
          sizes[trimmed] = (sizes[trimmed] || 0) + 1;
        }
      });
    });
    const sizeList = Object.entries(sizes).sort((a, b) => b[1] - a[1]).map(([s, q]) => `<span class="os-size">${esc(s)} <strong>×${q}</strong></span>`).join('');

    summary.innerHTML = `
      <div class="os-stats">
        <div class="os-stat"><div class="os-num">${totalOrders}</div><div class="os-label">Orders</div></div>
        <div class="os-stat"><div class="os-num">${totalQty}</div><div class="os-label">Jerseys</div></div>
        <div class="os-stat"><div class="os-num" style="color:var(--neon)">RM ${totalRevenue}</div><div class="os-label">Revenue</div></div>
      </div>
      <div class="os-status-row">
        <span class="os-badge" style="color:#ff9500;background:rgba(255,149,0,0.1);border-color:rgba(255,149,0,0.2)">Pending: ${pending}</span>
        <span class="os-badge" style="color:#00FF41;background:rgba(0,255,65,0.1);border-color:rgba(0,255,65,0.2)">Paid: ${paid}</span>
        <span class="os-badge" style="color:#00c4ff;background:rgba(0,196,255,0.1);border-color:rgba(0,196,255,0.2)">Collected: ${collected}</span>
        ${deleted ? `<span class="os-badge" style="color:#ff3b30;background:rgba(255,59,48,0.1);border-color:rgba(255,59,48,0.2)">Deleted: ${deleted}</span>` : ''}
      </div>
      <div class="os-sizes">
        <div class="os-sizes-label">SIZE BREAKDOWN</div>
        <div class="os-sizes-list">${sizeList}</div>
      </div>
    `;
  }

  function renderOrders() {
    const filter = (document.getElementById('orderFilter') as HTMLSelectElement).value;
    // "all" hides deleted orders; use "Deleted" filter to see them
    const filtered = filter === 'all'
      ? allOrders.filter((o: any) => o['Payment Status'] !== 'Deleted')
      : allOrders.filter((o: any) => o['Payment Status'] === filter);
    const wrap = document.getElementById('ordersList')!;

    renderOrderSummary();

    if (!filtered.length) {
      wrap.innerHTML = '<p class="empty-msg">No orders found.</p>';
      return;
    }

    const statusColors: Record<string, string> = { Paid: '#00FF41', Pending: '#ff9500', Collected: '#00c4ff', Deleted: '#ff3b30' };

    wrap.innerHTML = filtered.map((o: any) => {
      const status = o['Payment Status'] || 'Pending';
      const isDeleted = status === 'Deleted';
      const color = statusColors[status] || '#666';
      const name = esc(o['Player Name']);
      const phone = String(o.Phone || '').replace("'", '').trim();
      const ref = esc(o['Ref Code'] || '');
      const delivery = o.Delivery || '';
      const address = o.Address || '';

      return `<div class="player-card-admin" style="${isDeleted ? 'opacity:0.45;' : ''}">
        <div class="pca-top">
          <div class="pca-avatar" style="background:${color}18;color:${color};border-color:${color}40">👕</div>
          <div class="pca-info">
            <span class="pca-name">${name}${isDeleted ? ' <span style="font-size:0.62rem;color:#ff3b30;">(DELETED)</span>' : ''}</span>
            <span class="pca-phone">${esc(phone)}</span>
            ${ref ? `<span class="pca-ref">${ref}</span>` : ''}
          </div>
          <div style="text-align:right">
            <span style="font-size:0.72rem;color:var(--text-muted)">${esc(o.Size)} (${esc(o.Quantity)} pcs)</span>
            <span style="display:block;font-size:0.82rem;font-weight:700;color:var(--neon);font-family:'Space Grotesk',sans-serif">RM ${esc(o.Total)}</span>
          </div>
        </div>
        ${delivery ? `<div style="font-size:0.68rem;color:var(--text-muted);padding:0 0.4rem;margin-top:0.3rem;">📦 ${esc(delivery)}${address ? ' — ' + esc(address) : ''}</div>` : ''}
        <div class="pca-controls">
          <div class="pca-field" style="flex:1;">
            <label>Status</label>
            <select class="form-select o-status" data-ref="${ref}">
              <option value="Pending" ${status === 'Pending' ? 'selected' : ''}>Pending</option>
              <option value="Paid" ${status === 'Paid' ? 'selected' : ''}>Paid</option>
              <option value="Collected" ${status === 'Collected' ? 'selected' : ''}>Collected</option>
              <option value="Deleted" ${status === 'Deleted' ? 'selected' : ''}>Deleted</option>
            </select>
          </div>
          <button type="button" class="pca-save o-save" data-ref="${ref}">SAVE</button>
          ${!isDeleted
            ? `<button type="button" class="pca-save pca-save--danger o-delete" data-ref="${ref}">DELETE</button>`
            : `<button type="button" class="pca-save pca-save--info o-restore" data-ref="${ref}">RESTORE</button>`}
        </div>
      </div>`;
    }).join('');

    // Save order status. Orders use soft-delete (Payment Status = Deleted),
    // so deletes is always empty — server preserves concurrent orders.
    async function saveOrders(feedbackMsg: string) {
      try {
        const res = await fetch(`${API}/admin/orders`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ orders: allOrders, deletes: [] }),
        });
        if (!res.ok) throw new Error('save failed');
        const data = await res.json().catch(() => ({}));
        if (Array.isArray(data.orders)) allOrders = data.orders;
        showToast(feedbackMsg);
        renderOrders();
      } catch {
        showToast('Failed to save order', 'error');
      }
    }

    // Save button handlers
    wrap.querySelectorAll('.o-save').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        const card = btn.closest('.player-card-admin')!;
        const sel = card.querySelector('.o-status') as HTMLSelectElement;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = sel.value;
          (btn as HTMLButtonElement).textContent = '…';
          (btn as HTMLButtonElement).disabled = true;
          await saveOrders(`Order ${ref} saved`);
          (btn as HTMLButtonElement).textContent = 'SAVE';
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    });

    // Delete button handlers
    wrap.querySelectorAll('.o-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        if (!confirm('Delete this order? You can restore it later from the Deleted filter.')) return;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = 'Deleted';
          await saveOrders('Order deleted');
        }
      });
    });

    // Restore button handlers
    wrap.querySelectorAll('.o-restore').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = 'Pending';
          await saveOrders('Order restored');
        }
      });
    });
  }

  document.getElementById('refreshOrdersBtn')!.addEventListener('click', () => loadOrders());
  document.getElementById('orderFilter')!.addEventListener('change', () => renderOrders());

