---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin — KroniBola">
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src="/logo.png" alt="KroniBola" class="brand-logo" />
        <div>
          <h1 class="brand-name">KRONI<span class="neon-text">BOLA</span></h1>
          <p class="brand-tag">ADMIN PANEL</p>
        </div>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </a>
    </div>
  </header>

  <main class="container">
    <!-- Login Gate -->
    <div id="loginGate">
      <div class="login-card glass">
        <div class="login-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2>ADMIN <span class="neon-text">ACCESS</span></h2>
        <form id="loginForm">
          <div class="form-group">
            <label class="form-label" for="adminPass">Password</label>
            <input type="password" class="form-input" id="adminPass" placeholder="Enter admin password" required style="width:100%" />
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%;margin-top:0.5rem">UNLOCK</button>
        </form>
        <div id="loginError" style="display:none;margin-top:1rem"></div>
      </div>
    </div>

    <!-- Admin Content (hidden until auth) -->
    <div id="adminContent" style="display:none">
      <!-- Tabs -->
      <div class="tabs">
        <button class="tab active" data-tab="schedule">MANAGE SCHEDULE</button>
        <button class="tab" data-tab="players">MANAGE PLAYERS</button>
        <button class="tab" data-tab="revenue">REVENUE</button>
      </div>

      <!-- Schedule Tab -->
      <div class="tab-panel active" id="tab-schedule">
        <div class="glass panel-card">
          <div class="panel-header">
            <h3>UPCOMING <span class="neon-text">GAMES</span></h3>
            <button class="btn btn--primary" id="addSessionBtn" style="padding:0.6rem 1.2rem;font-size:0.78rem">+ ADD GAME</button>
          </div>
          <div id="scheduleTable" class="table-wrap"></div>
          <button class="btn btn--primary" id="saveScheduleBtn" style="width:100%;margin-top:1rem">SAVE SCHEDULE</button>
        </div>
      </div>

      <!-- Players Tab -->
      <div class="tab-panel" id="tab-players">
        <div class="glass panel-card">
          <div class="panel-header">
            <h3>MANAGE <span class="neon-text">PLAYERS</span></h3>
          </div>
          <div class="form-group" style="margin-bottom:1rem">
            <label class="form-label" for="filterDate">Filter by Game</label>
            <select class="form-select" id="filterDate" style="width:100%;margin-top:0.3rem">
              <option value="">Select a date...</option>
            </select>
          </div>
          <div class="alert alert--info" style="margin-bottom:1rem">
            Moving a player from Waitlist to Pending? Use the WhatsApp link to notify them to pay.
          </div>
          <div id="playersTable" class="table-wrap"></div>
          <button class="btn btn--primary" id="savePlayersBtn" style="width:100%;margin-top:1rem">SAVE CHANGES</button>
        </div>
      </div>

      <!-- Revenue Tab -->
      <div class="tab-panel" id="tab-revenue">
        <div class="glass panel-card">
          <div class="panel-header">
            <h3>REVENUE <span class="neon-text">DASHBOARD</span></h3>
          </div>
          <div id="revenueDashboard">
            <p style="color:var(--text-muted);padding:1rem">Loading revenue data...</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>&copy; 2025 KroniBola. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<script>
  const API = '/api';
  let adminToken = '';
  let sessionsData: any[] = [];
  let allPlayers: any[] = [];

  // --- LOGIN ---
  document.getElementById('loginForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pass = (document.getElementById('adminPass') as HTMLInputElement).value;
    const errEl = document.getElementById('loginError')!;

    try {
      const res = await fetch(`${API}/admin/auth`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pass }),
      });
      const data = await res.json();
      if (data.success) {
        adminToken = data.token;
        document.getElementById('loginGate')!.style.display = 'none';
        document.getElementById('adminContent')!.style.display = '';
        loadSchedule();
        loadAllPlayers();
        loadRevenue();
      } else {
        errEl.style.display = '';
        errEl.innerHTML = '<div class="alert alert--error">Wrong password.</div>';
      }
    } catch {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Connection error.</div>';
    }
  });

  // --- TABS ---
  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${(tab as HTMLElement).dataset.tab}`)!.classList.add('active');
    });
  });

  // --- SCHEDULE ---
  async function loadSchedule() {
    try {
      const res = await fetch(`${API}/admin/sessions`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      sessionsData = data.sessions || [];
      renderSchedule();
    } catch {}
  }

  function renderSchedule() {
    const wrap = document.getElementById('scheduleTable')!;
    if (!sessionsData.length) { wrap.innerHTML = '<p style="color:var(--text-muted);padding:1rem">No sessions. Click "+ ADD GAME" to create one.</p>'; return; }

    wrap.innerHTML = `<table class="data-table">
      <thead><tr><th>Name</th><th>Date</th><th>Time</th><th>Location</th><th>Fee</th><th>Max</th><th>Status</th><th></th></tr></thead>
      <tbody>${sessionsData.map((s, i) => `<tr>
        <td><input class="cell-input" data-field="Session Name" data-idx="${i}" value="${s['Session Name'] || ''}" /></td>
        <td><input class="cell-input" type="date" data-field="Date" data-idx="${i}" value="${s.Date || ''}" /></td>
        <td><input class="cell-input" data-field="Time" data-idx="${i}" value="${s.Time || ''}" /></td>
        <td><input class="cell-input" data-field="Location" data-idx="${i}" value="${s.Location || ''}" /></td>
        <td><input class="cell-input" type="number" data-field="Fee" data-idx="${i}" value="${s.Fee || ''}" style="width:60px" /></td>
        <td><input class="cell-input" type="number" data-field="Max Players" data-idx="${i}" value="${s['Max Players'] || 15}" style="width:50px" /></td>
        <td><select class="cell-select" data-field="Status" data-idx="${i}">
          <option value="Open" ${s.Status === 'Open' ? 'selected' : ''}>Open</option>
          <option value="Closed" ${s.Status === 'Closed' ? 'selected' : ''}>Closed</option>
        </select></td>
        <td class="action-cell">
          <button class="dup-btn" data-idx="${i}" title="Duplicate">&#9851;</button>
          <button class="del-btn" data-idx="${i}" title="Delete">&#10005;</button>
        </td>
      </tr>`).join('')}</tbody>
    </table>`;

    wrap.querySelectorAll('.cell-input, .cell-select').forEach((el) => {
      el.addEventListener('change', (e) => {
        const t = e.target as HTMLInputElement;
        sessionsData[parseInt(t.dataset.idx!)][t.dataset.field!] = t.value;
      });
    });

    wrap.querySelectorAll('.dup-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        const original = sessionsData[idx];
        const duplicate = { ...original, Date: '', Status: 'Open' };
        sessionsData.push(duplicate);
        renderSchedule();
      });
    });

    wrap.querySelectorAll('.del-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        sessionsData.splice(parseInt((btn as HTMLElement).dataset.idx!), 1);
        renderSchedule();
      });
    });
  }

  document.getElementById('addSessionBtn')!.addEventListener('click', () => {
    sessionsData.push({ 'Session Name': '', Date: '', Time: '', Location: '', Fee: 10, Status: 'Open', 'Max Players': 15 });
    renderSchedule();
  });

  document.getElementById('saveScheduleBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('saveScheduleBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'SAVING...';
    try {
      await fetch(`${API}/admin/sessions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ sessions: sessionsData }),
      });
      btn.textContent = 'SAVED!';
      setTimeout(() => { btn.textContent = 'SAVE SCHEDULE'; btn.disabled = false; }, 2000);
    } catch { btn.textContent = 'ERROR'; btn.disabled = false; }
  });

  // --- PLAYERS ---
  async function loadAllPlayers() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      allPlayers = data.players || [];

      const dates = [...new Set(allPlayers.map((p: any) => p['Session Date']))];
      const sel = document.getElementById('filterDate') as HTMLSelectElement;
      sel.innerHTML = dates.map((d) => `<option value="${d}">${d}</option>`).join('');
      if (dates.length) { sel.value = dates[0] as string; renderPlayers(dates[0] as string); }
    } catch {}
  }

  document.getElementById('filterDate')!.addEventListener('change', () => {
    renderPlayers((document.getElementById('filterDate') as HTMLSelectElement).value);
  });

  function renderPlayers(date: string) {
    const wrap = document.getElementById('playersTable')!;
    const filtered = allPlayers.filter((p: any) => p['Session Date'] === date);
    if (!filtered.length) { wrap.innerHTML = '<p style="color:var(--text-muted);padding:1rem">No players for this game.</p>'; return; }

    wrap.innerHTML = `<table class="data-table">
      <thead><tr><th>Del?</th><th>Name</th><th>Phone</th><th>Status</th><th>Notify</th></tr></thead>
      <tbody>${filtered.map((p, i) => {
        const phone = String(p.Phone || '').replace("'", '').trim();
        const waMsg = encodeURIComponent(`Hi ${p['Player Name']}, good news! A slot opened up for the game on ${date}. Please pay RM${p.Amount} to confirm your spot.`);
        const waLink = phone ? `https://wa.me/6${phone}?text=${waMsg}` : '#';
        return `<tr>
          <td><input type="checkbox" class="player-del" data-name="${p['Player Name']}" /></td>
          <td>${p['Player Name']}</td>
          <td>${phone}</td>
          <td><select class="cell-select player-status" data-name="${p['Player Name']}">
            <option value="Pending" ${p['Payment Status'] === 'Pending' ? 'selected' : ''}>Pending</option>
            <option value="Paid" ${p['Payment Status'] === 'Paid' ? 'selected' : ''}>Paid</option>
            <option value="Waitlist" ${p['Payment Status'] === 'Waitlist' ? 'selected' : ''}>Waitlist</option>
            <option value="Rejected" ${p['Payment Status'] === 'Rejected' ? 'selected' : ''}>Rejected</option>
          </select></td>
          <td><a href="${waLink}" target="_blank" class="wa-notify-link">Send</a></td>
        </tr>`;
      }).join('')}</tbody>
    </table>`;
  }

  document.getElementById('savePlayersBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('savePlayersBtn') as HTMLButtonElement;
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    btn.disabled = true; btn.textContent = 'SAVING...';

    const delNames = new Set<string>();
    document.querySelectorAll('.player-del:checked').forEach((cb) => delNames.add((cb as HTMLInputElement).dataset.name!));

    const statusMap = new Map<string, string>();
    document.querySelectorAll('.player-status').forEach((sel) => {
      statusMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value);
    });

    // Track status changes for notifications
    const changedPlayers: { name: string; phone: string; oldStatus: string; newStatus: string }[] = [];

    const updated = allPlayers.map((p: any) => {
      if (p['Session Date'] === date) {
        if (delNames.has(p['Player Name'])) return null;
        if (statusMap.has(p['Player Name'])) {
          const newStatus = statusMap.get(p['Player Name'])!;
          if (newStatus !== p['Payment Status']) {
            changedPlayers.push({
              name: p['Player Name'],
              phone: String(p.Phone || '').replace("'", '').trim(),
              oldStatus: p['Payment Status'],
              newStatus,
            });
          }
          p['Payment Status'] = newStatus;
        }
      }
      return p;
    }).filter(Boolean);

    try {
      await fetch(`${API}/admin/players`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ players: updated }),
      });
      allPlayers = updated as any[];
      renderPlayers(date);
      btn.textContent = 'SAVED!';
      setTimeout(() => { btn.textContent = 'SAVE CHANGES'; btn.disabled = false; }, 3000);

      // Show WhatsApp notification links for changed players
      if (changedPlayers.length > 0) {
        const notifyHtml = changedPlayers.map((cp) => {
          const statusMsgs: Record<string, string> = {
            Paid: `Hi ${cp.name}, your payment for the game on ${date} has been confirmed! See you on the pitch!`,
            Pending: `Hi ${cp.name}, a slot has opened for the game on ${date}. Please pay to confirm your spot.`,
            Rejected: `Hi ${cp.name}, your registration for the game on ${date} has been cancelled.`,
            Waitlist: `Hi ${cp.name}, you've been moved to the waitlist for the game on ${date}. We'll notify you if a slot opens.`,
          };
          const msg = statusMsgs[cp.newStatus] || `Hi ${cp.name}, your status for the game on ${date} has been updated to: ${cp.newStatus}.`;
          const waLink = cp.phone ? `https://wa.me/6${cp.phone}?text=${encodeURIComponent(msg)}` : '#';
          return `<div style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0;border-bottom:1px solid var(--border)">
            <span style="flex:1;font-size:0.82rem"><strong>${cp.name}</strong> → <span class="badge badge--${cp.newStatus.toLowerCase()}">${cp.newStatus}</span></span>
            <a href="${waLink}" target="_blank" class="btn btn--wa" style="padding:0.4rem 0.8rem;font-size:0.72rem">Notify</a>
          </div>`;
        }).join('');

        const wrap = document.getElementById('playersTable')!;
        const notifyBox = document.createElement('div');
        notifyBox.className = 'alert alert--success';
        notifyBox.style.marginTop = '1rem';
        notifyBox.innerHTML = `<div><strong style="display:block;margin-bottom:0.5rem">Notify players of status changes:</strong>${notifyHtml}</div>`;
        wrap.parentElement!.appendChild(notifyBox);
        setTimeout(() => notifyBox.remove(), 15000);
      }
    } catch { btn.textContent = 'ERROR'; btn.disabled = false; }
  });

  // --- REVENUE ---
  async function loadRevenue() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      const players = data.players || [];
      renderRevenue(players);
    } catch {}
  }

  function renderRevenue(players: any[]) {
    const wrap = document.getElementById('revenueDashboard')!;

    const paid = players.filter((p: any) => p['Payment Status'] === 'Paid');
    const pending = players.filter((p: any) => p['Payment Status'] === 'Pending');
    const rejected = players.filter((p: any) => p['Payment Status'] === 'Rejected');

    const totalRevenue = paid.reduce((sum: number, p: any) => sum + (parseFloat(p.Amount) || 0), 0);

    // Revenue per session
    const sessionMap: Record<string, { paid: number; count: number }> = {};
    paid.forEach((p: any) => {
      const date = p['Session Date'] || 'Unknown';
      if (!sessionMap[date]) sessionMap[date] = { paid: 0, count: 0 };
      sessionMap[date].paid += parseFloat(p.Amount) || 0;
      sessionMap[date].count += 1;
    });

    const sessions = Object.entries(sessionMap).sort(([a], [b]) => a.localeCompare(b));
    const maxRevenue = Math.max(...sessions.map(([, v]) => v.paid), 1);

    wrap.innerHTML = `
      <div class="revenue-summary">
        <div class="rev-card glass">
          <div class="rev-label">Total Revenue</div>
          <div class="rev-value neon-text">RM ${totalRevenue.toFixed(2)}</div>
        </div>
        <div class="rev-card glass">
          <div class="rev-label">Paid</div>
          <div class="rev-value" style="color:var(--neon)">${paid.length}</div>
        </div>
        <div class="rev-card glass">
          <div class="rev-label">Pending</div>
          <div class="rev-value" style="color:#f0c040">${pending.length}</div>
        </div>
        <div class="rev-card glass">
          <div class="rev-label">Rejected</div>
          <div class="rev-value" style="color:var(--red)">${rejected.length}</div>
        </div>
      </div>

      <h4 style="margin:1.5rem 0 1rem;font-size:0.95rem">REVENUE <span class="neon-text">PER SESSION</span></h4>
      ${sessions.length === 0 ? '<p style="color:var(--text-muted)">No paid sessions yet.</p>' : `
        <div class="rev-chart">
          ${sessions.map(([date, v]) => {
            const pct = (v.paid / maxRevenue) * 100;
            return `<div class="rev-bar-row">
              <span class="rev-bar-label">${date}</span>
              <div class="rev-bar-track">
                <div class="rev-bar-fill" style="width:${pct}%"></div>
              </div>
              <span class="rev-bar-amount">RM ${v.paid.toFixed(2)} (${v.count})</span>
            </div>`;
          }).join('')}
        </div>
      `}
    `;
  }
</script>

<style>
  .header { position: sticky; top: 0; z-index: 100; background: rgba(10,10,10,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 0.8rem 0; }
  .brand { display: flex; align-items: center; gap: 0.8rem; }
  .brand-logo { width: 40px; height: 40px; border-radius: 8px; }
  .brand-name { font-size: 1.2rem; }
  .brand-tag { font-size: 0.6rem; color: var(--neon); letter-spacing: 0.2em; font-weight: 600; }
  .back-link { display: flex; align-items: center; gap: 0.3rem; font-size: 0.82rem; color: var(--text-muted); transition: color 0.2s; }
  .back-link:hover { color: var(--neon); }

  .login-card { max-width: 400px; margin: 4rem auto; padding: 2.5rem; text-align: center; }
  .login-icon { color: var(--neon); margin-bottom: 1rem; }
  .login-card h2 { margin-bottom: 1.5rem; font-size: 1.3rem; }

  .tabs { display: flex; gap: 0; margin: 2rem 0 0; border-bottom: 1px solid var(--border); }
  .tab { flex: 1; padding: 1rem; background: none; border: none; color: var(--text-muted); font-family: 'Space Grotesk', sans-serif; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--neon); border-bottom-color: var(--neon); }

  .tab-panel { display: none; padding: 1.5rem 0; }
  .tab-panel.active { display: block; }

  .panel-card { padding: 1.5rem; }
  .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .panel-header h3 { font-size: 1.1rem; }

  .table-wrap { overflow-x: auto; }

  .cell-input, .cell-select {
    background: rgba(0,0,0,0.4); border: 1px solid var(--border); color: var(--text);
    padding: 0.4rem 0.5rem; border-radius: 6px; font-size: 0.82rem; font-family: 'Inter', sans-serif;
    width: 100%;
  }
  .cell-input:focus, .cell-select:focus { border-color: var(--neon); outline: none; }

  .action-cell { display: flex; gap: 0.3rem; }
  .dup-btn, .del-btn { background: none; border: 1px solid var(--border); cursor: pointer; padding: 0.3rem 0.6rem; border-radius: 6px; font-size: 0.8rem; transition: all 0.2s; }
  .del-btn { color: var(--red); }
  .del-btn:hover { background: var(--red); color: #fff; }
  .dup-btn { color: var(--neon); }
  .dup-btn:hover { background: var(--neon); color: #000; }

  .wa-notify-link { color: var(--neon); font-size: 0.82rem; font-weight: 600; }
  .wa-notify-link:hover { text-decoration: underline; }

  .footer { border-top: 1px solid var(--border); padding: 2rem 0; text-align: center; margin-top: 3rem; }
  .footer-inner { font-size: 0.78rem; color: var(--text-muted); }

  /* Revenue Dashboard */
  .revenue-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 1rem; }
  .rev-card { padding: 1.2rem; text-align: center; border-radius: 12px; }
  .rev-label { font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.1em; font-weight: 600; text-transform: uppercase; margin-bottom: 0.4rem; }
  .rev-value { font-size: 1.4rem; font-weight: 700; font-family: 'Space Grotesk', sans-serif; }

  .rev-chart { display: flex; flex-direction: column; gap: 0.6rem; }
  .rev-bar-row { display: flex; align-items: center; gap: 0.8rem; }
  .rev-bar-label { font-size: 0.78rem; color: var(--text-muted); min-width: 90px; text-align: right; }
  .rev-bar-track { flex: 1; height: 24px; background: rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; }
  .rev-bar-fill { height: 100%; background: linear-gradient(90deg, var(--neon), #00e676); border-radius: 6px; transition: width 0.4s ease; }
  .rev-bar-amount { font-size: 0.78rem; color: var(--text); min-width: 110px; font-weight: 600; }
</style>
