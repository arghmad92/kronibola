  }
  .admin-role-chip--sa {
    background: rgba(0,196,255,0.12); color: #00c4ff;
    border: 1px solid rgba(0,196,255,0.3);
  }

  /* Calendar tab — modern month-grid view, mobile-first */

  /* Month nav: < APRIL 2026 >  [TODAY] */
  .cal-monthnav {
    display: flex; align-items: center; gap: 0.6rem;
    margin: 0.8rem 0 0.6rem;
  }
  .cal-nav-btn {
    flex-shrink: 0; width: 38px; height: 38px; border-radius: 12px;
