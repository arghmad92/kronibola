  .pca-trace > div { display: flex; gap: 0.5rem; }
  .pca-trace .trace-label { color: var(--text-muted); min-width: 56px; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.5px; }
  .pca-trace .trace-val { color: var(--text); flex: 1; word-break: break-all; }
  .pca-trace .pca-block {
    margin-top: 0.4rem; align-self: flex-start;
