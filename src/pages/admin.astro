---
import Layout from '../layouts/Layout.astro';
import { FORMATIONS } from '../../functions/api/_formations.js';
// Formation slot list for the admin shuffle dropdowns — same source the
// homepage and the Worker use, so the Position options always match the
// real slots.
const FORMATION_433 = FORMATIONS['4-3-3'];
---

<Layout title="Admin — KroniBola" hideNav={true} noindex={true}>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src="/logo-v2.png" alt="KroniBola" class="brand-logo" />
        <div>
          <h1 class="brand-name">KRONI<span class="neon-text">BOLA</span></h1>
          <p class="brand-tag">ADMIN PANEL</p>
        </div>
      </a>
      <div class="header-right">
        <div class="logged-in-as" id="loggedInAs" style="display:none" title="Logged in as">
          <span class="logged-in-as-label">As</span>
          <span class="logged-in-as-name" id="loggedInAsName">—</span>
          <button type="button" class="logged-in-as-logout" id="logoutBtn" title="Log out">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </div>
        <button type="button" class="notify-bell" id="notifyBell" style="display:none" aria-label="Pending notifications" title="Pending notifications">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
          </svg>
          <span class="notify-bell-count zero" id="notifyBellCount">0</span>
        </button>
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Back
        </a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- Login -->
    <div id="loginGate">
      <div class="login-card glass">
        <div class="login-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2>ADMIN <span class="neon-text">ACCESS</span></h2>
        <form id="loginForm">
          <div class="form-group">
            <label class="form-label" for="adminUser">Username</label>
            <input type="text" class="form-input" id="adminUser" placeholder="e.g. iman" autocomplete="username" autocapitalize="none" autocorrect="off" spellcheck="false" required style="width:100%;text-transform:lowercase" />
          </div>
          <div class="form-group">
            <label class="form-label" for="adminPass">Password</label>
            <input type="password" class="form-input" id="adminPass" placeholder="Your password" autocomplete="current-password" required style="width:100%" />
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%;margin-top:0.5rem">UNLOCK</button>
        </form>
        <div id="loginError" style="display:none;margin-top:1rem"></div>
        <p class="login-hint">Forgot your password? Ask the Creator.</p>
      </div>
    </div>

    <div id="adminContent" style="display:none">
      <!-- Tabs -->
      <div class="tabs">
        <button class="tab active" data-tab="schedule">Schedule</button>
        <button class="tab" data-tab="players">Players</button>
        <button class="tab" data-tab="orders">Orders</button>
        <button class="tab" data-tab="calendar">Calendar</button>
        <button class="tab" data-tab="stats">Stats</button>
        <button class="tab" data-tab="notifs">Notifs</button>
        <button class="tab" data-tab="blocked">Blocked</button>
        <button class="tab" data-tab="admins">Admins</button>
      </div>

      <!-- Schedule Tab -->
      <div class="tab-panel active" id="tab-schedule">
        <div class="panel-top">
          <h3 class="panel-title">UPCOMING <span class="neon-text">GAMES</span></h3>
          <div style="display:flex;gap:0.4rem">
            <button class="btn btn--outline btn--sm" id="autoCloseBtn" title="Close all played sessions">AUTO-CLOSE</button>
            <button class="btn btn--primary btn--sm" id="addSessionBtn">+ ADD</button>
          </div>
        </div>
        <div id="scheduleList" class="card-list"></div>
        <button class="btn btn--primary" id="saveScheduleBtn" style="width:100%;margin-top:1rem">SAVE SCHEDULE</button>
      </div>

      <!-- Players Tab -->
      <div class="tab-panel" id="tab-players">
        <div class="panel-top">
          <h3 class="panel-title">MANAGE <span class="neon-text">PLAYERS</span></h3>
          <button class="btn btn--outline btn--sm" id="refreshPlayersBtn">Refresh</button>
        </div>
        <div class="form-group" style="margin-bottom:0.8rem">
          <select class="form-select" id="filterDate" style="width:100%">
            <option value="">Select a game...</option>
          </select>
        </div>
        <!-- Per-game summary -->
        <div id="playersSummary" class="order-summary" style="display:none"></div>
        <!-- Share to WhatsApp -->
        <div id="shareWaSection" style="display:none;margin-bottom:0.8rem">
          <div class="share-wa-btns">
            <button class="btn btn--wa btn--sm" id="shareWaOpen">🟢 Open</button>
            <button class="btn btn--wa btn--sm" id="shareWaFilling">🔥 Filling Up</button>
            <button class="btn btn--wa btn--sm" id="shareWaLast">🚨 Last Slots</button>
            <button class="btn btn--wa btn--sm" id="shareWaFull">🔴 Full</button>
          </div>
        </div>
        <!-- Add player form -->
        <div class="add-player-box" id="addPlayerBox" style="display:none">
          <div class="ap-row">
            <div class="form-group" style="flex:1">
              <label class="form-label">Name</label>
              <input type="text" class="form-input" id="apName" placeholder="Player name" style="text-transform:capitalize" autocapitalize="words" />
            </div>
            <div class="form-group" style="flex:1">
              <label class="form-label">Phone</label>
              <input type="tel" class="form-input" id="apPhone" placeholder="0123456789" />
            </div>
          </div>
          <div class="ap-row">
            <div class="form-group" style="flex:1">
              <label class="form-label">Status</label>
              <select class="form-select" id="apStatus">
                <option value="Paid">Paid</option>
                <option value="Pending">Pending</option>
                <option value="Waitlist">Waitlist</option>
              </select>
            </div>
            <div class="form-group" style="flex:1">
              <label class="form-label">Fee (RM)</label>
              <input type="number" class="form-input" id="apFee" value="28" />
            </div>
          </div>
          <!-- Optional plate: only shown for sessions where Require Car Plate = Yes.
               Admin can skip it if the plate isn't known at add time — the
               player can fill it in later via the public Check-My-Status flow. -->
          <div class="ap-row" id="apPlateRow" style="display:none">
            <div class="form-group" style="flex:1">
              <label class="form-label">Car Plate <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
              <input type="text" class="form-input" id="apPlate" placeholder="e.g. VAB1234" style="text-transform:uppercase" autocomplete="off" maxlength="10" />
            </div>
          </div>
          <button class="btn btn--primary btn--sm" id="apConfirm" style="width:100%">ADD PLAYER</button>
        </div>
        <button class="btn btn--outline btn--sm" id="addPlayerBtn" style="width:100%;margin-bottom:0.8rem">+ ADD PLAYER MANUALLY</button>

        <div id="playersList" class="card-list"></div>
        <button class="btn btn--primary" id="savePlayersBtn" style="width:100%;margin-top:1rem">SAVE CHANGES</button>

        <div id="carPlateSection" style="display:none">
          <div class="panel-top" style="margin-top:1rem">
            <h3 class="panel-title">CAR <span class="neon-text">PLATES</span></h3>
            <button class="btn btn--primary btn--sm" id="copyPlatesBtn">Copy Plates</button>
          </div>
          <div id="carPlateList" class="card-list"></div>
        </div>
      </div>

      <!-- Notifications Tab -->
      <div class="tab-panel" id="tab-notifs">
        <div class="panel-top">
          <h3 class="panel-title">NOTIFICATION <span class="neon-text">LOG</span></h3>
          <button class="btn btn--primary btn--sm" id="refreshNotifsBtn">Refresh</button>
        </div>
        <div id="notifsList" class="card-list">
          <p class="empty-msg">Loading...</p>
        </div>
      </div>

      <!-- Orders Tab -->
      <div class="tab-panel" id="tab-orders">
        <div class="panel-top">
          <h3 class="panel-title">JERSEY <span class="neon-text">ORDERS</span></h3>
          <button class="btn btn--outline btn--sm" id="refreshOrdersBtn">Refresh</button>
        </div>

        <!-- Order Summary -->
        <div id="orderSummary" class="order-summary"></div>

        <div class="form-group" style="margin-bottom:0.8rem">
          <select class="form-select" id="orderFilter" style="width:100%">
            <option value="all">All Orders</option>
            <option value="Pending">Pending</option>
            <option value="Paid">Paid</option>
            <option value="Collected">Collected</option>
            <option value="Deleted">Deleted</option>
          </select>
        </div>

        <div id="ordersList" class="card-list"><p class="empty-msg">Loading...</p></div>
      </div>

      <!-- Stats Tab -->
      <div class="tab-panel" id="tab-stats">
        <div class="panel-top">
          <h3 class="panel-title">STATS <span class="neon-text">DASHBOARD</span></h3>
        </div>
        <div class="stats-grid" id="statsGrid">
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <div class="stat-value" id="statSessions">-</div>
            <div class="stat-label">Sessions Played</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            <div class="stat-value" id="statTotalPlayers">-</div>
            <div class="stat-label">Total Registrations</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="stat-value" id="statUnique">-</div>
            <div class="stat-label">Unique Players</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
            <div class="stat-value" id="statRevenue">-</div>
            <div class="stat-label">Total Revenue</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg></div>
            <div class="stat-value" id="statAvg">-</div>
            <div class="stat-label">Avg Players/Game</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
            <div class="stat-value" id="statMvp">-</div>
            <div class="stat-label">Most Active Player</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
            <div class="stat-value" id="statRetention">-</div>
            <div class="stat-label">Retention Rate</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
            <div class="stat-value" id="statNoshow">-</div>
            <div class="stat-label">No-shows / Overdue</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <div class="stat-value" id="statPeakDay">-</div>
            <div class="stat-label">Most Popular Day</div>
          </div>
        </div>
        <h4 class="sub-heading">REVENUE <span class="neon-text">BREAKDOWN</span></h4>
        <div id="revenueDashboard"></div>
      </div>

      <!-- Calendar Tab — month grid view with games, public holidays, admin leave -->
      <div class="tab-panel" id="tab-calendar">
        <div class="panel-top">
          <h3 class="panel-title">CALENDAR</h3>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap">
            <button class="btn btn--outline btn--sm" id="addLeaveBtn">+ LEAVE</button>
            <button class="btn btn--outline btn--sm" id="addHolidayBtn">+ HOLIDAY</button>
            <button class="btn btn--outline btn--sm" id="syncMyHolidaysBtn" title="Pre-fill Malaysia Klang Valley 2026 public holidays">SYNC MY 2026</button>
          </div>
        </div>

        <!-- Month navigation -->
        <div class="cal-monthnav">
          <button type="button" class="cal-nav-btn" id="calPrevMonth" aria-label="Previous month">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="cal-month-label">
            <span class="cal-month-name" id="calMonthName">—</span>
            <span class="cal-month-year" id="calMonthYear">—</span>
          </div>
          <button type="button" class="cal-nav-btn" id="calNextMonth" aria-label="Next month">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <button type="button" class="cal-today-btn" id="calTodayBtn">TODAY</button>
        </div>

        <!-- Filter chips -->
        <div class="cal-filters" id="calFilters">
          <button type="button" class="cal-chip active" data-stream="all">All</button>
          <button type="button" class="cal-chip" data-stream="games"><span class="cal-dot cal-dot--game"></span>Games</button>
          <button type="button" class="cal-chip" data-stream="holidays"><span class="cal-dot cal-dot--holiday"></span>Holidays</button>
          <button type="button" class="cal-chip" data-stream="school"><span class="cal-dot cal-dot--school"></span>School</button>
          <button type="button" class="cal-chip" data-stream="sports"><span class="cal-dot cal-dot--sports"></span>Sports</button>
          <button type="button" class="cal-chip" data-stream="leave"><span class="cal-dot cal-dot--leave"></span>Leave</button>
        </div>

        <!-- Subscribe-to-feed (admin testing). Two URLs per admin: a public
             matches feed and a token-protected full admin feed. Tap "Add to
             iPhone" on phone for the webcal:// deep-link, or copy the URL
             into Google Calendar / Outlook / Mac Calendar. Hidden behind a
             <details> so it doesn't dominate the calendar header. -->
        <details class="cal-feeds">
          <summary>📲 Subscribe on your phone</summary>
          <div class="cal-feeds-body">
            <p class="cal-feeds-help">
              Add your KroniBola calendar to iPhone or Google Calendar so it
              stays in sync automatically. iOS refresh defaults to once a day —
              set it to <em>Every 5 mins</em> in Settings → Calendar →
              Accounts → Subscribed Calendars for near-realtime updates.
            </p>

            <div class="cal-feed">
              <div class="cal-feed-meta">
                <span class="cal-feed-label">⚽ Match schedule</span>
                <span class="cal-feed-tag cal-feed-tag--public">PUBLIC</span>
              </div>
              <div class="cal-feed-row">
                <input type="text" readonly id="feedMatchesUrl" class="cal-feed-url" placeholder="loading…" />
                <button type="button" class="cal-feed-copy" data-target="feedMatchesUrl">Copy</button>
                <a id="feedMatchesAdd" class="btn btn--primary btn--sm" href="#" target="_blank" rel="noopener">Add to iPhone</a>
              </div>
            </div>

            <div class="cal-feed">
              <div class="cal-feed-meta">
                <span class="cal-feed-label">📅 Full admin calendar</span>
                <span class="cal-feed-tag cal-feed-tag--admin">ADMIN ONLY</span>
              </div>
              <div class="cal-feed-row">
                <input type="text" readonly id="feedAdminUrl" class="cal-feed-url" placeholder="loading…" />
                <button type="button" class="cal-feed-copy" data-target="feedAdminUrl">Copy</button>
                <a id="feedAdminAdd" class="btn btn--primary btn--sm" href="#" target="_blank" rel="noopener">Add to iPhone</a>
              </div>
              <p class="cal-feed-warning">⚠️ Includes leave + sports events. Only share with KroniBola admins.</p>
            </div>
          </div>
        </details>

        <!-- Month grid -->
        <div class="cal-grid-wrap">
          <div class="cal-weekdays" id="calWeekdays"></div>
          <div class="cal-grid" id="calGrid"></div>
        </div>

        <!-- Selected-day details panel -->
        <div class="cal-day-details" id="calDayDetails"></div>
      </div>

      <!-- Blocked Tab — manage phone & IP blocklist for spam / fake receipts -->
      <div class="tab-panel" id="tab-blocked">
        <div class="panel-top">
          <h3 class="panel-title">BLOCK <span class="neon-text">LIST</span></h3>
          <button class="btn btn--outline btn--sm" id="refreshBlockedBtn">Refresh</button>
        </div>
        <p class="admin-help">Phones and IPs in these lists are rejected at registration with a generic error. Useful for shutting down repeat fake-receipt offenders without exposing them to enumeration.</p>

        <div class="block-section">
          <div class="block-section-head">
            <h4 class="sub-heading" style="margin:0">BLOCKED <span class="neon-text">PHONES</span></h4>
            <button class="btn btn--primary btn--sm" id="addBlockedPhoneBtn">+ Add</button>
          </div>
          <div id="blockedPhonesList" class="card-list"></div>
        </div>

        <div class="block-section" style="margin-top:1.5rem">
          <div class="block-section-head">
            <h4 class="sub-heading" style="margin:0">BLOCKED <span class="neon-text">IPs</span></h4>
            <button class="btn btn--primary btn--sm" id="addBlockedIpBtn">+ Add</button>
          </div>
          <div id="blockedIpsList" class="card-list"></div>
        </div>
      </div>

      <!-- Admins Tab — manage admin accounts -->
      <div class="tab-panel" id="tab-admins">
        <div class="panel-top">
          <h3 class="panel-title">MANAGE <span class="neon-text">ADMINS</span></h3>
          <button class="btn btn--primary btn--sm" id="addAdminBtn">+ ADD ADMIN</button>
        </div>
        <p class="admin-help">Create accounts for each admin so leave applications and notification logs are attributed to the right person. The owner password (env var) still works as a recovery login.</p>
        <div id="adminsList" class="card-list"></div>
      </div>
    </div>
  </main>

  <!-- Apply for Leave modal -->
  <div class="modal-overlay" id="leaveModal" style="display:none">
    <div class="modal">
      <button type="button" class="modal-close" id="leaveModalClose">&times;</button>
      <h3 class="modal-title">APPLY <span class="neon-text">LEAVE</span></h3>
      <p class="modal-sub" id="leaveModalSub">Logged in as —</p>
      <div class="form-group">
        <label class="form-label">From</label>
        <input type="date" class="form-input" id="leaveFrom" />
      </div>
      <div class="form-group">
        <label class="form-label">To</label>
        <input type="date" class="form-input" id="leaveTo" />
      </div>
      <div class="form-group">
        <label class="form-label">Reason <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
        <input type="text" class="form-input" id="leaveReason" placeholder="e.g. Family trip KK" maxlength="200" />
      </div>
      <button type="button" class="btn btn--primary" id="leaveSubmitBtn" style="width:100%;margin-top:0.4rem">SUBMIT</button>
      <div id="leaveModalError" style="display:none;margin-top:0.6rem"></div>
    </div>
  </div>

  <!-- Add Holiday modal -->
  <div class="modal-overlay" id="holidayModal" style="display:none">
    <div class="modal">
      <button type="button" class="modal-close" id="holidayModalClose">&times;</button>
      <h3 class="modal-title" id="holidayModalTitle">ADD <span class="neon-text">HOLIDAY</span></h3>
      <p class="modal-sub" id="holidayModalSub">Add a public holiday or community blackout day.</p>
      <div class="form-group">
        <label class="form-label">Date</label>
        <input type="date" class="form-input" id="holidayDate" />
      </div>
      <div class="form-group">
        <label class="form-label">Name</label>
        <input type="text" class="form-input" id="holidayName" placeholder="e.g. Hari Pekerja" maxlength="80" />
      </div>
      <!-- Type row hidden for regular admins (they can only add Sports
           events; Type is forced server-side regardless). -->
      <div class="form-group" id="holidayTypeRow">
        <label class="form-label">Type</label>
        <select class="form-select" id="holidayType">
          <option value="Federal">Federal</option>
          <option value="State">State</option>
          <option value="School">School</option>
          <option value="Sports">Sports Event</option>
          <option value="Custom" selected>Custom</option>
        </select>
      </div>
      <button type="button" class="btn btn--primary" id="holidaySubmitBtn" style="width:100%;margin-top:0.4rem">SAVE</button>
      <div id="holidayModalError" style="display:none;margin-top:0.6rem"></div>
    </div>
  </div>

  <!-- Add / Edit Admin modal -->
  <div class="modal-overlay" id="adminModal" style="display:none">
    <div class="modal">
      <button type="button" class="modal-close" id="adminModalClose">&times;</button>
      <h3 class="modal-title" id="adminModalTitle">ADD <span class="neon-text">ADMIN</span></h3>
      <p class="modal-sub" id="adminModalSub">Create a new admin account</p>
      <!-- Username is only editable when creating a new admin. On edit it's
           hidden — the modal subtitle already shows @username and the
           server doesn't accept username changes anyway. -->
      <div class="form-group" id="adminUsernameRow">
        <label class="form-label">Username</label>
        <input type="text" class="form-input" id="adminUsername" placeholder="e.g. iman" autocapitalize="none" autocorrect="off" spellcheck="false" style="text-transform:lowercase" />
      </div>
      <div class="form-group">
        <label class="form-label">Display Name</label>
        <input type="text" class="form-input" id="adminDisplayName" placeholder="e.g. Iman" />
      </div>
      <div class="form-group">
        <label class="form-label" id="adminPasswordLabel">Password</label>
        <input type="password" class="form-input" id="adminPassword" placeholder="At least 6 characters" autocomplete="new-password" />
        <p class="form-hint" id="adminPasswordHint" style="display:none;font-size:0.7rem;color:var(--text-muted);margin-top:0.3rem">Leave blank to keep the current password.</p>
      </div>
      <!-- Role row: visible to superadmins only. Promotes/demotes managed
           admins. Hidden when the current session is a regular admin so the
           form can't be (mis)used to escalate privilege client-side; the
           server still rejects the change either way. -->
      <div class="form-group" id="adminRoleRow" style="display:none">
        <label class="form-label">Role</label>
        <select class="form-select" id="adminRole">
          <option value="">Admin</option>
          <option value="superadmin">Superadmin (can manage other admins)</option>
        </select>
      </div>
      <button type="button" class="btn btn--primary" id="adminSubmitBtn" style="width:100%;margin-top:0.4rem">CREATE</button>
      <div id="adminModalError" style="display:none;margin-top:0.6rem"></div>
    </div>
  </div>

  <!-- Global save status toast (visible from any tab) -->
  <div class="save-toast" id="saveToast" role="status" aria-live="polite">Saved</div>

  <!-- Notification Center (queue of pending WhatsApp messages for status changes) -->
  <div class="nc-backdrop" id="ncBackdrop"></div>
  <aside class="ncenter" id="ncenter" role="dialog" aria-label="Pending player notifications" aria-hidden="true">
    <div class="nc-handle"></div>
    <div class="nc-head">
      <div class="nc-title-wrap">
        <h2 class="nc-title">Notify Players</h2>
        <span class="nc-subtitle" id="ncSubtitle">0 pending</span>
      </div>
      <button type="button" class="nc-close" id="ncClose" aria-label="Close notification center">&times;</button>
    </div>
    <div class="nc-list" id="ncList"></div>
    <div class="nc-foot" id="ncFoot" style="display:none">
      <button type="button" class="nc-foot-btn nc-foot-btn--secondary" id="ncMarkAll">Mark all sent</button>
      <button type="button" class="nc-foot-btn nc-foot-btn--primary" id="ncSendAll">Send all →</button>
    </div>
  </aside>

  <footer class="footer">
    <p>&copy; 2025 KroniBola. All rights reserved.</p>
    <p class="ssm">SSM: 202603032902 (TR0336774-T)</p>
  </footer>
</Layout>

<!-- Formation slot list for the admin shuffle dropdowns. -->
<script is:inline define:vars={{ kbFormation: FORMATION_433 }}>
  window.KB_FORMATION = kbFormation;
</script>

<script>
  const API = '/api';
  let adminToken = '';
  // Session captured from /api/admin/auth response. Drives "Logged in as"
  // header chip, leave-modal pre-fill, Apply-Leave eligibility, and the
  // Manage Admins panel's conditional buttons (only superadmins can edit
  // OR delete other admins; everyone can edit themselves).
  let adminSession: { username: string; displayName: string; isOwner: boolean; isSuperadmin: boolean } | null = null;

  // --- Toast helper (global save confirmation) ---
  let toastTimer: ReturnType<typeof setTimeout> | null = null;
  function showToast(message: string, kind: 'success' | 'error' = 'success') {
    const toast = document.getElementById('saveToast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.remove('save-toast--error');
    if (kind === 'error') toast.classList.add('save-toast--error');
    toast.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => { toast.classList.remove('show'); }, 2200);
  }

  // --- Notification Center (queue of pending WhatsApp messages) ---
  type NotifyItem = { id: string; name: string; phone: string; fromStatus: string; toStatus: string; date: string; msg: string; time: number };
  let notifyQueue: NotifyItem[] = [];
  let notifyIdCounter = 1;
  const NC_STATUSES = ['Pending', 'Paid', 'Overdue', 'Waitlist', 'Rejected'];

  function ncEsc(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }
  function ncTimeAgo(ts: number): string {
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 10) return 'just now';
    if (s < 60) return `${s}s ago`;
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ago`;
    return `${Math.floor(m / 60)}h ago`;
  }

  // Build the templated WhatsApp message for a status change.
  // Single source of truth — used by both bulk and per-player save paths.
  function buildNotifyMessage(playerName: string, newStatus: string, date: string, session: any): string {
    const sessionName = session ? session['Session Name'] : 'Game';
    const sessionTime = session ? session.Time : '';
    const sessionLoc = session ? session.Location : '';
    const wazeLink = sessionLoc ? `https://waze.com/ul?q=${encodeURIComponent(sessionLoc)}` : '';
    const gameDetails = `📅 ${date}${sessionTime ? `\n⏰ ${sessionTime}` : ''}${sessionLoc ? `\n📍 ${sessionLoc}` : ''}${wazeLink ? `\n🗺️ ${wazeLink}` : ''}`;
    const msgs: Record<string, string> = {
      Paid: `Hi ${playerName}! ✅ Your payment for *${sessionName}* has been confirmed. You're in!\n\n${gameDetails}\n\nSee you on the pitch! ⚽\n\nJoin our WhatsApp group if you haven't: https://chat.whatsapp.com/FsLEE1Bko9a9fGXd88UPgS`,
      Pending: `Hi ${playerName}! 🎉 Good news — a slot has opened up for *${sessionName}*!\n\n${gameDetails}\n\nTo confirm your spot:\n1. Pay via Maybank MAE (scan QR at kronibola.com)\n2. Go to kronibola.com\n3. Tap "CHECK MY STATUS"\n4. Enter your phone number\n5. Upload your payment receipt\n\nPlease do this ASAP or your slot may be given to the next player.`,
      Rejected: `Hi ${playerName}, unfortunately your registration for *${sessionName}* on ${date} has been cancelled. If you believe this is a mistake, please contact us via kronibola.com.`,
      Waitlist: `Hi ${playerName}, you've been moved to the waitlist for *${sessionName}* on ${date}. We'll notify you immediately if a slot opens up.\n\n⚠️ Please do NOT pay yet — only pay when we confirm a slot for you.`,
      Overdue: `Hi ${playerName}, ⚠️ your payment for *${sessionName}* is overdue.\n\n${gameDetails}\n\nTo keep your slot:\n1. Pay via Maybank MAE (scan QR at kronibola.com)\n2. Go to kronibola.com → tap "CHECK MY STATUS"\n3. Enter your phone number and upload your receipt\n\nPlease do this ASAP or your slot will be given to the next player.`,
    };
    return msgs[newStatus] || `Hi ${playerName}, your status for ${date} is now: ${newStatus}.`;
  }

  function renderNotifyCenter() {
    const list = document.getElementById('ncList');
    const subtitle = document.getElementById('ncSubtitle');
    const count = document.getElementById('notifyBellCount');
    const foot = document.getElementById('ncFoot');
    if (!list || !subtitle || !count || !foot) return;

    subtitle.textContent = `${notifyQueue.length} pending`;
    count.textContent = String(notifyQueue.length);
    count.classList.toggle('zero', notifyQueue.length === 0);
    foot.style.display = notifyQueue.length > 0 ? 'flex' : 'none';

    if (notifyQueue.length === 0) {
      list.innerHTML = `
        <div class="nc-empty">
          <div class="nc-empty-icon">✓</div>
          <div class="nc-empty-title">All caught up</div>
          <div class="nc-empty-sub">Change a player's status to queue a WhatsApp notification.</div>
        </div>`;
      return;
    }

    list.innerHTML = notifyQueue.map((q) => {
      const safeFrom = NC_STATUSES.includes(q.fromStatus) ? q.fromStatus : 'Pending';
      const safeTo = NC_STATUSES.includes(q.toStatus) ? q.toStatus : 'Pending';
      return `<div class="nc-row" data-id="${ncEsc(q.id)}">
        <div class="nc-row-head">
          <span class="nc-row-name">${ncEsc(q.name)}</span>
          <span class="nc-row-time" data-time="${q.time}">${ncTimeAgo(q.time)}</span>
        </div>
        <div class="nc-row-transition">
          <span class="nc-status-chip nc-status--${safeFrom}">${ncEsc(q.fromStatus || '—')}</span>
          <span class="nc-row-arrow">→</span>
          <span class="nc-status-chip nc-status--${safeTo}">${ncEsc(q.toStatus)}</span>
          <span class="nc-row-phone">${ncEsc(q.phone || 'no phone')}</span>
        </div>
        <div class="nc-row-preview">${ncEsc(q.msg)}</div>
        <button type="button" class="nc-preview-expand" data-action="expand" data-id="${ncEsc(q.id)}">Show full message ▾</button>
        <textarea class="nc-row-edit" data-id="${ncEsc(q.id)}" rows="6">${ncEsc(q.msg)}</textarea>
        <div class="nc-row-actions">
          <button type="button" class="nc-btn nc-btn--edit" data-action="edit" data-id="${ncEsc(q.id)}">✎ Edit</button>
          <button type="button" class="nc-btn nc-btn--skip" data-action="skip" data-id="${ncEsc(q.id)}">⏭ Skip</button>
          <button type="button" class="nc-btn nc-btn--send" data-action="send" data-id="${ncEsc(q.id)}">Send WhatsApp →</button>
        </div>
      </div>`;
    }).join('');
  }

  function enqueueNotify(item: Omit<NotifyItem, 'id' | 'time'>) {
    if (!item.toStatus) return;
    const newItem: NotifyItem = { ...item, id: 'n' + (notifyIdCounter++), time: Date.now() };
    notifyQueue.push(newItem);
    renderNotifyCenter();
    // Log the notification intent to the sheet (preserves existing audit behaviour).
    logNotification(newItem.name, newItem.phone, newItem.toStatus, newItem.date, newItem.msg);
    // Pulse the bell to draw the eye.
    const bell = document.getElementById('notifyBell');
    if (bell) { bell.classList.remove('notify-bell--pulse'); void bell.offsetHeight; bell.classList.add('notify-bell--pulse'); }
    showToast(`Queued for ${item.name}`);
  }

  function openNotifyCenter() {
    document.getElementById('ncBackdrop')?.classList.add('open');
    const el = document.getElementById('ncenter');
    if (el) { el.classList.add('open'); el.setAttribute('aria-hidden', 'false'); }
    // Refresh time-ago labels when opening.
    document.querySelectorAll<HTMLElement>('.nc-row-time[data-time]').forEach((el) => {
      el.textContent = ncTimeAgo(parseInt(el.dataset.time!, 10));
    });
  }
  function closeNotifyCenter() {
    document.getElementById('ncBackdrop')?.classList.remove('open');
    const el = document.getElementById('ncenter');
    if (el) { el.classList.remove('open'); el.setAttribute('aria-hidden', 'true'); }
  }
  function removeNotifyItem(id: string) {
    const row = document.querySelector(`.nc-row[data-id="${id}"]`);
    if (row) row.classList.add('removing');
    setTimeout(() => {
      notifyQueue = notifyQueue.filter((q) => q.id !== id);
      renderNotifyCenter();
    }, 240);
  }
  function waLinkFor(item: NotifyItem): string | null {
    // toWaNumber handles E.164 (new), legacy MY local 0-prefix, and bare
    // international formats. Lives in Layout.astro's shared phone helper.
    const num = (window as any).KB_PHONE?.toWaNumber(item.phone || '') || '';
    return num ? `https://wa.me/${num}?text=${encodeURIComponent(item.msg)}` : null;
  }

  // Wire up the center once, after DOM is ready.
  (function initNotifyCenter() {
    const bell = document.getElementById('notifyBell');
    const closeBtn = document.getElementById('ncClose');
    const backdrop = document.getElementById('ncBackdrop');
    const list = document.getElementById('ncList');
    const sendAll = document.getElementById('ncSendAll');
    const markAll = document.getElementById('ncMarkAll');
    if (!bell || !closeBtn || !backdrop || !list || !sendAll || !markAll) return;

    bell.addEventListener('click', openNotifyCenter);
    closeBtn.addEventListener('click', closeNotifyCenter);
    backdrop.addEventListener('click', closeNotifyCenter);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.getElementById('ncenter')?.classList.contains('open')) closeNotifyCenter();
    });

    list.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!btn) return;
      const id = btn.dataset.id!;
      const action = btn.dataset.action!;
      const item = notifyQueue.find((q) => q.id === id);
      if (!item) return;
      const rowEl = list.querySelector(`.nc-row[data-id="${id}"]`) as HTMLElement | null;
      if (!rowEl) return;

      if (action === 'expand') {
        rowEl.querySelector('.nc-row-preview')?.classList.add('expanded');
        btn.remove();
      } else if (action === 'edit') {
        if (rowEl.classList.contains('editing')) {
          const ta = rowEl.querySelector<HTMLTextAreaElement>('.nc-row-edit');
          if (ta) item.msg = ta.value;
          rowEl.classList.remove('editing');
          const preview = rowEl.querySelector('.nc-row-preview') as HTMLElement | null;
          if (preview) preview.textContent = item.msg;
          btn.innerHTML = '✎ Edit';
        } else {
          rowEl.classList.add('editing');
          btn.innerHTML = '✓ Save';
        }
      } else if (action === 'skip') {
        removeNotifyItem(id);
      } else if (action === 'send') {
        const href = waLinkFor(item);
        if (href) window.open(href, '_blank', 'noopener');
        else showToast(`No phone number for ${item.name}`, 'error');
        removeNotifyItem(id);
      }
    });

    sendAll.addEventListener('click', () => {
      const items = [...notifyQueue];
      if (!items.length) return;
      items.forEach((it, i) => {
        setTimeout(() => {
          const href = waLinkFor(it);
          if (href) window.open(href, '_blank', 'noopener');
          removeNotifyItem(it.id);
        }, i * 400);
      });
      showToast(`Opening ${items.length} WhatsApp message${items.length > 1 ? 's' : ''}…`);
    });
    markAll.addEventListener('click', () => {
      const n = notifyQueue.length;
      if (!n) return;
      notifyQueue = [];
      renderNotifyCenter();
      showToast(`Marked ${n} as sent`);
    });

    // Live time-ago updater (runs every 30s while any items are queued).
    setInterval(() => {
      document.querySelectorAll<HTMLElement>('.nc-row-time[data-time]').forEach((el) => {
        el.textContent = ncTimeAgo(parseInt(el.dataset.time!, 10));
      });
    }, 30_000);

    renderNotifyCenter();
  })();
  let sessionsData: any[] = [];
  let allPlayers: any[] = [];

  // XSS protection — escape HTML in user-supplied data
  function esc(text: any): string {
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
    return String(text || '').replace(/[&<>"']/g, m => map[m]);
  }

  // --- STATS DASHBOARD ---
  async function loadStats() {
    try {
      const [sessRes, plRes] = await Promise.all([
        fetch(`${API}/admin/sessions`, { headers: { Authorization: adminToken } }),
        fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } }),
      ]);
      const sessions = (await sessRes.json()).sessions || [];
      const players = (await plRes.json()).players || [];

      // Only count confirmed players (Paid status, not Rejected/Waitlist)
      const confirmed = players.filter((p: any) => p['Payment Status'] === 'Paid');

      // Sessions played (Closed status)
      const closedSessions = sessions.filter((s: any) => s.Status === 'Closed');
      document.getElementById('statSessions')!.textContent = String(closedSessions.length);

      // Total registrations
      document.getElementById('statTotalPlayers')!.textContent = String(confirmed.length);

      // Group by player name — reused for unique count, MVP, and retention.
      // Phone isn't a reliable identity key since one person often registers
      // for friends using their own phone, which both inflates that person's
      // count and merges multiple different players into one record.
      // Names are Title-Cased at registration (see functions/api/register.js),
      // so case/whitespace drift can't split one player into two.
      const nameCounts: Record<string, { name: string; count: number }> = {};
      for (const p of confirmed) {
        const displayName = String(p['Player Name'] || '').trim();
        if (!displayName) continue;
        const key = displayName.toLowerCase().replace(/\s+/g, ' ');
        if (!nameCounts[key]) nameCounts[key] = { name: displayName, count: 0 };
        nameCounts[key].count++;
      }

      // Unique players
      document.getElementById('statUnique')!.textContent = String(Object.keys(nameCounts).length);

      // Total revenue (sum of Amount for Paid players)
      const totalRev = confirmed.reduce((sum: number, p: any) => sum + (parseFloat(p.Amount) || 0), 0);
      document.getElementById('statRevenue')!.textContent = `RM${totalRev.toLocaleString()}`;

      // Average players per closed session
      if (closedSessions.length > 0) {
        const avg = (confirmed.length / closedSessions.length).toFixed(1);
        document.getElementById('statAvg')!.textContent = avg;
      } else {
        document.getElementById('statAvg')!.textContent = '-';
      }

      // Most active player
      const sorted = Object.values(nameCounts).sort((a, b) => b.count - a.count);
      if (sorted.length > 0) {
        const mvp = sorted[0];
        document.getElementById('statMvp')!.textContent = mvp.name;
        document.getElementById('statMvp')!.title = `${mvp.count} sessions`;
      } else {
        document.getElementById('statMvp')!.textContent = '-';
      }

      // Retention rate (players who came back 2+ times)
      const returning = Object.values(nameCounts).filter(p => p.count >= 2).length;
      const totalUnique = Object.keys(nameCounts).length;
      if (totalUnique > 0) {
        const rate = Math.round((returning / totalUnique) * 100);
        document.getElementById('statRetention')!.textContent = `${rate}%`;
        document.getElementById('statRetention')!.title = `${returning} of ${totalUnique} players returned`;
      }

      // No-shows / Overdue count
      const noshows = players.filter((p: any) => ['Overdue', 'Rejected'].includes(p['Payment Status']));
      document.getElementById('statNoshow')!.textContent = String(noshows.length);

      // Most popular day of week
      const dayCounts: Record<string, number> = {};
      for (const s of closedSessions) {
        const d = new Date(s.Date);
        if (isNaN(d.getTime())) continue;
        const day = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][d.getDay()];
        dayCounts[day] = (dayCounts[day] || 0) + 1;
      }
      const peakDay = Object.entries(dayCounts).sort((a, b) => b[1] - a[1])[0];
      if (peakDay) {
        document.getElementById('statPeakDay')!.textContent = peakDay[0];
        document.getElementById('statPeakDay')!.title = `${peakDay[1]} sessions on ${peakDay[0]}`;
      }
    } catch {
      // Silently fail — stats show "-"
    }
  }

  // --- ORDERS TAB ---
  let allOrders: any[] = [];

  async function loadOrders() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      // Orders are on a separate sheet — use a direct call
      const ordRes = await fetch(`${API}/order-status?phone=_all_admin_`).catch(() => null);
      // Fallback: read from admin endpoint with sheet name override
      // For now, read orders via a simple fetch
    } catch {}
    // Direct sheet read via admin sessions endpoint pattern
    try {
      const res = await fetch(`${API}/admin/orders`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      allOrders = data.orders || [];
      renderOrders();
    } catch {
      document.getElementById('ordersList')!.innerHTML = '<p class="empty-msg">Failed to load orders.</p>';
    }
  }

  function renderOrderSummary() {
    const summary = document.getElementById('orderSummary')!;
    if (!allOrders.length) { summary.innerHTML = ''; return; }

    // Exclude deleted orders from summary
    const activeOrders = allOrders.filter((o: any) => o['Payment Status'] !== 'Deleted');
    const totalOrders = activeOrders.length;
    const totalQty = activeOrders.reduce((s: number, o: any) => s + (parseInt(o.Quantity) || 0), 0);
    const totalRevenue = activeOrders.reduce((s: number, o: any) => s + (parseFloat(o.Total) || 0), 0);
    const pending = activeOrders.filter((o: any) => o['Payment Status'] === 'Pending').length;
    const paid = activeOrders.filter((o: any) => o['Payment Status'] === 'Paid').length;
    const collected = activeOrders.filter((o: any) => o['Payment Status'] === 'Collected').length;
    const deleted = allOrders.filter((o: any) => o['Payment Status'] === 'Deleted').length;

    // Size breakdown — parse "M ×1, L ×2" format (active orders only)
    const sizes: Record<string, number> = {};
    activeOrders.forEach((o: any) => {
      const sizeStr = o.Size || '';
      // Split by comma, then parse each "SIZE ×QTY" pair
      sizeStr.split(',').forEach((part: string) => {
        const trimmed = part.trim();
        const match = trimmed.match(/^(\S+)\s*[×x]\s*(\d+)$/i);
        if (match) {
          sizes[match[1]] = (sizes[match[1]] || 0) + parseInt(match[2], 10);
        } else if (trimmed) {
          sizes[trimmed] = (sizes[trimmed] || 0) + 1;
        }
      });
    });
    const sizeList = Object.entries(sizes).sort((a, b) => b[1] - a[1]).map(([s, q]) => `<span class="os-size">${esc(s)} <strong>×${q}</strong></span>`).join('');

    summary.innerHTML = `
      <div class="os-stats">
        <div class="os-stat"><div class="os-num">${totalOrders}</div><div class="os-label">Orders</div></div>
        <div class="os-stat"><div class="os-num">${totalQty}</div><div class="os-label">Jerseys</div></div>
        <div class="os-stat"><div class="os-num" style="color:var(--neon)">RM ${totalRevenue}</div><div class="os-label">Revenue</div></div>
      </div>
      <div class="os-status-row">
        <span class="os-badge" style="color:#ff9500;background:rgba(255,149,0,0.1);border-color:rgba(255,149,0,0.2)">Pending: ${pending}</span>
        <span class="os-badge" style="color:#00FF41;background:rgba(0,255,65,0.1);border-color:rgba(0,255,65,0.2)">Paid: ${paid}</span>
        <span class="os-badge" style="color:#00c4ff;background:rgba(0,196,255,0.1);border-color:rgba(0,196,255,0.2)">Collected: ${collected}</span>
        ${deleted ? `<span class="os-badge" style="color:#ff3b30;background:rgba(255,59,48,0.1);border-color:rgba(255,59,48,0.2)">Deleted: ${deleted}</span>` : ''}
      </div>
      <div class="os-sizes">
        <div class="os-sizes-label">SIZE BREAKDOWN</div>
        <div class="os-sizes-list">${sizeList}</div>
      </div>
    `;
  }

  function renderOrders() {
    const filter = (document.getElementById('orderFilter') as HTMLSelectElement).value;
    // "all" hides deleted orders; use "Deleted" filter to see them
    const filtered = filter === 'all'
      ? allOrders.filter((o: any) => o['Payment Status'] !== 'Deleted')
      : allOrders.filter((o: any) => o['Payment Status'] === filter);
    const wrap = document.getElementById('ordersList')!;

    renderOrderSummary();

    if (!filtered.length) {
      wrap.innerHTML = '<p class="empty-msg">No orders found.</p>';
      return;
    }

    const statusColors: Record<string, string> = { Paid: '#00FF41', Pending: '#ff9500', Collected: '#00c4ff', Deleted: '#ff3b30' };

    wrap.innerHTML = filtered.map((o: any) => {
      const status = o['Payment Status'] || 'Pending';
      const isDeleted = status === 'Deleted';
      const color = statusColors[status] || '#666';
      const name = esc(o['Player Name']);
      const phone = String(o.Phone || '').replace("'", '').trim();
      const ref = esc(o['Ref Code'] || '');
      const delivery = o.Delivery || '';
      const address = o.Address || '';

      return `<div class="player-card-admin" style="${isDeleted ? 'opacity:0.45;' : ''}">
        <div class="pca-top">
          <div class="pca-avatar" style="background:${color}18;color:${color};border-color:${color}40">👕</div>
          <div class="pca-info">
            <span class="pca-name">${name}${isDeleted ? ' <span style="font-size:0.62rem;color:#ff3b30;">(DELETED)</span>' : ''}</span>
            <span class="pca-phone">${esc(phone)}</span>
            ${ref ? `<span class="pca-ref">${ref}</span>` : ''}
          </div>
          <div style="text-align:right">
            <span style="font-size:0.72rem;color:var(--text-muted)">${esc(o.Size)} (${esc(o.Quantity)} pcs)</span>
            <span style="display:block;font-size:0.82rem;font-weight:700;color:var(--neon);font-family:'Space Grotesk',sans-serif">RM ${esc(o.Total)}</span>
          </div>
        </div>
        ${delivery ? `<div style="font-size:0.68rem;color:var(--text-muted);padding:0 0.4rem;margin-top:0.3rem;">📦 ${esc(delivery)}${address ? ' — ' + esc(address) : ''}</div>` : ''}
        <div class="pca-controls">
          <div class="pca-field" style="flex:1;">
            <label>Status</label>
            <select class="form-select o-status" data-ref="${ref}">
              <option value="Pending" ${status === 'Pending' ? 'selected' : ''}>Pending</option>
              <option value="Paid" ${status === 'Paid' ? 'selected' : ''}>Paid</option>
              <option value="Collected" ${status === 'Collected' ? 'selected' : ''}>Collected</option>
              <option value="Deleted" ${status === 'Deleted' ? 'selected' : ''}>Deleted</option>
            </select>
          </div>
          <button type="button" class="pca-save o-save" data-ref="${ref}">SAVE</button>
          ${!isDeleted
            ? `<button type="button" class="pca-save pca-save--danger o-delete" data-ref="${ref}">DELETE</button>`
            : `<button type="button" class="pca-save pca-save--info o-restore" data-ref="${ref}">RESTORE</button>`}
        </div>
      </div>`;
    }).join('');

    // Save order status. Orders use soft-delete (Payment Status = Deleted),
    // so deletes is always empty — server preserves concurrent orders.
    async function saveOrders(feedbackMsg: string) {
      try {
        const res = await fetch(`${API}/admin/orders`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ orders: allOrders, deletes: [] }),
        });
        if (!res.ok) throw new Error('save failed');
        const data = await res.json().catch(() => ({}));
        if (Array.isArray(data.orders)) allOrders = data.orders;
        showToast(feedbackMsg);
        renderOrders();
      } catch {
        showToast('Failed to save order', 'error');
      }
    }

    // Save button handlers
    wrap.querySelectorAll('.o-save').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        const card = btn.closest('.player-card-admin')!;
        const sel = card.querySelector('.o-status') as HTMLSelectElement;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = sel.value;
          (btn as HTMLButtonElement).textContent = '…';
          (btn as HTMLButtonElement).disabled = true;
          await saveOrders(`Order ${ref} saved`);
          (btn as HTMLButtonElement).textContent = 'SAVE';
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    });

    // Delete button handlers
    wrap.querySelectorAll('.o-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        if (!confirm('Delete this order? You can restore it later from the Deleted filter.')) return;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = 'Deleted';
          await saveOrders('Order deleted');
        }
      });
    });

    // Restore button handlers
    wrap.querySelectorAll('.o-restore').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ref = (btn as HTMLButtonElement).dataset.ref;
        const order = allOrders.find((o: any) => o['Ref Code'] === ref);
        if (order) {
          order['Payment Status'] = 'Pending';
          await saveOrders('Order restored');
        }
      });
    });
  }

  document.getElementById('refreshOrdersBtn')!.addEventListener('click', () => loadOrders());
  document.getElementById('orderFilter')!.addEventListener('change', () => renderOrders());

  // --- LOGIN ---
  // Pre-fill username from localStorage so returning admins only need to
  // type their password. Username is stored unencrypted on purpose; it's
  // not a secret.
  (function prefillUsername() {
    const last = localStorage.getItem('kb_admin_username') || '';
    if (last) (document.getElementById('adminUser') as HTMLInputElement).value = last;
  })();

  function showLoggedInAs(name: string) {
    const wrap = document.getElementById('loggedInAs') as HTMLElement | null;
    const nameEl = document.getElementById('loggedInAsName') as HTMLElement | null;
    if (wrap) wrap.style.display = '';
    if (nameEl) nameEl.textContent = name;
  }

  function hideLoggedInAs() {
    const wrap = document.getElementById('loggedInAs') as HTMLElement | null;
    if (wrap) wrap.style.display = 'none';
  }

  document.getElementById('loginForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('adminUser') as HTMLInputElement).value.trim().toLowerCase();
    const pass = (document.getElementById('adminPass') as HTMLInputElement).value;
    const errEl = document.getElementById('loginError')!;
    if (!username || !pass) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Please enter both username and password.</div>';
      return;
    }
    try {
      const res = await fetch(`${API}/admin/auth`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password: pass }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.success) {
        adminToken = data.token;
        adminSession = {
          username,
          displayName: data.displayName || username,
          isOwner: !!data.isOwner,
          isSuperadmin: !!data.isSuperadmin,
        };
        localStorage.setItem('kb_admin_username', username);
        document.getElementById('loginGate')!.style.display = 'none';
        document.getElementById('adminContent')!.style.display = '';
        document.getElementById('notifyBell')!.style.display = '';
        showLoggedInAs(adminSession.isOwner ? `${adminSession.displayName} (owner)` : adminSession.displayName);
        // Schedule must finish first: loadAllPlayers() cross-references sessionsData
        // to classify dates as Upcoming vs Past. Running them in parallel races,
        // and when players resolves first every game falls into "Past Games".
        await loadSchedule();
        loadAllPlayers(); loadRevenue(); loadNotifs(); loadStats(); loadOrders();
        // Calendar + Admins lazy-load when those tabs are first opened
      } else {
        errEl.style.display = '';
        errEl.innerHTML = `<div class="alert alert--error">${(data && data.error) || 'Invalid username or password.'}</div>`;
      }
    } catch {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Connection error.</div>';
    }
  });

  // Logout — clears the in-memory token and reloads to the login screen.
  // Username stays in localStorage as a convenience for the next sign-in.
  document.getElementById('logoutBtn')!.addEventListener('click', () => {
    adminToken = '';
    adminSession = null;
    hideLoggedInAs();
    document.getElementById('notifyBell')!.style.display = 'none';
    document.getElementById('adminContent')!.style.display = 'none';
    document.getElementById('loginGate')!.style.display = '';
    (document.getElementById('adminPass') as HTMLInputElement).value = '';
  });

  // --- TABS ---
  // Track which lazy-loaded tabs have already fetched so we don't refetch
  // every time the admin clicks back to them — let an explicit Refresh
  // button (or save/cancel actions) trigger reloads.
  const tabsLoaded = { calendar: false, admins: false, blocked: false };
  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      const which = (tab as HTMLElement).dataset.tab || '';
      const panel = document.getElementById(`tab-${which}`);
      if (panel) panel.classList.add('active');
      if (which === 'calendar' && !tabsLoaded.calendar) { tabsLoaded.calendar = true; loadCalendar(); }
      if (which === 'admins' && !tabsLoaded.admins) { tabsLoaded.admins = true; loadAdmins(); }
      if (which === 'blocked' && !tabsLoaded.blocked) { tabsLoaded.blocked = true; loadBlocked(); }
    });
  });

  // --- BLOCK LIST ---
  async function loadBlocked() {
    const phonesEl = document.getElementById('blockedPhonesList')!;
    const ipsEl = document.getElementById('blockedIpsList')!;
    phonesEl.innerHTML = '<p class="empty-msg">Loading…</p>';
    ipsEl.innerHTML = '<p class="empty-msg">Loading…</p>';
    try {
      const res = await fetch(`${API}/admin/blocklist`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      const phones = data.phones || [];
      const ips = data.ips || [];

      const renderRow = (kind: string, value: string, reason: string, when: string, by: string) =>
        `<div class="block-row">
          <div class="block-row-main">
            <div class="block-row-value">${esc(value)}</div>
            ${reason ? `<div class="block-row-reason">${esc(reason)}</div>` : ''}
            <div class="block-row-meta">${esc(when)} · by ${esc(by)}</div>
          </div>
          <button type="button" class="pca-save pca-save--danger block-remove" data-kind="${kind}" data-value="${esc(value)}">Remove</button>
        </div>`;

      phonesEl.innerHTML = phones.length
        ? phones.map((r: any) => renderRow('phone', String(r.Phone || ''), String(r.Reason || ''), String(r['Blocked At'] || ''), String(r['Blocked By'] || ''))).join('')
        : '<p class="empty-msg">No phones blocked.</p>';
      ipsEl.innerHTML = ips.length
        ? ips.map((r: any) => renderRow('ip', String(r.IP || ''), String(r.Reason || ''), String(r['Blocked At'] || ''), String(r['Blocked By'] || ''))).join('')
        : '<p class="empty-msg">No IPs blocked.</p>';
    } catch {
      phonesEl.innerHTML = '<p class="empty-msg">Failed to load.</p>';
      ipsEl.innerHTML = '';
    }
  }

  document.getElementById('refreshBlockedBtn')!.addEventListener('click', () => loadBlocked());

  async function addBlockEntry(kind: 'phone' | 'ip') {
    const label = kind === 'phone'
      ? 'phone (E.164, e.g. +60123456789)'
      : 'IP or CIDR (IPv6 will auto-expand to /64 household block)';
    const value = prompt(`Enter ${label} to block:`);
    if (!value) return;
    const reason = prompt('Reason (optional):') || '';
    try {
      const res = await fetch(`${API}/admin/blocklist`, {
        method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ kind, value: value.trim(), reason }),
      });
      const data = await res.json();
      if (!res.ok) { alert(data.error || 'Add failed'); return; }
      if (data.alreadyBlocked) alert('Already blocked.');
      await loadBlocked();
    } catch { alert('Add failed.'); }
  }

  document.getElementById('addBlockedPhoneBtn')!.addEventListener('click', () => addBlockEntry('phone'));
  document.getElementById('addBlockedIpBtn')!.addEventListener('click', () => addBlockEntry('ip'));

  document.getElementById('tab-blocked')!.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.block-remove') as HTMLButtonElement | null;
    if (!btn) return;
    const kind = btn.dataset.kind || '';
    const value = btn.dataset.value || '';
    if (!kind || !value) return;
    if (!confirm(`Remove this ${kind} from the blocklist?`)) return;
    btn.disabled = true;
    try {
      const res = await fetch(`${API}/admin/blocklist?kind=${encodeURIComponent(kind)}&value=${encodeURIComponent(value)}`, {
        method: 'DELETE', headers: { Authorization: adminToken },
      });
      if (!res.ok) throw new Error('delete failed');
      await loadBlocked();
    } catch {
      btn.disabled = false;
      alert('Remove failed.');
    }
  });

  // --- SCHEDULE (Card Layout) ---
  async function loadSchedule() {
    try {
      const res = await fetch(`${API}/admin/sessions`, { headers: { Authorization: adminToken } });
      sessionsData = (await res.json()).sessions || [];
      renderSchedule();
    } catch {}
  }

  // Default 3-team labels/colours, and a parser for the Sessions `Teams`
  // JSON column. Falls back to defaults for missing/invalid data so the
  // builder always has 3 sensible teams.
  const KB_DEFAULT_TEAMS = [
    { label: 'Team A', color: '#00FF41' },
    { label: 'Team B', color: '#00c4ff' },
    { label: 'Team C', color: '#ff9500' },
  ];
  function parseTeams(raw: any) {
    if (raw) {
      try {
        const p = typeof raw === 'string' ? JSON.parse(raw) : raw;
        if (Array.isArray(p) && p.length === 3) {
          return p.map((t: any, i: number) => ({
            label: (t && String(t.label || '').trim()) || KB_DEFAULT_TEAMS[i].label,
            color: (t && String(t.color || '').trim()) || KB_DEFAULT_TEAMS[i].color,
          }));
        }
      } catch {}
    }
    return KB_DEFAULT_TEAMS.map((t) => ({ ...t }));
  }

  function renderSchedule() {
    const wrap = document.getElementById('scheduleList')!;
    if (!sessionsData.length) { wrap.innerHTML = '<p class="empty-msg">No games yet. Tap "+ ADD" to create one.</p>'; return; }

    // Sort: Open first, then by date descending. Keep original indices for editing.
    const indexed = sessionsData.map((s: any, i: number) => ({ s, i }));
    indexed.sort((a: any, b: any) => {
      if (a.s.Status === 'Open' && b.s.Status !== 'Open') return -1;
      if (a.s.Status !== 'Open' && b.s.Status === 'Open') return 1;
      return (b.s.Date || '').localeCompare(a.s.Date || '');
    });

    wrap.innerHTML = indexed.map(({ s, i }: any) => {
      const isOpen = s.Status === 'Open';
      return `<div class="admin-card ${isOpen ? '' : 'admin-card--closed'}">
        <div class="ac-header">
          <span class="ac-badge ${isOpen ? 'ac-badge--open' : 'ac-badge--closed'}">${s.Status || 'Open'}</span>
          <div class="ac-actions">
            <button class="ac-btn ac-btn--dup" data-idx="${i}" title="Duplicate">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <button class="ac-btn ac-btn--del" data-idx="${i}" title="Delete">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
        <div class="ac-fields">
          <div class="ac-field">
            <label>Name</label>
            <input class="form-input s-input" data-field="Session Name" data-idx="${i}" value="${s['Session Name'] || ''}" placeholder="e.g. Minifootball" />
          </div>
          <div class="ac-row2">
            <div class="ac-field">
              <label>Date ${s.Date ? `<span class="ac-day">${new Date(s.Date).toLocaleDateString('en-MY', { weekday: 'long' })}</span>` : ''}</label>
              <input class="form-input s-input" type="date" data-field="Date" data-idx="${i}" value="${s.Date || ''}" />
            </div>
            <div class="ac-field">
              <label>Time</label>
              <input class="form-input s-input" data-field="Time" data-idx="${i}" value="${s.Time || ''}" placeholder="e.g. 5pm-7pm" />
            </div>
          </div>
          <div class="ac-field">
            <label>Location</label>
            <input class="form-input s-input" data-field="Location" data-idx="${i}" value="${s.Location || ''}" placeholder="e.g. FootballHub" />
          </div>
          <div class="ac-row3">
            <div class="ac-field">
              <label>Fee (RM)</label>
              <input class="form-input s-input" type="number" data-field="Fee" data-idx="${i}" value="${s.Fee || ''}" />
            </div>
            <div class="ac-field">
              <label>Max Players</label>
              <input class="form-input s-input" type="number" data-field="Max Players" data-idx="${i}" value="${s['Max Players'] || 15}" />
            </div>
            <div class="ac-field">
              <label>Status</label>
              <select class="form-select s-input" data-field="Status" data-idx="${i}">
                <option value="Open" ${s.Status === 'Open' ? 'selected' : ''}>Open</option>
                <option value="Closed" ${s.Status === 'Closed' ? 'selected' : ''}>Closed</option>
              </select>
            </div>
          </div>
          <div class="ac-field">
            <label>Car Plate</label>
            <select class="form-select s-carplate s-input" data-field="Require Car Plate" data-idx="${i}">
              <option value="No" ${s['Require Car Plate'] === 'Yes' ? '' : 'selected'}>Not Required</option>
              <option value="Yes" ${s['Require Car Plate'] === 'Yes' ? 'selected' : ''}>Required</option>
            </select>
          </div>
          <div class="ac-field">
            <label>Format</label>
            <select class="form-select s-input" data-field="Format" data-idx="${i}">
              <option value="" ${s.Format === '3-team-11' ? '' : 'selected'}>Normal session</option>
              <option value="3-team-11" ${s.Format === '3-team-11' ? 'selected' : ''}>11-a-side · 3 teams (position builder)</option>
            </select>
          </div>
          ${s.Format === '3-team-11' ? `<div class="ac-teams" data-idx="${i}">
            <label>Teams — jersey colour &amp; name</label>
            ${parseTeams(s.Teams).map((t: any, ti: number) => `<div class="ac-team-row">
              <input type="color" class="s-teamcfg" data-idx="${i}" data-team="${ti}" data-tf="color" value="${esc(t.color)}" title="Team ${ti + 1} jersey colour" />
              <input type="text" class="form-input s-teamcfg" data-idx="${i}" data-team="${ti}" data-tf="label" value="${esc(t.label)}" placeholder="e.g. Reds" maxlength="24" />
            </div>`).join('')}
          </div>` : ''}
        </div>
      </div>`;
    }).join('');

    wrap.querySelectorAll('.s-input').forEach(el => {
      el.addEventListener('change', (e) => {
        const t = e.target as HTMLInputElement;
        sessionsData[parseInt(t.dataset.idx!)][t.dataset.field!] = t.value;
      });
    });
    // Format change re-renders the card so the Teams config appears/hides
    // immediately, and bumps Max Players to 33 for a fresh team game.
    wrap.querySelectorAll('.s-input[data-field="Format"]').forEach(el => {
      el.addEventListener('change', (e) => {
        const idx = parseInt((e.target as HTMLSelectElement).dataset.idx!);
        if ((e.target as HTMLSelectElement).value === '3-team-11') sessionsData[idx]['Max Players'] = 33;
        renderSchedule();
      });
    });
    // Team config inputs — any change re-serialises all 3 rows for that
    // session into the Teams JSON column.
    wrap.querySelectorAll('.s-teamcfg').forEach(el => {
      el.addEventListener('change', (e) => {
        const idx = parseInt((e.target as HTMLElement).dataset.idx!);
        const cfg = [0, 1, 2].map((ti) => {
          const colorEl = wrap.querySelector(`.s-teamcfg[data-idx="${idx}"][data-team="${ti}"][data-tf="color"]`) as HTMLInputElement | null;
          const labelEl = wrap.querySelector(`.s-teamcfg[data-idx="${idx}"][data-team="${ti}"][data-tf="label"]`) as HTMLInputElement | null;
          return {
            label: (labelEl?.value || '').trim() || `Team ${String.fromCharCode(65 + ti)}`,
            color: colorEl?.value || KB_DEFAULT_TEAMS[ti].color,
          };
        });
        sessionsData[idx].Teams = JSON.stringify(cfg);
      });
    });
    wrap.querySelectorAll('.ac-btn--dup').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).closest('[data-idx]')!.getAttribute('data-idx') || (btn as HTMLElement).dataset.idx!);
        sessionsData.push({ ...sessionsData[idx], Date: '', Status: 'Open' });
        renderSchedule();
      });
    });
    wrap.querySelectorAll('.ac-btn--del').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!confirm('Delete this game?')) return;
        sessionsData.splice(parseInt((btn as HTMLElement).dataset.idx!), 1);
        renderSchedule();
      });
    });
  }

  document.getElementById('autoCloseBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('autoCloseBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'CLOSING...';
    try {
      const res = await fetch(`${API}/cron-autoclose`, { method: 'POST', headers: { Authorization: adminToken } });
      const data = await res.json();
      if (data.success && data.closed > 0) {
        btn.textContent = `CLOSED ${data.closed}`;
        loadSchedule();
      } else {
        btn.textContent = 'NO CHANGES';
      }
      setTimeout(() => { btn.textContent = 'AUTO-CLOSE'; btn.disabled = false; }, 2000);
    } catch { btn.textContent = 'ERROR'; setTimeout(() => { btn.textContent = 'AUTO-CLOSE'; btn.disabled = false; }, 2000); }
  });

  document.getElementById('addSessionBtn')!.addEventListener('click', () => {
    sessionsData.push({ 'Session Name': '', Date: '', Time: '', Location: '', Fee: 10, Status: 'Open', 'Max Players': 15, 'Require Car Plate': 'No', Format: '', Teams: '' });
    renderSchedule();
  });

  document.getElementById('saveScheduleBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('saveScheduleBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'SAVING...';
    try {
      const res = await fetch(`${API}/admin/sessions`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken }, body: JSON.stringify({ sessions: sessionsData }) });
      if (!res.ok) throw new Error('save failed');
      btn.textContent = 'SAVED!';
      showToast('Schedule saved');
      setTimeout(() => { btn.textContent = 'SAVE SCHEDULE'; btn.disabled = false; }, 2000);
    } catch {
      btn.textContent = 'ERROR';
      btn.disabled = false;
      showToast('Failed to save schedule', 'error');
    }
  });

  // --- PLAYERS (Card Layout) ---
  async function loadAllPlayers() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      allPlayers = (await res.json()).players || [];

      // Union of session dates and registration dates. Using only registration
      // dates would hide freshly-scheduled games that nobody has signed up for
      // yet, making them impossible to open from this tab.
      const playerDates = allPlayers.map((p: any) => p['Session Date']).filter(Boolean);
      const sessionDates = sessionsData.map((s: any) => s.Date).filter(Boolean);
      const dates = [...new Set<string>([...playerDates, ...sessionDates])];

      // Split into open and closed sessions. Dates with registrations but no
      // matching session (orphan data) also fall into "Past Games".
      const openDates = dates.filter(d => sessionsData.some((s: any) => s.Date === d && s.Status === 'Open'));
      const closedDates = dates.filter(d => !openDates.includes(d));

      // Open games sort ascending so the nearest upcoming game is first
      // (and becomes the default selection). Past games stay descending so
      // the most recent one is first.
      openDates.sort((a, b) => a.localeCompare(b));
      closedDates.sort((a, b) => b.localeCompare(a));

      // Build the dropdown label. Append the Session Name (e.g. "Futsal",
      // "7-a-side") so the admin can tell sessions apart at a glance when
      // two dates are close together or when picking from the Past list.
      const labelFor = (d: string) => {
        const s = sessionsData.find((x: any) => x.Date === d);
        const name = s && s['Session Name'] ? String(s['Session Name']).trim() : '';
        return name ? `${d} · ${name}` : d;
      };

      const sel = document.getElementById('filterDate') as HTMLSelectElement;
      let html = '';
      if (openDates.length) {
        html += `<optgroup label="Upcoming">`;
        html += openDates.map(d => `<option value="${d}">${labelFor(d)}</option>`).join('');
        html += `</optgroup>`;
      }
      if (closedDates.length) {
        html += `<optgroup label="Past Games">`;
        html += closedDates.map(d => `<option value="${d}">${labelFor(d)}</option>`).join('');
        html += `</optgroup>`;
      }
      sel.innerHTML = html;

      // Default to first open game, or first closed if none open
      const defaultDate = openDates[0] || closedDates[0];
      if (defaultDate) { sel.value = defaultDate as string; renderPlayers(defaultDate as string); }
    } catch {}
  }

  document.getElementById('refreshPlayersBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('refreshPlayersBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = '...';
    await loadAllPlayers();
    btn.textContent = 'Refresh'; btn.disabled = false;
  });

  document.getElementById('filterDate')!.addEventListener('change', () => {
    renderPlayers((document.getElementById('filterDate') as HTMLSelectElement).value);
    // If the Add Player form is open, re-evaluate whether to show the optional
    // plate field for the newly selected session.
    if (addPlayerBox.style.display !== 'none') syncApPlateRow();
  });

  function renderPlayersSummary(date: string, players: any[]) {
    const summary = document.getElementById('playersSummary')!;
    if (!date) { summary.style.display = 'none'; summary.innerHTML = ''; return; }

    const session = sessionsData.find((s: any) => s.Date === date);
    const max = parseInt(session && session['Max Players']) || 0;

    const counts: Record<string, number> = { Paid: 0, Pending: 0, Overdue: 0, Waitlist: 0, Rejected: 0 };
    let revenue = 0;
    players.forEach((p: any) => {
      const st = p['Payment Status'] || 'Pending';
      if (counts[st] !== undefined) counts[st]++;
      if (st === 'Paid') revenue += parseFloat(p.Amount) || 0;
    });
    const active = counts.Paid + counts.Pending + counts.Overdue;
    const slotsLeft = max ? Math.max(0, max - active) : 0;
    const slotsLabel = max ? `${active} / ${max}` : String(active);

    const badge = (label: string, n: number, color: string) => n
      ? `<span class="os-badge" style="color:${color};background:${color}1a;border-color:${color}33">${label}: ${n}</span>`
      : '';

    // Status badges below — Paid is already in the stats row above so we
    // skip it here to avoid duplication.
    const badges = [
      badge('Pending', counts.Pending, '#ff9500'),
      badge('Overdue', counts.Overdue, '#ff5722'),
      badge('Waitlist', counts.Waitlist, '#00c4ff'),
      badge('Rejected', counts.Rejected, '#ff3b30'),
      max && slotsLeft > 0 ? `<span class="os-badge" style="color:var(--text-muted);background:rgba(255,255,255,0.04);border-color:var(--border)">${slotsLeft} slot${slotsLeft !== 1 ? 's' : ''} left</span>` : '',
      max && slotsLeft === 0 && active > 0 ? `<span class="os-badge" style="color:#ff3b30;background:rgba(255,59,48,0.1);border-color:rgba(255,59,48,0.2)">FULL</span>` : '',
    ].filter(Boolean).join('');

    summary.style.display = '';
    summary.innerHTML = `
      <div class="os-stats">
        <div class="os-stat"><div class="os-num">${slotsLabel}</div><div class="os-label">Slots Filled</div></div>
        <div class="os-stat"><div class="os-num" style="color:#00FF41">${counts.Paid}</div><div class="os-label">Paid</div></div>
        <div class="os-stat"><div class="os-num" style="color:var(--neon)">RM ${revenue}</div><div class="os-label">Collected</div></div>
      </div>
      ${badges ? `<div class="os-status-row players-badges">${badges}</div>` : ''}
    `;
  }

  function renderPlayers(date: string) {
    const wrap = document.getElementById('playersList')!;
    const filtered = allPlayers
      .filter((p: any) => p['Session Date'] === date)
      .sort((a: any, b: any) => {
        // Latest registered first
        const tA = a.Timestamp || '';
        const tB = b.Timestamp || '';
        return tB.localeCompare(tA);
      });
    renderPlayersSummary(date, filtered);
    if (!filtered.length) {
      wrap.innerHTML = '<p class="empty-msg">No players for this game.</p>';
      document.getElementById('carPlateSection')!.style.display = 'none';
      document.getElementById('shareWaSection')!.style.display = 'none';
      return;
    }

    const statusColors: Record<string, string> = { Paid: '#00FF41', Pending: '#ff9500', Overdue: '#ff5722', Waitlist: '#00c4ff', Rejected: '#ff3b30' };

    // 3-team game? If so, each card gets Team + Position shuffle dropdowns.
    const sessionForDate = sessionsData.find((s: any) => s.Date === date);
    const isTeamGameDate = !!sessionForDate && String(sessionForDate.Format || '').trim() === '3-team-11';
    const formationSlots = (window as any).KB_FORMATION || [];
    // Admin-defined team labels/colours for this session (falls back to
    // Team A/B/C green/blue/orange). Team key A/B/C maps to index 0/1/2.
    const teamsCfg = parseTeams(sessionForDate && sessionForDate.Teams);

    wrap.innerHTML = filtered.map((p: any, i: number) => {
      const phone = String(p.Phone || '').replace("'", '').trim();
      const ref = p['Ref Code'] || '';
      const refund = p['Refund'] || '';
      const status = p['Payment Status'] || 'Pending';
      const isOverdue = status === 'Overdue';
      const color = statusColors[status] || '#666';
      const playerName = esc(p['Player Name']);
      const initial = (p['Player Name'] || '?')[0].toUpperCase();
      const waMsg = encodeURIComponent(`Hi ${p['Player Name']}, this is regarding your registration (Ref: ${ref}) for the game on ${date}. `);
      const waNum = (window as any).KB_PHONE?.toWaNumber(phone) || '';
      const waLink = waNum ? `https://wa.me/${waNum}?text=${waMsg}` : '#';

      // Tracing metadata captured at registration time. Older rows
      // (pre-blocklist deploy) will have these empty — the expander just
      // shows what's there.
      const ip = String(p.IP || '').trim();
      const country = String(p.Country || '').trim();
      const ua = String(p['User Agent'] || '').trim();
      const hasTraceData = !!(ip || country || ua);

      // 3-team game: show which team + position this player booked,
      // using the session's configured team label + colour.
      const pTeam = String(p.Team || '').trim().toUpperCase();
      const pPosition = String(p.Position || '').trim().toUpperCase();
      const pTeamIdx = 'ABC'.indexOf(pTeam);
      const pTeamCfg = pTeamIdx >= 0 ? teamsCfg[pTeamIdx] : null;
      const pTeamColor = pTeamCfg ? pTeamCfg.color : '#888';
      const pTeamLabel = pTeamCfg ? pTeamCfg.label : pTeam;
      const teamPosBadge = (pTeam && pPosition)
        ? `<span class="pca-teampos" style="color:${pTeamColor};border-color:${pTeamColor}55;background:${pTeamColor}14">${esc(pTeamLabel)} · ${esc(pPosition)}</span>`
        : '';

      // Shuffle controls — only for 3-team sessions. A blank "—" option
      // sits first so a player with no team/position set doesn't get one
      // auto-assigned on save. Team/Position are PROTECTED server-side, so
      // an untouched blank reverts to existing rather than wiping.
      const shuffleRow = isTeamGameDate ? `<div class="pca-shuffle">
        <div class="pca-field">
          <label>Team</label>
          <select class="form-select p-team" data-name="${playerName}">
            <option value="" ${!pTeam ? 'selected' : ''}>—</option>
            ${['A', 'B', 'C'].map((t, ti) => `<option value="${t}" ${pTeam === t ? 'selected' : ''}>${esc(teamsCfg[ti].label)}</option>`).join('')}
          </select>
        </div>
        <div class="pca-field">
          <label>Position</label>
          <select class="form-select p-position" data-name="${playerName}">
            <option value="" ${!pPosition ? 'selected' : ''}>—</option>
            ${formationSlots.map((s: any) => `<option value="${esc(s.id)}" ${pPosition === String(s.id).toUpperCase() ? 'selected' : ''}>${esc(s.id)} — ${esc(s.full)}</option>`).join('')}
          </select>
        </div>
      </div>` : '';

      return `<div class="player-card-admin ${isOverdue ? 'player-card--overdue' : ''}">
        <div class="pca-top">
          <div class="pca-avatar" style="background:${color}18;color:${color};border-color:${color}40">${esc(initial)}</div>
          <div class="pca-info">
            <span class="pca-name">${playerName} ${teamPosBadge}</span>
            <span class="pca-phone">${esc(phone)} ${country ? `<span class="pca-country">${esc(country)}</span>` : ''}</span>
            ${ref ? `<span class="pca-ref">${esc(ref)}</span>` : ''}
          </div>
          ${hasTraceData ? `<button type="button" class="pca-trace-toggle" data-ref="${esc(ref)}" title="Show registration details">🔍</button>` : ''}
        </div>
        ${hasTraceData ? `<div class="pca-trace" id="trace-${esc(ref)}" style="display:none">
          ${ip ? `<div><span class="trace-label">IP</span><span class="trace-val">${esc(ip)}</span></div>` : ''}
          ${country ? `<div><span class="trace-label">Country</span><span class="trace-val">${esc(country)}</span></div>` : ''}
          ${ua ? `<div><span class="trace-label">Device</span><span class="trace-val" title="${esc(ua)}">${esc(ua.slice(0, 80))}${ua.length > 80 ? '…' : ''}</span></div>` : ''}
          <button type="button" class="pca-block" data-phone="${esc(phone)}" data-ip="${esc(ip)}" data-name="${playerName}">🚫 BLOCK PHONE${ip ? ' + IP' : ''}</button>
        </div>` : ''}
        ${shuffleRow}
        <div class="pca-controls">
          <div class="pca-field">
            <label>Status</label>
            <select class="form-select p-status" data-name="${playerName}">
              <option value="Pending" ${status === 'Pending' ? 'selected' : ''}>Pending</option>
              <option value="Overdue" ${status === 'Overdue' ? 'selected' : ''}>Overdue</option>
              <option value="Paid" ${status === 'Paid' ? 'selected' : ''}>Paid</option>
              <option value="Waitlist" ${status === 'Waitlist' ? 'selected' : ''}>Waitlist</option>
              <option value="Rejected" ${status === 'Rejected' ? 'selected' : ''}>Rejected</option>
            </select>
          </div>
          <div class="pca-field">
            <label>Refund</label>
            <select class="form-select p-refund" data-name="${playerName}">
              <option value="" ${!refund ? 'selected' : ''}>—</option>
              <option value="Pending Refund" ${refund === 'Pending Refund' ? 'selected' : ''}>Pending</option>
              <option value="Refunded" ${refund === 'Refunded' ? 'selected' : ''}>Done</option>
            </select>
          </div>
          <button type="button" class="pca-save" data-name="${playerName}" title="Save this player">SAVE</button>
          <button type="button" class="pca-save pca-save--danger pca-delete" data-name="${playerName}" title="Delete this player">DELETE</button>
          <a href="${waLink}" target="_blank" class="pca-wa" title="WhatsApp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          </a>
        </div>
      </div>`;
    }).join('');

    // Car plates section
    const carPlateSection = document.getElementById('carPlateSection')!;
    const carPlateList = document.getElementById('carPlateList')!;
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresCarPlate = session && session['Require Car Plate'] === 'Yes';

    if (requiresCarPlate) {
      const activePlayers = filtered.filter((p: any) => ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status']));
      const platesData = activePlayers
        .filter((p: any) => p['Car Plate'])
        .map((p: any) => ({ plate: String(p['Car Plate']).trim(), name: p['Player Name'] }));

      carPlateSection.style.display = '';
      if (platesData.length) {
        carPlateList.innerHTML = platesData.map((d: any, i: number) =>
          `<div class="car-plate-item"><span class="car-plate-num">${i + 1}. ${esc(d.plate)}</span> <span class="car-plate-name">— ${esc(d.name)}</span></div>`
        ).join('');
      } else {
        carPlateList.innerHTML = '<p class="empty-msg">No car plates registered yet.</p>';
      }
    } else {
      carPlateSection.style.display = 'none';
    }

    // Share to WhatsApp section — always show when players exist
    document.getElementById('shareWaSection')!.style.display = '';
  }

  // --- SHARE TO WHATSAPP ---
  function getShareData() {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const session = sessionsData.find((s: any) => s.Date === date);
    if (!session) return null;
    const sessionName = session['Session Name'] || 'Game';
    const time = session.Time || '';
    const loc = session.Location || '';
    const fee = session.Fee || '';
    const max = parseInt(session['Max Players']) || 20;
    const active = allPlayers.filter((p: any) => p['Session Date'] === date && ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status'])).length;
    const slotsLeft = Math.max(0, max - active);
    const wazeLink = loc ? `https://waze.com/ul?q=${encodeURIComponent(loc)}` : '';
    return { sessionName, date, time, loc, fee, max, active, slotsLeft, wazeLink };
  }

  document.getElementById('shareWaOpen')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `⚽ GAME ON! 🟢\n\n🏟 ${d.sessionName}\n📅 ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}${d.loc ? `\n📍 ${d.loc}` : ''}\n💰 RM${d.fee}/pax\n👥 ${d.max} slots available${d.wazeLink ? `\n🗺️ ${d.wazeLink}` : ''}\n\nRegister now 👉 kronibola.com\n\nFirst come first serve. Jangan lepas! 🔥`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaFilling')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🔥 SLOTS FILLING UP!\n\n🏟 ${d.sessionName}\n📅 ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}${d.loc ? `\n📍 ${d.loc}` : ''}\n👥 Only *${d.slotsLeft} slot${d.slotsLeft !== 1 ? 's' : ''}* left!\n\nDon't miss out 👉 kronibola.com`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaLast')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🚨 LAST *${d.slotsLeft} SLOT${d.slotsLeft !== 1 ? 'S' : ''}*!\n\n🏟 ${d.sessionName} — ${d.date}${d.time ? `\n⏰ ${d.time}` : ''}\n\nSiapa cepat dia dapat 👉 kronibola.com`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  document.getElementById('shareWaFull')!.addEventListener('click', () => {
    const d = getShareData();
    if (!d) return;
    const msg = `🔴 GAME FULL!\n\n🏟 ${d.sessionName} — ${d.date}\n👥 ${d.max}/${d.max} players confirmed\n\nWaitlist still open 👉 kronibola.com\nNext game loading soon... ⏳`;
    window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
  });

  // --- COPY CAR PLATES ---
  document.getElementById('copyPlatesBtn')!.addEventListener('click', () => {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const filtered = allPlayers.filter((p: any) => p['Session Date'] === date && ['Paid', 'Pending', 'Overdue'].includes(p['Payment Status']));
    const plates = filtered.filter((p: any) => p['Car Plate']).map((p: any, i: number) => `${i + 1}. ${String(p['Car Plate']).trim()}`);
    if (!plates.length) { alert('No car plates to copy.'); return; }
    navigator.clipboard.writeText(plates.join('\n')).then(() => {
      const btn = document.getElementById('copyPlatesBtn') as HTMLButtonElement;
      const orig = btn.textContent;
      btn.textContent = `${plates.length} plates copied`;
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  });

  // --- ADD PLAYER MANUALLY ---
  const addPlayerBox = document.getElementById('addPlayerBox')!;

  // Toggle the optional Car Plate row based on the currently selected session.
  // Only shown for plate-required sessions so admin can capture the plate at
  // add time; still optional on submit (admin can skip if unknown — player
  // can fill it in later via the public Check-My-Status flow).
  function syncApPlateRow() {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresPlate = !!(session && session['Require Car Plate'] === 'Yes');
    const row = document.getElementById('apPlateRow') as HTMLElement | null;
    if (!row) return;
    row.style.display = requiresPlate ? '' : 'none';
    if (!requiresPlate) {
      const inp = document.getElementById('apPlate') as HTMLInputElement | null;
      if (inp) inp.value = '';
    }
  }

  document.getElementById('addPlayerBtn')!.addEventListener('click', () => {
    const willShow = addPlayerBox.style.display === 'none';
    addPlayerBox.style.display = willShow ? '' : 'none';
    if (willShow) syncApPlateRow();
  });

  document.getElementById('apConfirm')!.addEventListener('click', async () => {
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    if (!date) { alert('Select a game first.'); return; }

    const name = (document.getElementById('apName') as HTMLInputElement).value.trim().replace(/\s+/g, ' ').split(' ').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');
    const phone = (document.getElementById('apPhone') as HTMLInputElement).value.replace(/[-\s]/g, '');
    const status = (document.getElementById('apStatus') as HTMLSelectElement).value;
    const fee = (document.getElementById('apFee') as HTMLInputElement).value;

    if (!name || !phone) { alert('Fill in name and phone.'); return; }

    // Plate field is only shown for plate-required sessions; still optional
    // on submit (admin may not know the plate yet). Validate format when
    // provided; for no-plate sessions we ignore any value entirely.
    const session = sessionsData.find((s: any) => s.Date === date);
    const requiresPlate = !!(session && session['Require Car Plate'] === 'Yes');
    let plate = '';
    if (requiresPlate) {
      const plateInput = (document.getElementById('apPlate') as HTMLInputElement).value.replace(/\s/g, '').toUpperCase();
      if (plateInput) {
        if (plateInput.length < 2 || plateInput.length > 10) { alert('Car plate must be 2-10 characters'); return; }
        if (!/^[A-Z0-9]+$/.test(plateInput)) { alert('Car plate must contain only letters and numbers'); return; }
        if (!/[A-Z]/.test(plateInput) || !/[0-9]/.test(plateInput)) { alert('Car plate must contain at least 1 letter and 1 digit'); return; }
        plate = plateInput;
      }
    }

    const timestamp = new Date().toISOString().replace('T', ' ').slice(0, 19);
    const refCode = `KB-${date.slice(5, 7)}${date.slice(8, 10)}-${name[0].toUpperCase()}${Math.random().toString(36).substring(2, 5).toUpperCase()}`;

    const newPlayer = {
      'Session Date': date,
      'Player Name': name,
      Phone: "'" + phone,
      'Payment Status': status,
      Amount: fee,
      Timestamp: timestamp,
      'Ref Code': refCode,
      Refund: '',
      'Car Plate': plate,
    };

    allPlayers.push(newPlayer);
    renderPlayers(date);

    // Clear form
    (document.getElementById('apName') as HTMLInputElement).value = '';
    (document.getElementById('apPhone') as HTMLInputElement).value = '';
    (document.getElementById('apPlate') as HTMLInputElement).value = '';
    addPlayerBox.style.display = 'none';

    // Auto-save. Passing deletes: [] explicitly keeps the new
    // reconcile-based server happy and preserves any concurrent registrations.
    try {
      const res = await fetch(`${API}/admin/players`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ players: allPlayers, deletes: [] }),
      });
      if (res.ok) {
        const data = await res.json().catch(() => ({}));
        if (Array.isArray(data.players)) allPlayers = data.players;
      }
    } catch {}
  });

  document.getElementById('savePlayersBtn')!.addEventListener('click', async () => {
    const btn = document.getElementById('savePlayersBtn') as HTMLButtonElement;
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    btn.disabled = true; btn.textContent = 'SAVING...';

    const delNames = new Set<string>();

    const statusMap = new Map<string, string>();
    document.querySelectorAll('.p-status').forEach(sel => statusMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));

    const refundMap = new Map<string, string>();
    document.querySelectorAll('.p-refund').forEach(sel => refundMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));

    // Team/Position shuffle maps — only populated for 3-team sessions
    // (the .p-team / .p-position selects only render there).
    const teamMap = new Map<string, string>();
    document.querySelectorAll('.p-team').forEach(sel => teamMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));
    const positionMap = new Map<string, string>();
    document.querySelectorAll('.p-position').forEach(sel => positionMap.set((sel as HTMLSelectElement).dataset.name!, (sel as HTMLSelectElement).value));

    const changedPlayers: { name: string; phone: string; oldStatus: string; newStatus: string }[] = [];
    // Collect Ref Codes for the deletions so the server can action them
    // explicitly. Rows missing from the payload are preserved now.
    const deletes: string[] = [];

    const updated = allPlayers.map((p: any) => {
      if (p['Session Date'] === date) {
        if (delNames.has(p['Player Name'])) {
          if (p['Ref Code']) deletes.push(p['Ref Code']);
          return null;
        }
        if (statusMap.has(p['Player Name'])) {
          const ns = statusMap.get(p['Player Name'])!;
          if (ns !== p['Payment Status']) changedPlayers.push({ name: p['Player Name'], phone: String(p.Phone || '').replace("'", '').trim(), oldStatus: p['Payment Status'], newStatus: ns });
          p['Payment Status'] = ns;
        }
        if (refundMap.has(p['Player Name'])) p['Refund'] = refundMap.get(p['Player Name']);
        // Apply team/position shuffle. An empty value can't wipe an
        // existing slot — Team/Position are PROTECTED server-side.
        if (teamMap.has(p['Player Name'])) p['Team'] = teamMap.get(p['Player Name']);
        if (positionMap.has(p['Player Name'])) p['Position'] = positionMap.get(p['Player Name']);
      }
      return p;
    }).filter(Boolean);

    try {
      const res = await fetch(`${API}/admin/players`, { method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken }, body: JSON.stringify({ players: updated, deletes }) });
      if (!res.ok) throw new Error('save failed');
      const data = await res.json().catch(() => ({}));
      allPlayers = Array.isArray(data.players) ? data.players : (updated as any[]);
      renderPlayers(date);
      btn.textContent = 'SAVED!';
      showToast(delNames.size ? `Saved (${delNames.size} removed)` : 'Players saved');
      setTimeout(() => { btn.textContent = 'SAVE CHANGES'; btn.disabled = false; }, 3000);

      if (changedPlayers.length > 0) {
        const session = sessionsData.find((s: any) => s.Date === date);
        changedPlayers.forEach((cp) => {
          const msg = buildNotifyMessage(cp.name, cp.newStatus, date, session);
          enqueueNotify({ name: cp.name, phone: cp.phone, fromStatus: cp.oldStatus, toStatus: cp.newStatus, date, msg });
        });
      }
    } catch {
      btn.textContent = 'ERROR';
      btn.disabled = false;
      showToast('Failed to save players', 'error');
    }
  });

  // --- Per-player save & delete (event delegation on players list) ---
  document.getElementById('playersList')!.addEventListener('click', async (e) => {
    // Trace expander — toggles the IP/Country/UA detail panel under each card.
    const traceBtn = (e.target as HTMLElement).closest('.pca-trace-toggle') as HTMLButtonElement | null;
    if (traceBtn) {
      const ref = traceBtn.dataset.ref || '';
      const panel = document.getElementById(`trace-${ref}`);
      if (panel) panel.style.display = panel.style.display === 'none' ? '' : 'none';
      return;
    }
    // Block button — adds the player's phone (and IP if captured) to the
    // blocklist sheets, then optionally marks the registration Rejected.
    const blockBtn = (e.target as HTMLElement).closest('.pca-block') as HTMLButtonElement | null;
    if (blockBtn) {
      const blkPhone = blockBtn.dataset.phone || '';
      const blkIp = blockBtn.dataset.ip || '';
      const blkName = blockBtn.dataset.name || 'this player';
      const reason = prompt(`Block ${blkName}? Enter a reason (optional, shown only in admin):`, 'Fake receipt');
      if (reason === null) return; // user hit Cancel
      blockBtn.disabled = true;
      blockBtn.textContent = '...';
      try {
        const calls: Promise<Response>[] = [];
        if (blkPhone) calls.push(fetch(`${API}/admin/blocklist`, {
          method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ kind: 'phone', value: blkPhone, reason }),
        }));
        if (blkIp) calls.push(fetch(`${API}/admin/blocklist`, {
          method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ kind: 'ip', value: blkIp, reason }),
        }));
        await Promise.all(calls);
        blockBtn.textContent = '✓ BLOCKED';
        blockBtn.style.background = 'rgba(255,59,48,0.25)';
      } catch (err) {
        blockBtn.textContent = '🚫 BLOCK';
        blockBtn.disabled = false;
        alert('Block failed. Try again.');
      }
      return;
    }
    const deleteBtn = (e.target as HTMLElement).closest('.pca-delete') as HTMLButtonElement | null;
    const saveBtn = !deleteBtn ? (e.target as HTMLElement).closest('.pca-save') as HTMLButtonElement | null : null;
    const target = deleteBtn || saveBtn;
    if (!target) return;

    const playerName = target.dataset.name || '';
    const date = (document.getElementById('filterDate') as HTMLSelectElement).value;
    const card = target.closest('.player-card-admin') as HTMLElement | null;
    if (!card) return;

    const isDeleted = !!deleteBtn;
    if (isDeleted && !confirm(`Delete ${playerName}? This cannot be undone.`)) return;

    const statusSel = card.querySelector('.p-status') as HTMLSelectElement | null;
    const refundSel = card.querySelector('.p-refund') as HTMLSelectElement | null;

    const newStatus = statusSel ? statusSel.value : '';
    const newRefund = refundSel ? refundSel.value : '';

    // Snapshot previous status BEFORE mutating allPlayers so we can detect a change
    const existing = allPlayers.find((p: any) => p['Session Date'] === date && p['Player Name'] === playerName);
    const oldStatus = existing ? existing['Payment Status'] : '';
    const phone = existing ? String(existing.Phone || '').replace("'", '').trim() : '';

    // Apply the change locally
    const updated = allPlayers
      .map((p: any) => {
        if (p['Session Date'] !== date || p['Player Name'] !== playerName) return p;
        if (isDeleted) return null;
        p['Payment Status'] = newStatus;
        p['Refund'] = newRefund;
        return p;
      })
      .filter(Boolean);

    target.disabled = true;
    const originalLabel = target.textContent || (isDeleted ? 'DELETE' : 'SAVE');
    target.textContent = '…';

    // Deletion must be explicit now — a row missing from the payload is
    // preserved server-side (so a concurrent registration between page load
    // and save doesn't get wiped). List the Ref Code if we're deleting.
    const deletes: string[] = isDeleted && existing && existing['Ref Code'] ? [existing['Ref Code']] : [];

    try {
      const res = await fetch(`${API}/admin/players`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ players: updated, deletes }),
      });
      if (!res.ok) throw new Error('save failed');
      // Server returns the reconciled state — adopt it so any concurrent
      // registrations the admin didn't know about appear on the next render.
      const data = await res.json().catch(() => ({}));
      allPlayers = Array.isArray(data.players) ? data.players : (updated as any[]);
      renderPlayers(date);
      showToast(isDeleted ? `${playerName} removed` : `${playerName} saved`);

      // If status changed, queue a notification in the Notification Center.
      if (!isDeleted && newStatus && newStatus !== oldStatus) {
        const session = sessionsData.find((s: any) => s.Date === date);
        const msg = buildNotifyMessage(playerName, newStatus, date, session);
        enqueueNotify({ name: playerName, phone, fromStatus: oldStatus, toStatus: newStatus, date, msg });
      }
    } catch {
      target.disabled = false;
      target.textContent = originalLabel;
      showToast(`Failed to save ${playerName}`, 'error');
    }
  });

  // --- NOTIFICATIONS LOG ---
  async function loadNotifs() {
    try {
      const res = await fetch(`${API}/admin/notifications`, { headers: { Authorization: adminToken } });
      const data = await res.json();
      renderNotifs(data.logs || []);
    } catch { renderNotifs([]); }
  }

  function renderNotifs(logs: any[]) {
    const wrap = document.getElementById('notifsList')!;
    if (!logs.length) { wrap.innerHTML = '<p class="empty-msg">No notifications sent yet.</p>'; return; }

    const statusColors: Record<string, string> = { Paid: '#00FF41', Pending: '#ff9500', Overdue: '#ff5722', Waitlist: '#00c4ff', Rejected: '#ff3b30' };

    wrap.innerHTML = logs.map((log: any) => {
      const color = statusColors[log.Status] || '#666';
      const phone = String(log.Phone || '').replace("'", '').trim();
      const waNum = (window as any).KB_PHONE?.toWaNumber(phone) || '';
      const waLink = waNum ? `https://wa.me/${waNum}?text=${encodeURIComponent(log.Message || '')}` : '#';
      const timeAgo = getTimeAgo(log.Timestamp);

      return `<div class="notif-card">
        <div class="notif-top">
          <div class="notif-info">
            <span class="notif-name">${esc(log['Player Name'])}</span>
            <span class="notif-meta">${esc(log['Session Date'] || '')} · ${esc(timeAgo)}</span>
          </div>
          <span class="badge" style="background:${color}20;color:${color};font-size:0.58rem">${esc(log.Status || '—')}</span>
        </div>
        <p class="notif-msg">${esc((log.Message || '').slice(0, 200))}${(log.Message || '').length > 200 ? '...' : ''}</p>
        <div class="notif-actions">
          <span class="notif-sent-by">${esc(log['Sent By'] || 'Admin')}</span>
          <a href="${waLink}" target="_blank" class="notif-resend">Resend</a>
        </div>
      </div>`;
    }).join('');
  }

  function getTimeAgo(ts: string) {
    if (!ts) return '';
    const diff = Date.now() - new Date(ts.replace(' ', 'T') + 'Z').getTime();
    if (isNaN(diff)) return ts;
    const mins = Math.floor(diff / 60000);
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    return `${days}d ago`;
  }

  async function logNotification(playerName: string, phone: string, status: string, date: string, message: string) {
    try {
      await fetch(`${API}/admin/notifications`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ playerName, phone, status, date, message, sentBy: 'Admin' }),
      });
    } catch {}
  }

  document.getElementById('refreshNotifsBtn')!.addEventListener('click', loadNotifs);

  // --- REVENUE ---
  async function loadRevenue() {
    try {
      const res = await fetch(`${API}/admin/players`, { headers: { Authorization: adminToken } });
      const players = (await res.json()).players || [];
      renderRevenue(players);
    } catch {}
  }

  function renderRevenue(players: any[]) {
    const wrap = document.getElementById('revenueDashboard')!;
    const paid = players.filter((p: any) => p['Payment Status'] === 'Paid');
    const pending = players.filter((p: any) => ['Pending', 'Overdue'].includes(p['Payment Status']));
    const rejected = players.filter((p: any) => p['Payment Status'] === 'Rejected');
    const total = paid.reduce((s: number, p: any) => s + (parseFloat(p.Amount) || 0), 0);

    const sessionMap: Record<string, { paid: number; count: number }> = {};
    paid.forEach((p: any) => {
      const d = p['Session Date'] || '?';
      if (!sessionMap[d]) sessionMap[d] = { paid: 0, count: 0 };
      sessionMap[d].paid += parseFloat(p.Amount) || 0;
      sessionMap[d].count += 1;
    });
    const sessions = Object.entries(sessionMap).sort(([a], [b]) => b.localeCompare(a));
    const maxRev = Math.max(...sessions.map(([, v]) => v.paid), 1);

    wrap.innerHTML = `
      <div class="rev-grid">
        <div class="rev-stat rev-stat--big">
          <span class="rev-stat-label">Total Revenue</span>
          <span class="rev-stat-value neon-text">RM ${total.toFixed(0)}</span>
        </div>
        <div class="rev-stat"><span class="rev-stat-label">Paid</span><span class="rev-stat-value" style="color:var(--neon)">${paid.length}</span></div>
        <div class="rev-stat"><span class="rev-stat-label">Pending</span><span class="rev-stat-value" style="color:var(--orange)">${pending.length}</span></div>
        <div class="rev-stat"><span class="rev-stat-label">Rejected</span><span class="rev-stat-value" style="color:var(--red)">${rejected.length}</span></div>
      </div>
      ${sessions.length ? `
        <h4 class="rev-section-title">PER SESSION</h4>
        <div class="rev-bars">
          ${sessions.map(([date, v]) => `
            <div class="rev-bar-item">
              <div class="rev-bar-head"><span>${date}</span><span class="neon-text">RM ${v.paid.toFixed(0)} (${v.count})</span></div>
              <div class="rev-bar-track"><div class="rev-bar-fill" style="width:${(v.paid / maxRev) * 100}%"></div></div>
            </div>
          `).join('')}
        </div>
      ` : '<p class="empty-msg">No paid sessions yet.</p>'}
    `;
  }

  // ===========================================================================
  // CALENDAR TAB — month-grid view of games, holidays, admin leave
  // ===========================================================================
  let holidaysData: any[] = [];
  let leavesData: any[] = [];
  let calendarFilter: 'all' | 'games' | 'holidays' | 'school' | 'sports' | 'leave' = 'all';
  // A holiday row in the Holidays sheet whose Type contains "school" is
  // surfaced as the dedicated `school` event kind (purple) instead of the
  // generic `holiday` kind (amber). Lets us colour and filter them apart
  // without needing a separate sheet.
  function isSchoolHoliday(row: any): boolean {
    return /school/i.test(String(row && row.Type || ''));
  }
  // Same trick for sports events (pink). Matches "Sports", "Sports Event",
  // "Tournament" — anything where the admin wants to flag an external
  // sports happening on a particular day (e.g. FIFA, marathon, league
  // game elsewhere) so it stands out from generic public holidays.
  function isSportsEvent(row: any): boolean {
    return /sports?|tournament/i.test(String(row && row.Type || ''));
  }
  // Month being viewed (year + 0-indexed month) and the day selected for
  // the details panel below the grid. Always interpreted in Malaysia time.
  let calViewYear = 0;
  let calViewMonth = 0;
  let calSelectedDate = '';

  function ymdToday(): string {
    return new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Kuala_Lumpur' });
  }

  function calEsc(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  function ymdFromYMD(y: number, m: number, d: number): string {
    return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  }

  function parseYmd(ymd: string): { y: number; m: number; d: number } | null {
    const m = String(ymd).match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!m) return null;
    return { y: parseInt(m[1], 10), m: parseInt(m[2], 10) - 1, d: parseInt(m[3], 10) };
  }

  function daysInMonth(y: number, m: number): number {
    return new Date(y, m + 1, 0).getDate();
  }

  // Mon-first weekday index: 0=Mon, 6=Sun. JS Date.getDay() is Sun-first
  // (0=Sun..6=Sat) so shift it.
  function monFirstWeekday(y: number, m: number, d: number): number {
    const js = new Date(y, m, d).getDay();
    return (js + 6) % 7;
  }

  // Initialise to today's month on first open.
  function initCalendarView() {
    const today = ymdToday();
    const t = parseYmd(today);
    if (!t) return;
    calViewYear = t.y;
    calViewMonth = t.m;
    calSelectedDate = today;
  }

  async function loadCalendar() {
    if (!calViewYear) initCalendarView();
    // Permission split:
    //   - Superadmin: full Holidays CRUD ("+ HOLIDAY", "SYNC MY 2026").
    //   - Regular admin: limited to adding Sports events. Same button is
    //     re-labelled "+ SPORTS" and the modal hides the Type dropdown
    //     (Type is forced to "Sports" at submit).
    //   The SYNC MY 2026 button stays superadmin-only — it touches federal
    //   holidays + school breaks which regular admins shouldn't change.
    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    const hBtn = document.getElementById('addHolidayBtn') as HTMLElement | null;
    const sBtn = document.getElementById('syncMyHolidaysBtn') as HTMLElement | null;
    if (hBtn) {
      hBtn.style.display = '';
      hBtn.textContent = meIsSA ? '+ HOLIDAY' : '+ SPORTS';
    }
    if (sBtn) sBtn.style.display = meIsSA ? '' : 'none';
    // Fire-and-forget — populate the subscribe-feed URLs in parallel with
    // the main calendar load. Failure is non-blocking; the section just
    // stays empty.
    loadCalendarFeeds().catch(() => {});
    const grid = document.getElementById('calGrid');
    if (grid) grid.innerHTML = '<p class="empty-msg" style="grid-column:1/-1">Loading…</p>';
    try {
      const [hRes, lRes] = await Promise.all([
        fetch(`${API}/admin/holidays`, { headers: { Authorization: adminToken } }),
        fetch(`${API}/admin/leave`, { headers: { Authorization: adminToken } }),
      ]);
      const hData = await hRes.json().catch(() => ({}));
      const lData = await lRes.json().catch(() => ({}));
      holidaysData = Array.isArray(hData.holidays) ? hData.holidays : [];
      leavesData = Array.isArray(lData.leaves) ? lData.leaves : [];
      renderCalendar();
    } catch {
      if (grid) grid.innerHTML = '<p class="empty-msg" style="grid-column:1/-1">Failed to load calendar.</p>';
    }
  }

  type EventKind = 'game' | 'holiday' | 'school' | 'sports' | 'leave';
  // Build a map: ymd → array of events { kind, payload } so the grid render
  // can look up cells in O(1). Leave entries are expanded across each
  // covered day. School-holiday rows (Type contains "school") and sports
  // events (Type contains "sports"/"tournament") are emitted as their
  // dedicated kinds so the UI can colour each apart from generic public
  // holidays. Filters drop entire categories from the map.
  function buildEventMap(): Record<string, Array<{ kind: EventKind; payload: any }>> {
    const map: Record<string, Array<{ kind: EventKind; payload: any }>> = {};
    const push = (ymd: string, kind: EventKind, payload: any) => {
      if (!map[ymd]) map[ymd] = [];
      map[ymd].push({ kind, payload });
    };
    if (calendarFilter === 'all' || calendarFilter === 'games') {
      for (const s of sessionsData) if (s.Date) push(s.Date, 'game', s);
    }
    for (const h of holidaysData) {
      if (!h.Date) continue;
      const isSports = isSportsEvent(h);
      const isSchool = !isSports && isSchoolHoliday(h);
      if (isSports && (calendarFilter === 'all' || calendarFilter === 'sports')) {
        push(h.Date, 'sports', h);
      } else if (isSchool && (calendarFilter === 'all' || calendarFilter === 'school')) {
        push(h.Date, 'school', h);
      } else if (!isSports && !isSchool && (calendarFilter === 'all' || calendarFilter === 'holidays')) {
        push(h.Date, 'holiday', h);
      }
    }
    if (calendarFilter === 'all' || calendarFilter === 'leave') {
      for (const lv of leavesData) {
        const from = parseYmd(String(lv['Date From'] || ''));
        const toY = parseYmd(String(lv['Date To'] || lv['Date From'] || ''));
        if (!from || !toY) continue;
        // Walk inclusive from-to without timezone surprises by iterating days locally.
        const start = new Date(from.y, from.m, from.d);
        const end = new Date(toY.y, toY.m, toY.d);
        for (let cur = start; cur <= end; cur.setDate(cur.getDate() + 1)) {
          push(ymdFromYMD(cur.getFullYear(), cur.getMonth(), cur.getDate()), 'leave', lv);
        }
      }
    }
    return map;
  }

  function renderCalendar() {
    if (!calViewYear) initCalendarView();
    renderMonthHeader();
    renderWeekdaysRow();
    renderMonthGrid();
    renderDayDetails();
  }

  function renderMonthHeader() {
    const monthName = new Date(calViewYear, calViewMonth, 1)
      .toLocaleDateString('en-MY', { month: 'long' });
    const nameEl = document.getElementById('calMonthName');
    const yearEl = document.getElementById('calMonthYear');
    if (nameEl) nameEl.textContent = monthName.toUpperCase();
    if (yearEl) yearEl.textContent = String(calViewYear);
  }

  function renderWeekdaysRow() {
    const wrap = document.getElementById('calWeekdays');
    if (!wrap) return;
    // Mon-first; short single-letter labels with full names in title for a11y.
    const labels = [
      { s: 'M', f: 'Mon' }, { s: 'T', f: 'Tue' }, { s: 'W', f: 'Wed' },
      { s: 'T', f: 'Thu' }, { s: 'F', f: 'Fri' }, { s: 'S', f: 'Sat' },
      { s: 'S', f: 'Sun' },
    ];
    wrap.innerHTML = labels.map((l) =>
      `<div class="cal-weekday" title="${l.f}">${l.s}</div>`
    ).join('');
  }

  function renderMonthGrid() {
    const grid = document.getElementById('calGrid');
    if (!grid) return;

    const eventMap = buildEventMap();
    const today = ymdToday();

    const firstWd = monFirstWeekday(calViewYear, calViewMonth, 1);  // 0=Mon..6=Sun
    const numDays = daysInMonth(calViewYear, calViewMonth);
    // Previous-month tail to fill the leading row.
    const prevMonth = calViewMonth === 0 ? 11 : calViewMonth - 1;
    const prevYear = calViewMonth === 0 ? calViewYear - 1 : calViewYear;
    const prevNum = daysInMonth(prevYear, prevMonth);
    // Next-month head to fill the trailing row.
    const nextMonth = calViewMonth === 11 ? 0 : calViewMonth + 1;
    const nextYear = calViewMonth === 11 ? calViewYear + 1 : calViewYear;

    const cells: Array<{ ymd: string; day: number; outside: boolean }> = [];
    for (let i = 0; i < firstWd; i++) {
      const d = prevNum - firstWd + 1 + i;
      cells.push({ ymd: ymdFromYMD(prevYear, prevMonth, d), day: d, outside: true });
    }
    for (let d = 1; d <= numDays; d++) {
      cells.push({ ymd: ymdFromYMD(calViewYear, calViewMonth, d), day: d, outside: false });
    }
    while (cells.length % 7 !== 0 || cells.length < 42) {
      const idx = cells.length - (firstWd + numDays);
      const d = idx + 1;
      cells.push({ ymd: ymdFromYMD(nextYear, nextMonth, d), day: d, outside: true });
      if (cells.length >= 42) break;
    }

    grid.innerHTML = cells.map((c) => {
      const evts = eventMap[c.ymd] || [];
      const kinds = new Set(evts.map((e) => e.kind));
      const isToday = c.ymd === today;
      const isSelected = c.ymd === calSelectedDate;

      // Single tint class per cell, picked by priority. Match days take
      // precedence so they pop visually on the grid; today/selected
      // states are still applied on top via separate classes.
      // Order: Match > Leave > Sports > Holiday > School.
      const tint =
        kinds.has('game')    ? 'cal-cell--has-game'    :
        kinds.has('leave')   ? 'cal-cell--has-leave'   :
        kinds.has('sports')  ? 'cal-cell--has-sports'  :
        kinds.has('holiday') ? 'cal-cell--has-holiday' :
        kinds.has('school')  ? 'cal-cell--has-school'  : '';

      const classes = [
        'cal-cell',
        c.outside ? 'cal-cell--outside' : '',
        isToday ? 'cal-cell--today' : '',
        isSelected ? 'cal-cell--selected' : '',
        evts.length ? 'cal-cell--has-events' : '',
        tint,
      ].filter(Boolean).join(' ');

      // Up to 5 colored dots indicating event categories on this day.
      const dotOrder: EventKind[] = ['game', 'sports', 'school', 'holiday', 'leave'];
      const dotsHtml = dotOrder.filter((k) => kinds.has(k))
        .map((k) => `<span class="cal-dot cal-dot--${k}"></span>`).join('');

      return `<button type="button" class="${classes}" data-ymd="${c.ymd}" aria-label="${c.ymd}">
        <span class="cal-cell-num">${c.day}</span>
        ${dotsHtml ? `<span class="cal-cell-dots">${dotsHtml}</span>` : ''}
      </button>`;
    }).join('');
  }

  function renderDayDetails() {
    const wrap = document.getElementById('calDayDetails');
    if (!wrap) return;
    if (!calSelectedDate) { wrap.innerHTML = ''; return; }

    const eventMap = buildEventMap();
    const events = eventMap[calSelectedDate] || [];
    const parsed = parseYmd(calSelectedDate);
    if (!parsed) { wrap.innerHTML = ''; return; }
    const d = new Date(parsed.y, parsed.m, parsed.d);
    const heading = d.toLocaleDateString('en-MY', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

    const me = adminSession ? adminSession.username : '';

    let body = '';
    if (!events.length) {
      body = '<p class="cal-empty">Nothing on this day.</p>';
    } else {
      body = events.map((e) => {
        if (e.kind === 'game') {
          const s = e.payload;
          return `<div class="cal-event cal-event--game" data-kind="game" data-date="${calEsc(s.Date || '')}">
            <span class="cal-event-icon">🏟</span>
            <div class="cal-event-body">
              <span class="cal-event-title">${calEsc(s['Session Name'] || 'Game')}</span>
              <span class="cal-event-meta">${calEsc(s.Time || '')}${s.Location ? ' · ' + calEsc(s.Location) : ''}</span>
            </div>
            <svg class="cal-event-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </div>`;
        }
        if (e.kind === 'holiday') {
          const h = e.payload;
          const meIsSA = !!(adminSession && adminSession.isSuperadmin);
          return `<div class="cal-event cal-event--holiday">
            <span class="cal-event-icon">🇲🇾</span>
            <div class="cal-event-body">
              <span class="cal-event-title">${calEsc(h.Name || 'Holiday')}</span>
              <span class="cal-event-meta">${calEsc(h.Type || 'Custom')}</span>
            </div>
            ${meIsSA ? `<button type="button" class="cal-event-remove" data-kind="holiday" data-date="${calEsc(h.Date || '')}" title="Remove holiday">&times;</button>` : ''}
          </div>`;
        }
        if (e.kind === 'school') {
          const h = e.payload;
          const meIsSA = !!(adminSession && adminSession.isSuperadmin);
          return `<div class="cal-event cal-event--school">
            <span class="cal-event-icon">🎒</span>
            <div class="cal-event-body">
              <span class="cal-event-title">${calEsc(h.Name || 'School Holiday')}</span>
              <span class="cal-event-meta">${calEsc(h.Type || 'School')}</span>
            </div>
            ${meIsSA ? `<button type="button" class="cal-event-remove" data-kind="holiday" data-date="${calEsc(h.Date || '')}" title="Remove">&times;</button>` : ''}
          </div>`;
        }
        if (e.kind === 'sports') {
          const h = e.payload;
          // Sports events are removable by ANY logged-in admin (regular or
          // superadmin). The server independently enforces that the row's
          // Type is Sports before allowing the delete.
          return `<div class="cal-event cal-event--sports">
            <span class="cal-event-icon">🏆</span>
            <div class="cal-event-body">
              <span class="cal-event-title">${calEsc(h.Name || 'Sports Event')}</span>
              <span class="cal-event-meta">${calEsc(h.Type || 'Sports')}</span>
            </div>
            ${adminSession ? `<button type="button" class="cal-event-remove" data-kind="holiday" data-date="${calEsc(h.Date || '')}" title="Remove">&times;</button>` : ''}
          </div>`;
        }
        // leave
        const lv = e.payload;
        const lvUsername = String(lv.Username || '').trim().toLowerCase();
        const isMine = lvUsername === me;
        const meIsSA = !!(adminSession && adminSession.isSuperadmin);
        // Self can always cancel; superadmin can cancel anyone's. Other
        // admins see no cancel button — server enforces this regardless.
        const canCancel = isMine || meIsSA;
        const reason = lv.Reason ? calEsc(String(lv.Reason).slice(0, 120)) : '';
        const span = lv['Date From'] !== lv['Date To'] && lv['Date To']
          ? ` <span class="cal-event-span">(${calEsc(lv['Date From'])} → ${calEsc(lv['Date To'])})</span>`
          : '';
        return `<div class="cal-event cal-event--leave">
          <span class="cal-event-icon">🛌</span>
          <div class="cal-event-body">
            <span class="cal-event-title">${calEsc(lv['Display Name'] || lv.Username || 'Admin')} on leave${span}</span>
            ${reason ? `<span class="cal-event-meta">"${reason}"</span>` : ''}
          </div>
          ${canCancel ? `<button type="button" class="cal-event-remove" data-kind="leave" data-created="${calEsc(lv['Created At'] || '')}" data-username="${calEsc(lvUsername)}" title="${isMine ? 'Cancel my leave' : 'Cancel ' + (lv['Display Name'] || lv.Username) + '\u2019s leave'}">&times;</button>` : ''}
        </div>`;
      }).join('');
    }

    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    // Quick "add" buttons in the day header. Regular admins get "+ Sports"
    // (limited Type); superadmins get the full "+ Holiday" with the type
    // dropdown. Both routes open the same modal — it adapts based on role.
    const quickHolidayLabel = meIsSA ? '+ Holiday' : '+ Sports';
    wrap.innerHTML = `
      <div class="cal-details-head">
        <span class="cal-details-date">${calEsc(heading)}</span>
        <div class="cal-details-actions">
          <button type="button" class="cal-mini-btn" id="calQuickLeave">+ Leave</button>
          ${adminSession ? `<button type="button" class="cal-mini-btn" id="calQuickHoliday">${quickHolidayLabel}</button>` : ''}
        </div>
      </div>
      <div class="cal-events">${body}</div>
    `;

    const qLeave = document.getElementById('calQuickLeave') as HTMLButtonElement | null;
    const qHoliday = document.getElementById('calQuickHoliday') as HTMLButtonElement | null;
    if (qLeave) qLeave.addEventListener('click', () => openLeaveModal(calSelectedDate));
    if (qHoliday) qHoliday.addEventListener('click', () => openHolidayModal(calSelectedDate));
  }

  // === Wire up navigation ===
  function calGoPrevMonth() {
    if (calViewMonth === 0) { calViewMonth = 11; calViewYear--; } else { calViewMonth--; }
    renderCalendar();
  }
  function calGoNextMonth() {
    if (calViewMonth === 11) { calViewMonth = 0; calViewYear++; } else { calViewMonth++; }
    renderCalendar();
  }
  document.getElementById('calPrevMonth')!.addEventListener('click', calGoPrevMonth);
  document.getElementById('calNextMonth')!.addEventListener('click', calGoNextMonth);
  document.getElementById('calTodayBtn')!.addEventListener('click', () => {
    const today = ymdToday();
    const t = parseYmd(today);
    if (!t) return;
    calViewYear = t.y; calViewMonth = t.m; calSelectedDate = today;
    renderCalendar();
  });

  // Swipe-to-navigate between months on touch devices.
  // Listens on the grid wrapper (not the whole tab) so the gesture
  // doesn't fight with vertical scrolling of the day-details panel
  // or the rest of the page. Threshold tuned for casual swipes:
  //   - 50px horizontal minimum (filters out taps + tiny drifts)
  //   - 60px vertical tolerance (anything more vertical than that
  //     reads as "user trying to scroll the page", not swipe nav)
  (function wireCalendarSwipe() {
    const wrap = document.querySelector('.cal-grid-wrap') as HTMLElement | null;
    if (!wrap) return;
    let startX = 0;
    let startY = 0;
    let active = false;
    wrap.addEventListener('touchstart', (e) => {
      if (e.touches.length !== 1) { active = false; return; }
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      active = true;
    }, { passive: true });
    wrap.addEventListener('touchend', (e) => {
      if (!active) return;
      active = false;
      const t = e.changedTouches[0];
      if (!t) return;
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      const HORIZONTAL_THRESHOLD = 50;
      const VERTICAL_TOLERANCE = 60;
      if (Math.abs(dx) < HORIZONTAL_THRESHOLD) return;
      if (Math.abs(dy) > VERTICAL_TOLERANCE) return;
      // Swipe left → next month, swipe right → previous month
      // (matches the visual: the next month is "to the right" of today,
      // so dragging left reveals what's next).
      if (dx < 0) calGoNextMonth();
      else calGoPrevMonth();
    }, { passive: true });
    // Cancel tracking if the gesture is interrupted (e.g. multitouch
    // pinch-zoom started, or system gesture took over).
    wrap.addEventListener('touchcancel', () => { active = false; }, { passive: true });
  })();

  // Filter chip clicks
  document.getElementById('calFilters')!.addEventListener('click', (e) => {
    const chip = (e.target as HTMLElement).closest('.cal-chip') as HTMLElement | null;
    if (!chip) return;
    document.querySelectorAll('#calFilters .cal-chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    calendarFilter = (chip.dataset.stream as any) || 'all';
    renderCalendar();
  });

  // Day cell clicks — selects the day and may jump months if user taps an
  // outside-month spillover cell.
  document.getElementById('calGrid')!.addEventListener('click', (e) => {
    const cell = (e.target as HTMLElement).closest('.cal-cell') as HTMLElement | null;
    if (!cell) return;
    const ymd = cell.dataset.ymd || '';
    if (!ymd) return;
    const parsed = parseYmd(ymd);
    if (!parsed) return;
    if (parsed.y !== calViewYear || parsed.m !== calViewMonth) {
      calViewYear = parsed.y;
      calViewMonth = parsed.m;
    }
    calSelectedDate = ymd;
    renderCalendar();
  });

  // Day-details event clicks: tap a game → switch to Schedule. Tap a remove
  // ✕ → confirm + delete via reconcile (holiday) or DELETE (leave).
  document.getElementById('calDayDetails')!.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const remove = target.closest('.cal-event-remove') as HTMLElement | null;
    if (remove) {
      const kind = remove.dataset.kind;
      e.stopPropagation();
      if (kind === 'holiday') {
        const date = remove.dataset.date || '';
        if (!date) return;
        if (!confirm(`Remove holiday on ${date}?`)) return;
        try {
          const remaining = holidaysData.filter((h: any) => h.Date !== date);
          const res = await fetch(`${API}/admin/holidays`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: adminToken },
            body: JSON.stringify({ holidays: remaining, deletes: [date] }),
          });
          if (!res.ok) throw new Error('save failed');
          const data = await res.json().catch(() => ({}));
          holidaysData = Array.isArray(data.holidays) ? data.holidays : remaining;
          renderCalendar();
          showToast('Holiday removed');
        } catch {
          showToast('Failed to remove holiday', 'error');
        }
      } else if (kind === 'leave') {
        const createdAt = remove.dataset.created || '';
        const targetUsername = (remove.dataset.username || '').toLowerCase();
        if (!createdAt) return;
        const me = adminSession?.username || '';
        const isMine = targetUsername === me;
        const prompt = isMine ? 'Cancel this leave?' : `Cancel ${targetUsername}'s leave? They won\u2019t be notified.`;
        if (!confirm(prompt)) return;
        try {
          const res = await fetch(`${API}/admin/leave`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', Authorization: adminToken },
            body: JSON.stringify({ createdAt, username: targetUsername }),
          });
          if (!res.ok) throw new Error('delete failed');
          // Drop the matching row from local state so the next render hides it.
          leavesData = leavesData.filter((lv: any) =>
            !(String(lv['Created At'] || '') === createdAt
              && String(lv.Username || '').toLowerCase() === targetUsername)
          );
          renderCalendar();
          showToast('Leave cancelled');
        } catch {
          showToast('Failed to cancel leave', 'error');
        }
      }
      return;
    }

    const game = target.closest('.cal-event--game') as HTMLElement | null;
    if (game) {
      const date = game.dataset.date || '';
      const tab = document.querySelector('.tab[data-tab="schedule"]') as HTMLButtonElement | null;
      if (tab) tab.click();
      setTimeout(() => {
        const card = document.querySelector(`.s-input[data-field="Date"][value="${date}"]`) as HTMLElement | null;
        if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 50);
    }
  });

  // === Subscribe to calendar feeds (admin testing) ===
  // Fetches the per-admin feed URLs from /api/admin/calendar-feeds and
  // populates the subscribe section. Token never leaves the server — we
  // just receive the resulting URLs.
  let feedsLoaded = false;
  async function loadCalendarFeeds() {
    if (feedsLoaded) return;
    try {
      const res = await fetch(`${API}/admin/calendar-feeds`, { headers: { Authorization: adminToken } });
      if (!res.ok) return;
      const data = await res.json().catch(() => ({}));
      const fillUrl = (id: string, url: string) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && url) el.value = url;
      };
      const fillHref = (id: string, url: string) => {
        const el = document.getElementById(id) as HTMLAnchorElement | null;
        if (el && url) el.href = url;
      };
      fillUrl('feedMatchesUrl', data.matches);
      fillUrl('feedAdminUrl', data.admin);
      fillHref('feedMatchesAdd', data.webcalMatches);
      fillHref('feedAdminAdd', data.webcalAdmin);
      feedsLoaded = true;
    } catch {
      // Silent — admin can refresh if they want to retry.
    }
  }

  // Copy buttons on the subscribe section — clipboard write + brief
  // visual feedback.
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.cal-feed-copy') as HTMLButtonElement | null;
    if (!btn) return;
    const targetId = btn.dataset.target || '';
    const inp = document.getElementById(targetId) as HTMLInputElement | null;
    if (!inp || !inp.value) return;
    try {
      await navigator.clipboard.writeText(inp.value);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig || 'Copy'; }, 1500);
    } catch {
      // Fallback — select the text so the user can copy manually
      inp.select();
    }
  });

  // === Sync Malaysia 2026 Klang Valley public holidays + school breaks ===
  // Pre-curated. Lunar/Islamic/Hindu dates are based on widely-published
  // 2026 forecasts and may need adjustment by ±1 day once moon-sighting
  // announcements land — admins can edit any row inline afterwards.
  const KLANG_VALLEY_2026: Array<{ Date: string; Name: string; Type: string }> = [
    { Date: '2026-01-01', Name: 'New Year\u2019s Day', Type: 'Federal' },
    { Date: '2026-01-29', Name: 'Chinese New Year (Day 1)', Type: 'Federal' },
    { Date: '2026-01-30', Name: 'Chinese New Year (Day 2)', Type: 'Federal' },
    { Date: '2026-02-01', Name: 'Federal Territory Day', Type: 'KL/Putrajaya' },
    { Date: '2026-02-02', Name: 'Federal Territory Day (observed)', Type: 'KL/Putrajaya' },
    { Date: '2026-03-20', Name: 'Hari Raya Aidilfitri (Day 1)', Type: 'Federal' },
    { Date: '2026-03-21', Name: 'Hari Raya Aidilfitri (Day 2)', Type: 'Federal' },
    { Date: '2026-05-01', Name: 'Labour Day', Type: 'Federal' },
    { Date: '2026-05-27', Name: 'Hari Raya Aidiladha', Type: 'Federal' },
    { Date: '2026-05-31', Name: 'Wesak Day', Type: 'Federal' },
    { Date: '2026-06-06', Name: 'Yang di-Pertuan Agong\u2019s Birthday', Type: 'Federal' },
    { Date: '2026-06-17', Name: 'Awal Muharram', Type: 'Federal' },
    { Date: '2026-08-26', Name: 'Maulidur Rasul', Type: 'Federal' },
    { Date: '2026-08-31', Name: 'Hari Kebangsaan', Type: 'Federal' },
    { Date: '2026-09-16', Name: 'Malaysia Day', Type: 'Federal' },
    { Date: '2026-11-08', Name: 'Deepavali', Type: 'Federal' },
    { Date: '2026-11-09', Name: 'Deepavali (observed)', Type: 'Federal' },
    { Date: '2026-12-11', Name: 'Sultan of Selangor\u2019s Birthday', Type: 'Selangor' },
    { Date: '2026-12-25', Name: 'Christmas Day', Type: 'Federal' },
  ];

  // School-term breaks for Group A (Klang Valley + most peninsula states).
  // Based on the typical KPM/MoE calendar pattern; verify against the
  // official 2026 academic year release if MOE published a different
  // shape. Each range is expanded into one row per day at sync time.
  const KLANG_VALLEY_SCHOOL_2026: Array<{ from: string; to: string; name: string }> = [
    { from: '2026-03-28', to: '2026-04-05', name: 'School Holiday — Term 1 Break' },
    { from: '2026-05-23', to: '2026-05-31', name: 'School Holiday — Mid-Year Break' },
    { from: '2026-07-25', to: '2026-08-02', name: 'School Holiday — Term 3 Break' },
    { from: '2026-11-28', to: '2026-12-31', name: 'School Holiday — Year-End Break' },
  ];

  function expandSchoolBreaks(): Array<{ Date: string; Name: string; Type: string }> {
    const out: Array<{ Date: string; Name: string; Type: string }> = [];
    for (const r of KLANG_VALLEY_SCHOOL_2026) {
      const from = parseYmd(r.from);
      const to = parseYmd(r.to);
      if (!from || !to) continue;
      const start = new Date(from.y, from.m, from.d);
      const end = new Date(to.y, to.m, to.d);
      for (let cur = start; cur <= end; cur.setDate(cur.getDate() + 1)) {
        out.push({
          Date: ymdFromYMD(cur.getFullYear(), cur.getMonth(), cur.getDate()),
          Name: r.name,
          Type: 'School',
        });
      }
    }
    return out;
  }

  document.getElementById('syncMyHolidaysBtn')!.addEventListener('click', async () => {
    const schoolDays = expandSchoolBreaks();
    const totalSeed = KLANG_VALLEY_2026.length + schoolDays.length;
    if (!confirm(`Pre-fill Malaysia (Klang Valley) 2026 public holidays + school breaks?\n\n${KLANG_VALLEY_2026.length} public holidays\n${schoolDays.length} school-break days\n\nExisting custom holidays on different dates are kept; same-date entries are updated. You can still delete any row afterwards.`)) return;
    const btn = document.getElementById('syncMyHolidaysBtn') as HTMLButtonElement;
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = 'SYNCING…';
    try {
      // Merge order: school breaks first, public holidays second. So if a
      // public holiday falls inside a school break window (which is the
      // norm — that's why kids get the week off), the public holiday
      // overrides the school-break entry on that exact date.
      const seedByDate = new Map<string, { Date: string; Name: string; Type: string }>();
      for (const s of schoolDays) seedByDate.set(s.Date, s);
      for (const h of KLANG_VALLEY_2026) seedByDate.set(h.Date, h);

      const merged: any[] = [];
      const seenDates = new Set<string>();
      for (const row of holidaysData) {
        const seed = seedByDate.get(row.Date);
        if (seed) {
          merged.push({ Date: seed.Date, Name: seed.Name, Type: seed.Type });
          seenDates.add(row.Date);
          seedByDate.delete(row.Date);
        } else {
          merged.push(row);
          seenDates.add(row.Date);
        }
      }
      for (const seed of seedByDate.values()) {
        if (!seenDates.has(seed.Date)) merged.push(seed);
      }

      const res = await fetch(`${API}/admin/holidays`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ holidays: merged, deletes: [] }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.error || 'failed');
      holidaysData = Array.isArray(data.holidays) ? data.holidays : merged;
      renderCalendar();
      showToast(`${totalSeed} entries synced`);
    } catch (err: any) {
      showToast(err.message || 'Sync failed', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  });

  // === Apply for Leave modal ===
  const leaveModal = document.getElementById('leaveModal')!;
  // Optional preDate pre-fills both From and To when called from a day cell.
  function openLeaveModal(preDate?: string) {
    if (!adminSession) return;
    if (adminSession.isOwner) {
      showToast('Owner sessions can\u2019t apply for leave. Log in as a real admin first.', 'error');
      return;
    }
    const sub = document.getElementById('leaveModalSub')!;
    sub.textContent = `Logged in as ${adminSession.displayName}`;
    const seed = preDate || ymdToday();
    (document.getElementById('leaveFrom') as HTMLInputElement).value = seed;
    (document.getElementById('leaveTo') as HTMLInputElement).value = seed;
    (document.getElementById('leaveReason') as HTMLInputElement).value = '';
    (document.getElementById('leaveModalError') as HTMLElement).style.display = 'none';
    leaveModal.style.display = '';
  }
  document.getElementById('addLeaveBtn')!.addEventListener('click', () => openLeaveModal(calSelectedDate || undefined));
  document.getElementById('leaveModalClose')!.addEventListener('click', () => leaveModal.style.display = 'none');
  leaveModal.addEventListener('click', (e) => { if (e.target === leaveModal) leaveModal.style.display = 'none'; });
  document.getElementById('leaveSubmitBtn')!.addEventListener('click', async () => {
    const from = (document.getElementById('leaveFrom') as HTMLInputElement).value;
    const to = (document.getElementById('leaveTo') as HTMLInputElement).value || from;
    const reason = (document.getElementById('leaveReason') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('leaveModalError') as HTMLElement;
    if (!from) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Pick a start date.</div>';
      return;
    }
    if (to < from) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">"To" must be on or after "From".</div>';
      return;
    }
    const btn = document.getElementById('leaveSubmitBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'SUBMITTING…';
    try {
      const res = await fetch(`${API}/admin/leave`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ dateFrom: from, dateTo: to, reason }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.error || 'failed');
      leaveModal.style.display = 'none';
      showToast('Leave applied');
      // Refresh leave data so it appears in the calendar.
      try {
        const r = await fetch(`${API}/admin/leave`, { headers: { Authorization: adminToken } });
        const d = await r.json();
        leavesData = Array.isArray(d.leaves) ? d.leaves : leavesData;
        renderCalendar();
      } catch {}
    } catch (err: any) {
      errEl.style.display = '';
      errEl.innerHTML = `<div class="alert alert--error">${err.message || 'Failed to apply.'}</div>`;
    } finally {
      btn.disabled = false; btn.textContent = 'SUBMIT';
    }
  });

  // === Add Holiday / Sports Event modal ===
  const holidayModal = document.getElementById('holidayModal')!;
  function openHolidayModal(preDate?: string) {
    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    // Modal adapts to the role: regular admin sees a Sports-Event-only
    // form (Type row hidden, defaulted to Sports). Superadmin sees the
    // full form with the Type dropdown.
    const titleEl = document.getElementById('holidayModalTitle') as HTMLElement | null;
    const subEl = document.getElementById('holidayModalSub') as HTMLElement | null;
    const typeRow = document.getElementById('holidayTypeRow') as HTMLElement | null;
    if (titleEl) {
      titleEl.innerHTML = meIsSA
        ? 'ADD <span class="neon-text">HOLIDAY</span>'
        : 'ADD <span class="neon-text">SPORTS EVENT</span>';
    }
    if (subEl) {
      subEl.textContent = meIsSA
        ? 'Add a public holiday or community blackout day.'
        : 'Flag an external sports event so the team is aware.';
    }
    if (typeRow) typeRow.style.display = meIsSA ? '' : 'none';
    (document.getElementById('holidayDate') as HTMLInputElement).value = preDate || ymdToday();
    (document.getElementById('holidayName') as HTMLInputElement).value = '';
    (document.getElementById('holidayType') as HTMLSelectElement).value = meIsSA ? 'Custom' : 'Sports';
    (document.getElementById('holidayModalError') as HTMLElement).style.display = 'none';
    holidayModal.style.display = '';
  }
  document.getElementById('addHolidayBtn')!.addEventListener('click', () => openHolidayModal(calSelectedDate || undefined));
  document.getElementById('holidayModalClose')!.addEventListener('click', () => holidayModal.style.display = 'none');
  holidayModal.addEventListener('click', (e) => { if (e.target === holidayModal) holidayModal.style.display = 'none'; });
  document.getElementById('holidaySubmitBtn')!.addEventListener('click', async () => {
    const date = (document.getElementById('holidayDate') as HTMLInputElement).value;
    const name = (document.getElementById('holidayName') as HTMLInputElement).value.trim();
    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    // Force Type=Sports for non-superadmins regardless of what the DOM
    // reads — server enforces it too, this is just defence-in-depth.
    const type = meIsSA
      ? (document.getElementById('holidayType') as HTMLSelectElement).value
      : 'Sports';
    const errEl = document.getElementById('holidayModalError') as HTMLElement;
    if (!date || !name) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Date and name are required.</div>';
      return;
    }
    const btn = document.getElementById('holidaySubmitBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'SAVING…';
    try {
      // Add to local list, post the merged set; server reconciles by Date so
      // we don't need to worry about duplicate-by-date checks here.
      const next = [...holidaysData.filter((h: any) => h.Date !== date), { Date: date, Name: name, Type: type }];
      const res = await fetch(`${API}/admin/holidays`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: adminToken },
        body: JSON.stringify({ holidays: next, deletes: [] }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.error || 'failed');
      holidaysData = Array.isArray(data.holidays) ? data.holidays : next;
      holidayModal.style.display = 'none';
      showToast('Holiday added');
      renderCalendar();
    } catch (err: any) {
      errEl.style.display = '';
      errEl.innerHTML = `<div class="alert alert--error">${err.message || 'Failed to save.'}</div>`;
    } finally {
      btn.disabled = false; btn.textContent = 'SAVE';
    }
  });

  // ===========================================================================
  // ADMINS TAB — manage admin accounts (add, reset password, toggle active)
  // ===========================================================================
  let adminsData: any[] = [];
  let editingAdminUsername: string | null = null;

  async function loadAdmins() {
