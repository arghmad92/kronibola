    }
  }

  function renderAdmins() {
    const list = document.getElementById('adminsList');
    if (!list) return;
    if (!adminsData.length) {
      list.innerHTML = '<p class="empty-msg">No admin accounts yet. Tap "+ Add Admin" to create the first one.</p>';
      return;
    }
    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    list.innerHTML = adminsData.map((a: any) => {
      const username = String(a.Username || '').toLowerCase();
      const isMe = adminSession && adminSession.username === username;
      const active = String(a.Active || '').toLowerCase() === 'yes';
      const isSA = String(a.Role || '').toLowerCase() === 'superadmin';
      // Self-edit (display name + own password) is always allowed.
      // Editing OR deleting another admin requires superadmin.
      const canManageThis = isMe || meIsSA;
      const canDeleteThis = !isMe && meIsSA;
      const canToggleThis = !isMe && meIsSA;
      const roleChip = isSA
        ? `<span class="admin-role-chip admin-role-chip--sa">SUPERADMIN</span>`
        : '';
      return `<div class="player-card-admin">
        <div class="pca-top">
          <div class="pca-avatar" style="background:${active ? 'rgba(0,255,65,0.12)' : 'rgba(255,255,255,0.06)'};color:${active ? 'var(--neon)' : 'var(--text-muted)'};border-color:${active ? 'rgba(0,255,65,0.3)' : 'var(--border)'}">${calEsc((a['Display Name'] || username || '?')[0].toUpperCase())}</div>
          <div class="pca-info">
            <span class="pca-name">${calEsc(a['Display Name'] || username)}${isMe ? ' <span style="font-size:0.62rem;color:var(--neon)">(you)</span>' : ''} ${roleChip}</span>
            <span class="pca-phone">@${calEsc(username)} · ${active ? 'Active' : 'Inactive'}</span>
          </div>
        </div>
        <div class="pca-controls">
          ${canManageThis ? `<button type="button" class="pca-save admin-edit" data-username="${calEsc(username)}" title="${isMe ? 'Edit profile' : 'Edit / reset password'}">EDIT</button>` : ''}
          ${canToggleThis ? `<button type="button" class="pca-save ${active ? 'pca-save--info' : 'pca-save--danger'} admin-toggle" data-username="${calEsc(username)}" data-active="${active ? 'Yes' : 'No'}" title="${active ? 'Deactivate' : 'Reactivate'}">${active ? 'DEACTIVATE' : 'REACTIVATE'}</button>` : ''}
          ${canDeleteThis ? `<button type="button" class="pca-save pca-save--danger admin-delete" data-username="${calEsc(username)}" title="Delete admin">DELETE</button>` : ''}
        </div>
      </div>`;
    }).join('');
  }

  // === Add / Edit Admin modal ===
  const adminModal = document.getElementById('adminModal')!;
  document.getElementById('addAdminBtn')!.addEventListener('click', () => {
    if (!adminSession || !adminSession.isSuperadmin) {
      showToast('Only the superadmin can create new admins.', 'error');
      return;
    }
    editingAdminUsername = null;
    (document.getElementById('adminModalTitle') as HTMLElement).innerHTML = 'ADD <span class="neon-text">ADMIN</span>';
    (document.getElementById('adminModalSub') as HTMLElement).textContent = 'Create a new admin account';
    (document.getElementById('adminUsernameRow') as HTMLElement).style.display = '';
    (document.getElementById('adminUsername') as HTMLInputElement).value = '';
    (document.getElementById('adminUsername') as HTMLInputElement).disabled = false;
    (document.getElementById('adminDisplayName') as HTMLInputElement).value = '';
    (document.getElementById('adminPassword') as HTMLInputElement).value = '';
    (document.getElementById('adminPasswordLabel') as HTMLElement).textContent = 'Password';
    (document.getElementById('adminPasswordHint') as HTMLElement).style.display = 'none';
    (document.getElementById('adminSubmitBtn') as HTMLButtonElement).textContent = 'CREATE';
    (document.getElementById('adminModalError') as HTMLElement).style.display = 'none';
    // Role row visible to superadmins only (server enforces this regardless).
    (document.getElementById('adminRoleRow') as HTMLElement).style.display = '';
    (document.getElementById('adminRole') as HTMLSelectElement).value = '';
    adminModal.style.display = '';
  });
  document.getElementById('adminModalClose')!.addEventListener('click', () => adminModal.style.display = 'none');
  adminModal.addEventListener('click', (e) => { if (e.target === adminModal) adminModal.style.display = 'none'; });

  document.getElementById('adminsList')!.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const editBtn = target.closest('.admin-edit') as HTMLElement | null;
    const toggleBtn = target.closest('.admin-toggle') as HTMLElement | null;
    const delBtn = target.closest('.admin-delete') as HTMLElement | null;

    if (editBtn) {
      const username = editBtn.dataset.username || '';
      const row = adminsData.find((a: any) => String(a.Username || '').toLowerCase() === username);
      if (!row) return;
      const isMe = adminSession && adminSession.username === username;
      const meIsSA = !!(adminSession && adminSession.isSuperadmin);
      // Server also enforces this — UI guard for nicer UX.
      if (!isMe && !meIsSA) {
        showToast('Only the superadmin can edit other admins.', 'error');
        return;
      }
      editingAdminUsername = username;
      (document.getElementById('adminModalTitle') as HTMLElement).innerHTML = 'EDIT <span class="neon-text">ADMIN</span>';
      (document.getElementById('adminModalSub') as HTMLElement).textContent = `@${username}${isMe ? ' (you)' : ''}`;
      // Username is locked on edit. Hide the row entirely — the subtitle
      // above already shows it, and there's no path to actually change it
      // (server PUT uses the body username only as a lookup key, never
      // writes it as an update).
      (document.getElementById('adminUsernameRow') as HTMLElement).style.display = 'none';
      (document.getElementById('adminUsername') as HTMLInputElement).value = username;
      (document.getElementById('adminUsername') as HTMLInputElement).disabled = true;
      (document.getElementById('adminDisplayName') as HTMLInputElement).value = row['Display Name'] || '';
      (document.getElementById('adminPassword') as HTMLInputElement).value = '';
      (document.getElementById('adminPasswordLabel') as HTMLElement).textContent = 'New Password';
      (document.getElementById('adminPasswordHint') as HTMLElement).style.display = '';
      (document.getElementById('adminSubmitBtn') as HTMLButtonElement).textContent = 'SAVE';
      (document.getElementById('adminModalError') as HTMLElement).style.display = 'none';
      // Role row visible to superadmins only. When self-editing as a regular
      // admin, the row stays hidden — promoting yourself isn't a thing.
      const roleRow = document.getElementById('adminRoleRow') as HTMLElement;
      roleRow.style.display = meIsSA ? '' : 'none';
      (document.getElementById('adminRole') as HTMLSelectElement).value =
        String(row.Role || '').toLowerCase() === 'superadmin' ? 'superadmin' : '';
      adminModal.style.display = '';
      return;
    }

    if (toggleBtn) {
      const username = toggleBtn.dataset.username || '';
      const wasActive = toggleBtn.dataset.active === 'Yes';
      const next = wasActive ? 'No' : 'Yes';
      try {
        const res = await fetch(`${API}/admin/admins`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ username, active: next }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) throw new Error(data.error || 'failed');
        showToast(wasActive ? 'Admin deactivated' : 'Admin reactivated');
        await loadAdmins();
      } catch (err: any) {
        showToast(err.message || 'Failed to update', 'error');
      }
      return;
    }

    if (delBtn) {
      const username = delBtn.dataset.username || '';
      if (!confirm(`Delete admin "${username}"? Their leave history stays in the sheet but they can't log in anymore.`)) return;
      try {
        const res = await fetch(`${API}/admin/admins`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify({ username }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) throw new Error(data.error || 'failed');
        showToast('Admin deleted');
        await loadAdmins();
      } catch (err: any) {
        showToast(err.message || 'Failed to delete', 'error');
      }
      return;
    }
  });

  document.getElementById('adminSubmitBtn')!.addEventListener('click', async () => {
    const username = (document.getElementById('adminUsername') as HTMLInputElement).value.trim().toLowerCase();
    const displayName = (document.getElementById('adminDisplayName') as HTMLInputElement).value.trim();
    const password = (document.getElementById('adminPassword') as HTMLInputElement).value;
    const errEl = document.getElementById('adminModalError') as HTMLElement;
    const isCreate = editingAdminUsername === null;

    if (!username) { errEl.style.display = ''; errEl.innerHTML = '<div class="alert alert--error">Username is required.</div>'; return; }
    if (!displayName) { errEl.style.display = ''; errEl.innerHTML = '<div class="alert alert--error">Display name is required.</div>'; return; }
    if (isCreate && (!password || password.length < 6)) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">Password must be at least 6 characters.</div>';
      return;
    }
    if (!isCreate && password && password.length < 6) {
      errEl.style.display = '';
      errEl.innerHTML = '<div class="alert alert--error">New password must be at least 6 characters (or leave blank).</div>';
      return;
    }

    const meIsSA = !!(adminSession && adminSession.isSuperadmin);
    const role = meIsSA ? (document.getElementById('adminRole') as HTMLSelectElement).value : undefined;

    const btn = document.getElementById('adminSubmitBtn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = isCreate ? 'CREATING…' : 'SAVING…';
    try {
      let res;
      if (isCreate) {
        const body: any = { username, displayName, password, active: 'Yes' };
        if (role !== undefined) body.role = role;
        res = await fetch(`${API}/admin/admins`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify(body),
        });
      } else {
        const body: any = { username, displayName };
        if (password) body.password = password;
        if (role !== undefined) body.role = role;
        res = await fetch(`${API}/admin/admins`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Authorization: adminToken },
          body: JSON.stringify(body),
        });
      }
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.error || 'failed');
      adminModal.style.display = 'none';
      showToast(isCreate ? 'Admin created' : 'Admin updated');
      await loadAdmins();
    } catch (err: any) {
      errEl.style.display = '';
      errEl.innerHTML = `<div class="alert alert--error">${err.message || 'Failed to save.'}</div>`;
    } finally {
      btn.disabled = false; btn.textContent = isCreate ? 'CREATE' : 'SAVE';
    }
  });
</script>

<style is:global>
  .header { position: sticky; top: 0; z-index: 100; background: rgba(6,6,6,0.92); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding-top: env(safe-area-inset-top, 0px); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 0; }
  .brand { display: flex; align-items: center; gap: 0.7rem; }
  .brand-logo { width: 36px; height: 36px; border-radius: 8px; }
  .brand-name { font-size: 1.1rem; }
  .brand-tag { font-size: 0.55rem; color: var(--neon); letter-spacing: 0.2em; font-weight: 600; }
  .back-link { display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; color: var(--text-muted); transition: color 0.2s; }
  .back-link:hover { color: var(--neon); }

  /* Header right cluster (bell + back) */
  .header-right { display: flex; align-items: center; gap: 0.5rem; }
  .notify-bell {
    position: relative; width: 36px; height: 36px; border-radius: 50%;
    background: rgba(0,255,65,0.08); border: 1px solid rgba(0,255,65,0.22);
    color: var(--neon); cursor: pointer; padding: 0;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.15s, transform 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .notify-bell:hover { background: rgba(0,255,65,0.16); }
  .notify-bell:active { transform: scale(0.95); }
  .notify-bell-count {
    position: absolute; top: -4px; right: -4px;
    min-width: 18px; height: 18px; padding: 0 5px;
    background: var(--neon); color: #000;
    border-radius: 100px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800; font-size: 0.62rem;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 10px rgba(0,255,65,0.5);
  }
  .notify-bell-count.zero { display: none; }
  .notify-bell--pulse { animation: ncBellPulse 0.55s ease; }
  @keyframes ncBellPulse {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.18); }
    60%  { transform: scale(0.94); }
    100% { transform: scale(1); }
  }

  /* "Logged in as <name>" chip in the header */
  .logged-in-as {
    display: inline-flex; align-items: center; gap: 0.4rem;
