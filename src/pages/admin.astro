  }

  /* Block-list rows in the Blocked tab */
  .block-section { display: flex; flex-direction: column; gap: 0.6rem; }
  .block-section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.4rem; }
  .block-row {
    display: flex; gap: 0.7rem; align-items: center;
