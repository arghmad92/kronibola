  }
  .logged-in-as-logout:hover { color: var(--red); border-color: rgba(255,59,48,0.4); }
  @media (max-width: 480px) {
    .logged-in-as-label { display: none; }
    .logged-in-as-name { max-width: 90px; }
  }

  .login-hint {
    font-size: 0.7rem; color: var(--text-muted); margin-top: 1rem; line-height: 1.5;
  }

  .admin-help {
    font-size: 0.78rem; color: var(--text-secondary); line-height: 1.55;
    margin: 0.4rem 0 1rem; padding: 0.6rem 0.8rem;
