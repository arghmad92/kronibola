  .cal-today-btn:active { transform: scale(0.97); }

  /* Subscribe to calendar feeds — collapsible. */
  .cal-feeds {
    margin: 0.4rem 0 0.8rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
