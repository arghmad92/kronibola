    font-family: 'Space Grotesk', sans-serif; font-size: 0.7rem;
  }
  .logged-in-as-label { color: var(--text-muted); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
  .logged-in-as-name { color: var(--neon); font-weight: 700; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
