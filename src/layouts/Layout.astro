---
interface Props {
  title: string;
  description?: string;
  activeTab?: string;
  hideNav?: boolean;
}

const { title, description = 'KroniBola — Football pickup game registration', activeTab = 'home', hideNav = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00FF41" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Animated background -->
    <div class="bg-effects">
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
      <div class="bg-orb bg-orb--3"></div>
      <div class="bg-grid"></div>
    </div>

    <slot />

    {!hideNav && (
      <footer class="site-footer">
        <p>&copy; 2025 KroniBola. All rights reserved.</p>
        <p class="ssm-text">SSM: 202603032902 (TR0336774-T)</p>
      </footer>
    )}

    {!hideNav && (
      <nav class="bottom-nav" id="bottomNav">
        <a href="/" class={`nav-item ${activeTab === 'home' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          <span>Match</span>
        </a>
        <a href="/history" class={`nav-item ${activeTab === 'history' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>History</span>
        </a>
        <a href="/leaderboard" class={`nav-item ${activeTab === 'leaderboard' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 7 7"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 17 7"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span>Board</span>
        </a>
        <a href="/gallery" class={`nav-item ${activeTab === 'gallery' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <span>Gallery</span>
        </a>
        <a href="/crew" class={`nav-item ${activeTab === 'crew' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Crew</span>
        </a>
        <a href="/rules" class={`nav-item ${activeTab === 'rules' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <span>Rules</span>
        </a>
      </nav>
    )}

    <!-- Registration Modal -->
    <div class="modal-overlay" id="regModal" style="display:none">
      <div class="modal">
        <div class="modal-glow"></div>
        <button class="modal-close" id="modalClose">&times;</button>
        <div class="modal-steps" id="modalSteps">
          <div class="step-dot active" data-step="1">1</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="2">2</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="3">3</div>
        </div>

        <div class="modal-page active" id="step1">
          <h3 class="modal-title">YOUR <span class="neon-text">DETAILS</span></h3>
          <div class="form-group">
            <label class="form-label">Nickname</label>
            <input type="text" class="form-input" id="regName" placeholder="e.g. Haziq" />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input type="tel" class="form-input" id="regPhone" placeholder="e.g. 0123456789" />
          </div>
          <button class="btn btn--primary" id="toStep2" style="width:100%">NEXT</button>
        </div>

        <div class="modal-page" id="step2">
          <h3 class="modal-title">MAKE <span class="neon-text">PAYMENT</span></h3>
          <p class="modal-sub" id="payFeeLabel">Fee: RM 10</p>
          <img src="/pay.jpg" alt="Payment QR" class="qr-img" />
          <a href="https://www.maybank2u.com.my" target="_blank" class="btn btn--mae" style="width:100%">Open Maybank MAE</a>

          <!-- Receipt upload -->
          <div class="receipt-upload">
            <p class="upload-label">Upload payment receipt <span style="color:var(--red)">*</span></p>
            <label class="upload-area" id="uploadArea">
              <input type="file" accept="image/*" capture="environment" id="receiptFile" style="display:none" />
              <div class="upload-placeholder" id="uploadPlaceholder">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Tap to upload screenshot</span>
              </div>
              <img id="uploadPreview" class="upload-preview" style="display:none" />
            </label>
            <p class="upload-hint">Required — take a screenshot of your payment confirmation and upload it here</p>
            <div id="uploadStatus" style="display:none"></div>
          </div>

          <button class="btn btn--primary" id="toStep3" style="width:100%;margin-top:0.5rem">CONFIRM REGISTRATION</button>
        </div>

        <div class="modal-page" id="step2w">
          <h3 class="modal-title">JOINING <span style="color:var(--blue)">WAITLIST</span></h3>
          <div class="alert alert--warning">Game is full. You'll be added to the waitlist. Do NOT pay yet — you'll be notified when a slot opens.</div>
          <button class="btn btn--primary" id="confirmWaitlist" style="width:100%;margin-top:1rem">JOIN WAITLIST</button>
        </div>

        <div class="modal-page" id="step3">
          <div class="done-icon">&#9917;</div>
          <h3 class="modal-title" id="doneTitle">YOU'RE <span class="neon-text">IN!</span></h3>
          <p class="modal-sub" id="doneSub">Slot confirmed. See you on the pitch!</p>
          <!-- Confirmation receipt -->
          <div class="receipt" id="receiptCard">
            <div class="receipt-header">REGISTRATION RECEIPT</div>
            <div class="receipt-row"><span>Ref Code</span><span id="rcptRef" style="color:var(--neon);font-family:'Space Grotesk',sans-serif">—</span></div>
            <div class="receipt-row"><span>Player</span><span id="rcptName">—</span></div>
            <div class="receipt-row"><span>Session</span><span id="rcptSession">—</span></div>
            <div class="receipt-row"><span>Date</span><span id="rcptDate">—</span></div>
            <div class="receipt-row"><span>Status</span><span id="rcptStatus">—</span></div>
            <div class="receipt-row"><span>Fee</span><span id="rcptFee">—</span></div>
            <p class="receipt-note">Screenshot this as your proof of registration</p>
          </div>
          <a href="#" class="btn btn--wa" id="waBtn" target="_blank" style="width:100%">NOTIFY ADMIN (WHATSAPP)</a>
          <a href="https://chat.whatsapp.com/FsLEE1Bko9a9fGXd88UPgS" target="_blank" class="btn btn--ghost" style="width:100%;margin-top:0.5rem">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            JOIN WHATSAPP GROUP
          </a>
          <button class="btn btn--outline" id="modalDone" style="width:100%;margin-top:0.5rem">CLOSE</button>
        </div>

        <div id="regError" style="display:none;margin-top:0.8rem"></div>
      </div>
    </div>

    <!-- Check Status Modal -->
    <div class="modal-overlay" id="statusModal" style="display:none">
      <div class="modal">
        <button class="modal-close" id="statusClose">&times;</button>
        <h3 class="modal-title">CHECK <span class="neon-text">STATUS</span></h3>
        <p class="modal-sub">Enter your phone number to see your registrations</p>
        <div class="form-group">
          <label class="form-label">Phone Number</label>
          <input type="tel" class="form-input" id="statusPhone" placeholder="e.g. 0123456789" />
        </div>
        <button class="btn btn--primary" id="statusCheck" style="width:100%;margin-top:0.8rem">CHECK</button>
        <div id="statusResult" style="margin-top:1rem"></div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --neon: #00FF41;
    --neon-dim: #00cc33;
    --neon-glow: rgba(0, 255, 65, 0.15);
    --neon-glow-strong: rgba(0, 255, 65, 0.3);
    --bg: #060606;
    --surface: #111111;
    --surface-hover: #1a1a1a;
    --card: rgba(14, 14, 14, 0.9);
    --text: #ffffff;
    --text-secondary: #a0a0a0;
    --text-muted: #555555;
    --border: #1e1e1e;
    --border-light: #2a2a2a;
    --orange: #ff9500;
    --blue: #00c4ff;
    --red: #ff3b30;
    --tng-blue: #005EB8;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    padding-bottom: 80px;
    position: relative;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  ::selection { background: var(--neon); color: #000; }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 2px; }

  /* Animated background */
  .bg-effects {
    position: fixed; inset: 0; z-index: -1; overflow: hidden; pointer-events: none;
  }

  .bg-orb {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.4;
    animation: float 20s infinite ease-in-out;
  }

  .bg-orb--1 {
    width: 300px; height: 300px; top: -100px; right: -80px;
    background: radial-gradient(circle, rgba(0, 255, 65, 0.15), transparent 70%);
    animation-delay: 0s;
  }

  .bg-orb--2 {
    width: 250px; height: 250px; bottom: 30%; left: -80px;
    background: radial-gradient(circle, rgba(0, 196, 255, 0.08), transparent 70%);
    animation-delay: -7s;
  }

  .bg-orb--3 {
    width: 200px; height: 200px; top: 50%; right: -60px;
    background: radial-gradient(circle, rgba(0, 255, 65, 0.06), transparent 70%);
    animation-delay: -14s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    33% { transform: translateY(-30px) scale(1.05); }
    66% { transform: translateY(20px) scale(0.95); }
  }

  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .container { max-width: 600px; margin: 0 auto; padding: 0 1rem; position: relative; }
  .neon-text { color: var(--neon); text-shadow: 0 0 20px var(--neon-glow); }

  .glass {
    background: var(--card);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border);
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }

  .glass::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.2), transparent);
  }

  /* Badges */
  .badge {
    display: inline-flex; align-items: center; padding: 0.25rem 0.7rem;
    border-radius: 100px; font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .badge--paid { background: var(--neon); color: #000; box-shadow: 0 0 8px var(--neon-glow); }
  .badge--pending { background: var(--orange); color: #000; }
  .badge--waitlist { background: var(--blue); color: #000; }
  .badge--rejected { background: var(--red); color: #fff; }
  .badge--overdue { background: #ff5722; color: #fff; animation: blink 1.5s infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.9rem 1.8rem; border: none; border-radius: 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.05em; cursor: pointer; transition: all 0.25s; text-transform: uppercase;
  }
  .btn--primary {
    background: linear-gradient(135deg, var(--neon), var(--neon-dim));
    color: #000; box-shadow: 0 4px 24px var(--neon-glow), 0 0 0 1px rgba(0,255,65,0.1);
  }
  .btn--primary:hover { box-shadow: 0 8px 40px var(--neon-glow-strong); transform: translateY(-2px); }
  .btn--primary:active { transform: translateY(0); }
  .btn--primary:disabled { background: var(--border); color: var(--text-muted); box-shadow: none; cursor: not-allowed; }
  .btn--tng, .btn--mae { background: linear-gradient(135deg, #ffc107, #f9a825); color: #000; width: 100%; font-weight: 800; }
  .btn--tng:hover, .btn--mae:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(255,193,7,0.3); }
  .btn--outline { background: transparent; color: var(--neon); border: 1.5px solid rgba(0,255,65,0.3); }
  .btn--outline:hover { background: rgba(0,255,65,0.1); border-color: var(--neon); }
  .btn--wa { background: linear-gradient(135deg, #25D366, #20bd5a); color: #fff; }
  .btn--wa:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(37,211,102,0.3); }
  .btn--ghost { background: rgba(255,255,255,0.04); color: var(--text-secondary); border: 1px solid var(--border); }
  .btn--ghost:hover { background: rgba(255,255,255,0.08); color: var(--text); border-color: var(--border-light); }

  /* Form */
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-label { font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.12em; }
  .form-input, .form-select {
    padding: 0.85rem 1rem; background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    border-radius: 14px; color: var(--text); font-family: 'Inter', sans-serif; font-size: 0.9rem;
    outline: none; transition: all 0.2s;
  }
  .form-input:focus, .form-select:focus {
    border-color: var(--neon); box-shadow: 0 0 0 3px var(--neon-glow);
    background: rgba(0,255,65,0.02);
  }
  .form-input::placeholder { color: var(--text-muted); }

  /* Alerts */
  .alert { padding: 1rem 1.2rem; border-radius: 14px; font-size: 0.82rem; font-weight: 500; line-height: 1.5; }
  .alert--success { background: rgba(0,255,65,0.08); border: 1px solid rgba(0,255,65,0.2); color: var(--neon); }
  .alert--warning { background: rgba(255,149,0,0.08); border: 1px solid rgba(255,149,0,0.2); color: var(--orange); }
  .alert--error { background: rgba(255,59,48,0.08); border: 1px solid rgba(255,59,48,0.2); color: var(--red); }
  .alert--info { background: rgba(0,196,255,0.08); border: 1px solid rgba(0,196,255,0.2); color: var(--blue); }

  /* Bottom Nav */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    display: flex; justify-content: space-around; align-items: center;
    background: rgba(6, 6, 6, 0.95); backdrop-filter: blur(24px);
    border-top: 1px solid var(--border); padding: 0.4rem 0;
    padding-bottom: max(0.4rem, env(safe-area-inset-bottom));
  }

  .bottom-nav::before {
    content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.15), transparent);
  }

  .nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 0.1rem;
    padding: 0.35rem 0.4rem; color: var(--text-muted); font-size: 0.5rem;
    font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    transition: all 0.2s; position: relative; min-width: 0;
  }
  .nav-item svg { width: 18px; height: 18px; }
  .nav-item.active { color: var(--neon); }
  .nav-item.active::after {
    content: ''; position: absolute; top: -0.4rem; left: 50%; transform: translateX(-50%);
    width: 16px; height: 2px; background: var(--neon); border-radius: 1px;
    box-shadow: 0 0 8px var(--neon-glow);
  }
  .nav-item:hover { color: var(--text); }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,0.8);
    backdrop-filter: blur(12px); display: flex; align-items: flex-end; justify-content: center;
    padding: 0;
  }

  .modal {
    width: 100%; max-width: 480px; padding: 2rem 1.5rem;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 24px 24px 0 0; position: relative;
    max-height: 90vh; overflow-y: auto;
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp { from { transform: translateY(100%); } to { transform: none; } }

  .modal-glow {
    position: absolute; top: -50px; left: 50%; transform: translateX(-50%);
    width: 200px; height: 100px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,255,65,0.15), transparent);
    pointer-events: none;
  }

  .modal-close {
    position: absolute; top: 1rem; right: 1.2rem; background: rgba(255,255,255,0.06);
    border: 1px solid var(--border); color: var(--text-muted); width: 32px; height: 32px;
    border-radius: 10px; font-size: 1.1rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center; transition: all 0.2s;
  }
  .modal-close:hover { color: var(--text); background: rgba(255,255,255,0.1); }

  .modal-steps {
    display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 1.5rem;
  }
  .step-dot {
    width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700; background: rgba(255,255,255,0.06); color: var(--text-muted);
    border: 1px solid var(--border); transition: all 0.3s;
  }
  .step-dot.active { background: var(--neon); color: #000; border-color: var(--neon); box-shadow: 0 0 16px var(--neon-glow); }
  .step-dot.done { background: rgba(0,255,65,0.2); color: var(--neon); border-color: rgba(0,255,65,0.3); }
  .step-line { width: 36px; height: 2px; background: var(--border); }

  .modal-title { font-size: 1.3rem; margin-bottom: 1rem; text-align: center; }
  .modal-sub { font-size: 0.88rem; color: var(--text-secondary); text-align: center; margin-bottom: 1rem; }
  .modal-page { display: none; flex-direction: column; gap: 1rem; }
  .modal-page.active { display: flex; }
  .qr-img { border-radius: 16px; border: 1px solid var(--border); }
  .done-icon { font-size: 3.5rem; text-align: center; margin-bottom: 0.5rem; }

  /* Page header shared */
  .page-header {
    padding: 1.2rem 0 1rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .page-header::after {
    content: ''; position: absolute; bottom: 0; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.15), transparent);
  }

  .page-title { font-size: 1.4rem; letter-spacing: 0.04em; }
  .page-sub { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem; }

  /* Site footer */
  .site-footer {
    text-align: center; padding: 1.5rem 1rem 5rem;
