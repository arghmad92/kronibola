---
interface Props {
  title: string;
  description?: string;
  activeTab?: string;
  hideNav?: boolean;
}

const { title, description = 'KroniBola — Football pickup game registration', activeTab = 'home', hideNav = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00FF41" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    {!hideNav && (
      <nav class="bottom-nav" id="bottomNav">
        <a href="/" class={`nav-item ${activeTab === 'home' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          <span>Match</span>
        </a>
        <a href="/history" class={`nav-item ${activeTab === 'history' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>History</span>
        </a>
        <a href="/leaderboard" class={`nav-item ${activeTab === 'leaderboard' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 7 7"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 17 7"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span>Board</span>
        </a>
        <a href="/rules" class={`nav-item ${activeTab === 'rules' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <span>Rules</span>
        </a>
      </nav>
    )}

    <!-- Registration Modal -->
    <div class="modal-overlay" id="regModal" style="display:none">
      <div class="modal glass">
        <button class="modal-close" id="modalClose">&times;</button>
        <div class="modal-steps" id="modalSteps">
          <div class="step-dot active" data-step="1">1</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="2">2</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="3">3</div>
        </div>

        <!-- Step 1: Details -->
        <div class="modal-page active" id="step1">
          <h3 class="modal-title">YOUR <span class="neon-text">DETAILS</span></h3>
          <div class="form-group">
            <label class="form-label">Nickname</label>
            <input type="text" class="form-input" id="regName" placeholder="e.g. Haziq" />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input type="tel" class="form-input" id="regPhone" placeholder="e.g. 0123456789" />
          </div>
          <button class="btn btn--primary" id="toStep2" style="width:100%">NEXT</button>
        </div>

        <!-- Step 2: Payment -->
        <div class="modal-page" id="step2">
          <h3 class="modal-title">MAKE <span class="neon-text">PAYMENT</span></h3>
          <p class="modal-sub" id="payFeeLabel">Fee: RM 10</p>
          <img src="/pay.jpg" alt="Payment QR" class="qr-img" />
          <a href="tngdwallet://" class="btn btn--tng" style="width:100%">Open Touch 'n Go</a>
          <button class="btn btn--primary" id="toStep3" style="width:100%;margin-top:0.5rem">I'VE PAID — CONFIRM</button>
        </div>

        <!-- Step 2b: Waitlist -->
        <div class="modal-page" id="step2w">
          <h3 class="modal-title">JOINING <span style="color:var(--blue)">WAITLIST</span></h3>
          <div class="alert alert--warning">Game is full. You'll be added to the waitlist. Do NOT pay yet — you'll be notified when a slot opens.</div>
          <button class="btn btn--primary" id="confirmWaitlist" style="width:100%;margin-top:1rem">JOIN WAITLIST</button>
        </div>

        <!-- Step 3: Done -->
        <div class="modal-page" id="step3">
          <div class="done-icon">&#9917;</div>
          <h3 class="modal-title" id="doneTitle">YOU'RE <span class="neon-text">IN!</span></h3>
          <p class="modal-sub" id="doneSub">Slot confirmed. See you on the pitch!</p>
          <a href="#" class="btn btn--wa" id="waBtn" target="_blank" style="width:100%">NOTIFY ADMIN (WHATSAPP)</a>
          <button class="btn btn--outline" id="modalDone" style="width:100%;margin-top:0.5rem">CLOSE</button>
        </div>

        <div id="regError" style="display:none;margin-top:0.8rem"></div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --neon: #00FF41;
    --neon-dim: #00cc33;
    --neon-glow: rgba(0, 255, 65, 0.15);
    --neon-glow-strong: rgba(0, 255, 65, 0.3);
    --bg: #0a0a0a;
    --surface: #141414;
    --surface-hover: #1c1c1c;
    --card: rgba(20, 20, 20, 0.85);
    --text: #ffffff;
    --text-secondary: #a0a0a0;
    --text-muted: #666666;
    --border: #2a2a2a;
    --border-light: #333;
    --orange: #ff9500;
    --blue: #00c4ff;
    --red: #ff3b30;
    --tng-blue: #005EB8;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    padding-bottom: 80px;
  }

  h1, h2, h3, h4 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  ::selection { background: var(--neon); color: #000; }
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 3px; }

  .container { max-width: 600px; margin: 0 auto; padding: 0 1rem; }
  .neon-text { color: var(--neon); text-shadow: 0 0 20px var(--neon-glow); }
  .glass {
    background: var(--card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 20px;
  }

  /* Badges */
  .badge { display: inline-flex; align-items: center; padding: 0.25rem 0.7rem; border-radius: 100px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }
  .badge--paid { background: var(--neon); color: #000; }
  .badge--pending { background: var(--orange); color: #000; }
  .badge--waitlist { background: var(--blue); color: #000; }
  .badge--rejected { background: var(--red); color: #fff; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.9rem 1.8rem; border: none; border-radius: 12px;
    font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 700;
    letter-spacing: 0.04em; cursor: pointer; transition: all 0.2s; text-transform: uppercase;
  }
  .btn--primary { background: var(--neon); color: #000; box-shadow: 0 0 24px var(--neon-glow); }
  .btn--primary:hover { background: #fff; box-shadow: 0 0 32px var(--neon-glow-strong); transform: translateY(-1px); }
  .btn--primary:disabled { background: var(--border); color: var(--text-muted); box-shadow: none; cursor: not-allowed; }
  .btn--tng { background: var(--tng-blue); color: #fff; width: 100%; }
  .btn--tng:hover { background: #0070d4; }
  .btn--outline { background: transparent; color: var(--neon); border: 1.5px solid var(--neon); }
  .btn--outline:hover { background: var(--neon); color: #000; }
  .btn--wa { background: #25D366; color: #fff; }
  .btn--wa:hover { background: #20bd5a; }
  .btn--ghost { background: rgba(255,255,255,0.06); color: var(--text-secondary); border: 1px solid var(--border); }
  .btn--ghost:hover { background: rgba(255,255,255,0.1); color: var(--text); }

  /* Form */
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .form-label { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .form-input, .form-select {
    padding: 0.8rem 1rem; background: rgba(0,0,0,0.5); border: 1px solid var(--border);
    border-radius: 12px; color: var(--text); font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s;
  }
  .form-input:focus, .form-select:focus { border-color: var(--neon); box-shadow: 0 0 0 2px var(--neon-glow); }
  .form-input::placeholder { color: var(--text-muted); }

  /* Alerts */
  .alert { padding: 0.9rem 1.2rem; border-radius: 12px; font-size: 0.85rem; font-weight: 500; }
  .alert--success { background: rgba(0,255,65,0.1); border: 1px solid var(--neon); color: var(--neon); }
  .alert--warning { background: rgba(255,149,0,0.1); border: 1px solid var(--orange); color: var(--orange); }
  .alert--error { background: rgba(255,59,48,0.1); border: 1px solid var(--red); color: var(--red); }
  .alert--info { background: rgba(0,196,255,0.1); border: 1px solid var(--blue); color: var(--blue); }

  /* Bottom Nav */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    display: flex; justify-content: space-around; align-items: center;
    background: rgba(10, 10, 10, 0.95); backdrop-filter: blur(20px);
    border-top: 1px solid var(--border); padding: 0.5rem 0;
    padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
  }
  .nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.4rem 0.8rem; color: var(--text-muted); font-size: 0.62rem;
    font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s;
  }
  .nav-item.active { color: var(--neon); }
  .nav-item:hover { color: var(--text); }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center;
    padding: 1rem;
  }
  .modal {
    width: 100%; max-width: 420px; padding: 2rem; position: relative;
    max-height: 90vh; overflow-y: auto;
  }
  .modal-close {
    position: absolute; top: 1rem; right: 1rem; background: none; border: none;
    color: var(--text-muted); font-size: 1.5rem; cursor: pointer; line-height: 1;
  }
  .modal-close:hover { color: var(--text); }
  .modal-steps {
    display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 1.5rem;
  }
  .step-dot {
    width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700; background: var(--border); color: var(--text-muted); transition: all 0.3s;
  }
  .step-dot.active { background: var(--neon); color: #000; box-shadow: 0 0 12px var(--neon-glow); }
  .step-dot.done { background: var(--neon-dim); color: #000; }
  .step-line { width: 40px; height: 2px; background: var(--border); }
  .modal-title { font-size: 1.2rem; margin-bottom: 1rem; text-align: center; }
  .modal-sub { font-size: 0.88rem; color: var(--text-secondary); text-align: center; margin-bottom: 1rem; }
  .modal-page { display: none; flex-direction: column; gap: 1rem; }
  .modal-page.active { display: flex; }
  .qr-img { border-radius: 12px; border: 1px solid var(--border); margin-bottom: 0.5rem; }
  .done-icon { font-size: 3rem; text-align: center; margin-bottom: 0.5rem; }

  @media (max-width: 640px) {
    .container { padding: 0 0.8rem; }
  }
</style>
