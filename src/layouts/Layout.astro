---
interface Props {
  title: string;
  description?: string;
  activeTab?: string;
  hideNav?: boolean;
  noindex?: boolean;
}

const { title, description = 'KroniBola — Football pickup game registration in KL & Selangor. Join weekly futsal sessions, register online, and track your stats.', activeTab = 'home', hideNav = false, noindex = false } = Astro.props;

const siteUrl = 'https://kronibola.com';
const ogImage = `${siteUrl}/og-image.png`;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#00FF41" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="KroniBola" />
    <meta property="og:locale" content="en_MY" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/logo-v2.png" />
    <link rel="apple-touch-icon" href="/logo-v2.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SportsOrganization",
        "name": "KroniBola",
        "url": siteUrl,
        "logo": ogImage,
        "description": "Weekly football pickup games in KL & Selangor. Register online, track stats, and join the crew.",
        "sport": "Football",
        "location": {
          "@type": "Place",
          "name": "KL & Selangor, Malaysia"
        },
        "sameAs": [
          "https://www.instagram.com/kronibola.my",
          "https://www.tiktok.com/@kronibola.my",
          "https://www.threads.net/@kronibola.my"
        ]
      })} />
    )}
  </head>
  <body>
    <!-- Theme toggle (top-right) -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle light/dark mode">
      <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <!-- Theme script (runs before render to prevent flash) -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('kb-theme');
        if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
      })();
    </script>

    <!-- Animated background -->
    <div class="bg-effects">
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
      <div class="bg-orb bg-orb--3"></div>
      <div class="bg-grid"></div>
    </div>

    <slot />

    {!hideNav && (
      <footer class="site-footer">
        <div class="footer-socials">
          <a href="https://www.instagram.com/kronibola.my" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://www.tiktok.com/@kronibola.my" target="_blank" rel="noopener" aria-label="TikTok">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.72a8.19 8.19 0 0 0 4.76 1.52V6.79a4.84 4.84 0 0 1-1-.1z"/></svg>
          </a>
          <a href="https://www.threads.net/@kronibola.my" target="_blank" rel="noopener" aria-label="Threads">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007C5.461 23.926.052 18.514.052 11.73v-.162C.171 4.988 5.488-.05 12.074.002c3.16.025 6.019 1.262 8.1 3.397 2.06 2.114 3.197 4.95 3.197 7.982-.012 4.936-2.869 7.758-5.483 7.758-1.576 0-2.726-.752-3.172-2.044-.378.864-1.084 1.476-2.063 1.782-.34.107-.705.162-1.084.162-2.163 0-3.815-1.88-3.815-4.343 0-2.502 1.537-4.263 3.748-4.33 1.07-.033 1.997.341 2.693 1.05l.043-.658h2.076l-.68 7.244c-.066.677.211 1.064.765 1.064.978 0 2.754-1.587 2.762-5.514.008-2.56-.959-4.888-2.665-6.53A8.97 8.97 0 0 0 12.074 2.2c-5.46-.044-9.914 4.29-9.914 9.652v.134c.073 5.396 4.49 9.798 9.88 9.862h.162l-.016 2.152zm.302-8.293c.503-.014.903-.2 1.193-.553.315-.383.46-.94.46-1.655 0-1.2-.653-2.09-1.553-2.09-.422 0-.79.184-1.075.538-.316.394-.466.958-.466 1.647 0 1.243.631 2.128 1.44 2.113z"/></svg>
          </a>
        </div>
        <div class="visitor-wrap">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <span class="visitor-count" id="visitorCount">—</span>
          <span class="visitor-label">visitors</span>
        </div>
        <script is:inline>
          // Self-hosted visitor counter on Cloudflare KV (see functions/api/visitors.js).
          // Hide the entire wrap on any failure so a broken counter doesn't leave a
          // dangling "—" in the footer.
          fetch('/api/visitors', { method: 'POST' })
            .then(r => r.ok ? r.json() : Promise.reject())
            .then(data => {
              const el = document.getElementById('visitorCount');
              const wrap = document.querySelector('.visitor-wrap');
              if (data && typeof data.count === 'number' && data.count > 0) {
                if (el) el.textContent = data.count.toLocaleString('en-MY');
              } else if (wrap instanceof HTMLElement) {
                wrap.style.display = 'none';
              }
            })
            .catch(() => {
              const wrap = document.querySelector('.visitor-wrap');
              if (wrap instanceof HTMLElement) wrap.style.display = 'none';
            });
        </script>
        <p>&copy; 2025 KroniBola. All rights reserved.</p>
        <p class="ssm-text">SSM: 202603032902 (TR0336774-T)</p>
      </footer>
    )}

    {!hideNav && (
      <nav class="bottom-nav" id="bottomNav">
        <a href="/" class={`nav-item ${activeTab === 'home' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          <span>Match</span>
        </a>
        <a href="/history" class={`nav-item ${activeTab === 'history' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>History</span>
        </a>
        <a href="/leaderboard" class={`nav-item ${activeTab === 'leaderboard' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 7 7"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 17 7"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span>Board</span>
        </a>
        <a href="/jersey" class={`nav-item ${activeTab === 'jersey' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2 12 5 8 2 3.62 3.46a2 2 0 0 0-1.34 1.27l-.71 2.12A2 2 0 0 0 2.84 9.4l2.72 1.52a1 1 0 0 0 1.14-.1L8 9.5V22h8V9.5l1.3 1.32a1 1 0 0 0 1.14.1l2.72-1.52a2 2 0 0 0 .27-2.55l-.71-2.12a2 2 0 0 0-1.34-1.27z"/></svg>
          <span>Jersey</span>
        </a>
        <a href="/gallery" class={`nav-item ${activeTab === 'gallery' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <span>Gallery</span>
        </a>
        <a href="/crew" class={`nav-item ${activeTab === 'crew' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Crew</span>
        </a>
        <a href="/rules" class={`nav-item ${activeTab === 'rules' ? 'active' : ''}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <span>Rules</span>
        </a>
      </nav>
    )}

    <!-- PWA: keep internal links within the app shell -->
    <script is:inline>
      if (window.navigator.standalone || window.matchMedia('(display-mode: standalone)').matches) {
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href]');
          if (!link) return;
          var href = link.getAttribute('href');
          if (href && href.startsWith('/') && !link.getAttribute('target')) {
            e.preventDefault();
            window.location.href = href;
          }
        });
      }
    </script>

    <!-- Registration Modal -->
    <div class="modal-overlay" id="regModal" style="display:none">
      <div class="modal">
        <div class="modal-glow"></div>
        <button class="modal-close" id="modalClose">&times;</button>
        <div class="modal-steps" id="modalSteps">
          <div class="step-dot active" data-step="1">1</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="2">2</div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="3">3</div>
        </div>

        <div class="modal-page active" id="step1">
          <h3 class="modal-title">YOUR <span class="neon-text">DETAILS</span></h3>
          <!-- Position-context banner — only shown when the modal was opened
               by tapping a slot in the 3-team builder. -->
          <div class="booking-ctx" id="bookingCtx" style="display:none">
            <div class="booking-ctx-dot" id="bookingCtxDot">ST</div>
            <div>
              <div class="booking-ctx-pos" id="bookingCtxPos">Striker</div>
              <div class="booking-ctx-team" id="bookingCtxTeam">Team A</div>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Nickname</label>
            <input type="text" class="form-input" id="regName" placeholder="e.g. Haziq" style="text-transform:capitalize" autocapitalize="words" />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <div class="phone-row">
              <select class="form-input phone-country" id="regCountry" data-kb-country data-target="regPhone" aria-label="Country code"></select>
              <input type="tel" class="form-input phone-number" id="regPhone" placeholder="123456789" inputmode="numeric" autocomplete="tel-national" />
            </div>
            <p class="form-hint" style="font-size:0.7rem;color:var(--text-muted);margin-top:0.3rem">Mobile only. Leading 0 or country code is not needed.</p>
          </div>
          <div class="form-group" id="carPlateGroup" style="display:none">
            <label class="form-label">Car Plate Number</label>
            <input type="text" class="form-input" id="regCarPlate" placeholder="e.g. ABC1234" style="text-transform:uppercase" autocapitalize="characters" />
            <p class="form-hint" style="color:var(--orange);font-size:0.72rem;margin-top:0.3rem">Failing to register your car plate number will result in denied entry for parking.</p>
          </div>
          <button class="btn btn--primary" id="toStep2" style="width:100%">NEXT</button>
        </div>

        <div class="modal-page" id="step2">
          <h3 class="modal-title">MAKE <span class="neon-text">PAYMENT</span></h3>
          <p class="modal-sub" id="payFeeLabel">Fee: RM 10</p>
          <img src="/pay.webp" alt="Payment QR" class="qr-img" />
          <a href="https://www.maybank2u.com.my" target="_blank" class="btn btn--mae" style="width:100%">Open Maybank MAE</a>

          <!-- Receipt upload -->
          <div class="receipt-upload">
            <p class="upload-label">Upload payment receipt <span style="color:var(--red)">*</span></p>
            <label class="upload-area" id="uploadArea">
              <input type="file" accept="image/*" id="receiptFile" style="display:none" />
              <div class="upload-placeholder" id="uploadPlaceholder">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Tap to upload screenshot</span>
              </div>
              <img id="uploadPreview" class="upload-preview" style="display:none" />
            </label>
            <p class="upload-hint">Required — take a screenshot of your payment confirmation and upload it here</p>
            <div id="uploadStatus" style="display:none"></div>
          </div>

          <button class="btn btn--primary" id="toStep3" style="width:100%;margin-top:0.5rem">CONFIRM REGISTRATION</button>
        </div>

        <div class="modal-page" id="step2w">
          <h3 class="modal-title">JOINING <span style="color:var(--blue)">WAITLIST</span></h3>
          <div class="alert alert--warning">Game is full. You'll be added to the waitlist. Do NOT pay yet — you'll be notified when a slot opens.</div>
          <button class="btn btn--primary" id="confirmWaitlist" style="width:100%;margin-top:1rem">JOIN WAITLIST</button>
        </div>

        <div class="modal-page" id="step3">
          <div class="done-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 7l4.76 3.45l-1.76 5.55h-6l-1.76 -5.55z"/>
              <path d="M12 7v-5"/>
              <path d="M15 16l3 4"/>
              <path d="M16.85 10.45l4.15 -1.45"/>
              <path d="M9 16l-3 4"/>
              <path d="M7.15 10.45l-4.15 -1.45"/>
            </svg>
          </div>
          <h3 class="modal-title" id="doneTitle">YOU'RE <span class="neon-text">IN!</span></h3>
          <p class="modal-sub" id="doneSub">Slot confirmed. See you on the pitch!</p>
          <!-- Confirmation receipt -->
          <div class="receipt" id="receiptCard">
            <div class="receipt-header">REGISTRATION RECEIPT</div>
            <div class="receipt-row"><span>Ref Code</span><span id="rcptRef" style="color:var(--neon);font-family:'Space Grotesk',sans-serif">—</span></div>
            <div class="receipt-row"><span>Player</span><span id="rcptName">—</span></div>
            <div class="receipt-row"><span>Session</span><span id="rcptSession">—</span></div>
            <div class="receipt-row"><span>Date</span><span id="rcptDate">—</span></div>
            <div class="receipt-row"><span>Status</span><span id="rcptStatus">—</span></div>
            <div class="receipt-row"><span>Fee</span><span id="rcptFee">—</span></div>
            <p class="receipt-note">Screenshot this as your proof of registration</p>
          </div>
          <a href="#" class="btn btn--wa" id="waBtn" target="_blank" style="width:100%">NOTIFY ADMIN (WHATSAPP)</a>
          <a href="https://chat.whatsapp.com/FsLEE1Bko9a9fGXd88UPgS" target="_blank" class="btn btn--ghost" style="width:100%;margin-top:0.5rem">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            JOIN WHATSAPP GROUP
          </a>
          <button class="btn btn--outline" id="modalDone" style="width:100%;margin-top:0.5rem">CLOSE</button>
        </div>

        <div id="regError" style="display:none;margin-top:0.8rem"></div>
      </div>
    </div>

    <!-- Check Status Modal -->
    <div class="modal-overlay" id="statusModal" style="display:none">
      <div class="modal">
        <button class="modal-close" id="statusClose">&times;</button>
        <h3 class="modal-title">CHECK <span class="neon-text">STATUS</span></h3>
        <p class="modal-sub">Enter your phone number to see your registrations</p>
        <div class="form-group">
          <label class="form-label">Phone Number</label>
          <div class="phone-row">
            <select class="form-input phone-country" id="statusCountry" data-kb-country data-target="statusPhone" aria-label="Country code"></select>
            <input type="tel" class="form-input phone-number" id="statusPhone" placeholder="123456789" inputmode="numeric" autocomplete="tel-national" />
          </div>
        </div>
        <button class="btn btn--primary" id="statusCheck" style="width:100%;margin-top:0.8rem">CHECK</button>
        <div id="statusResult" style="margin-top:1rem"></div>
      </div>
    </div>

    <!-- Share Match Modal -->
    <div class="modal-overlay" id="shareModal" style="display:none">
      <div class="modal">
        <button class="modal-close" id="shareClose">&times;</button>
        <h3 class="modal-title">SHARE <span class="neon-text">MATCH</span></h3>
        <p class="modal-sub" id="shareSub">Tell your friends 👇</p>

        <div class="share-preview" id="sharePreview"></div>

        <div class="share-options">
          <button type="button" class="share-option share-option--wa" id="shareWa">
            <span class="share-option-icon" style="background:#25D366;color:#fff">
