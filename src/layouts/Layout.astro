    <!-- Phone input — country code selector + national-number input -->
    <style is:global>
      .phone-row { display: flex; gap: 0.4rem; align-items: stretch; }
      .phone-row .phone-country {
        flex: 0 0 auto; width: 105px;
        padding-left: 0.55rem; padding-right: 0.4rem;
        font-size: 0.88rem;
        background-position: right 0.4rem center;
        cursor: pointer;
      }
      .phone-row .phone-number { flex: 1; min-width: 0; }
    </style>
    <script is:inline>
      // Country + mobile validation. Mirrors functions/api/_phone.js — keep
      // the two lists in sync when you add a country. The frontend builds
      // E.164 (+countrycode + nationalnumber) and sends that to the API;
      // the API re-validates as a safety net.
      (function () {
        var COUNTRIES = [
          { code: '+60', flag: '🇲🇾', name: 'Malaysia',    re: /^1[0-9]{8,9}$/,           example: '123456789' },
          { code: '+65', flag: '🇸🇬', name: 'Singapore',   re: /^[89][0-9]{7}$/,          example: '81234567' },
          { code: '+62', flag: '🇮🇩', name: 'Indonesia',   re: /^8[0-9]{8,11}$/,          example: '812345678' },
          { code: '+66', flag: '🇹🇭', name: 'Thailand',    re: /^[689][0-9]{8}$/,         example: '812345678' },
          { code: '+63', flag: '🇵🇭', name: 'Philippines', re: /^9[0-9]{9}$/,             example: '9171234567' },
          { code: '+84', flag: '🇻🇳', name: 'Vietnam',     re: /^[35789][0-9]{8}$/,       example: '912345678' },
          { code: '+91', flag: '🇮🇳', name: 'India',       re: /^[6-9][0-9]{9}$/,         example: '9123456789' },
          { code: '+86', flag: '🇨🇳', name: 'China',       re: /^1[3-9][0-9]{9}$/,        example: '13812345678' },
          { code: '+81', flag: '🇯🇵', name: 'Japan',       re: /^[789]0[0-9]{8}$/,        example: '9012345678' },
          { code: '+82', flag: '🇰🇷', name: 'South Korea', re: /^10[0-9]{7,8}$/,          example: '1012345678' },
          { code: '+61', flag: '🇦🇺', name: 'Australia',   re: /^4[0-9]{8}$/,             example: '412345678' },
          { code: '+44', flag: '🇬🇧', name: 'UK',          re: /^7[0-9]{9}$/,             example: '7123456789' },
          { code: '+1',  flag: '🇺🇸', name: 'US/Canada',   re: /^[2-9][0-9]{2}[2-9][0-9]{6}$/, example: '4155551234' },
          { code: '+49', flag: '🇩🇪', name: 'Germany',     re: /^1[5-7][0-9]{8,9}$/,      example: '1512345678' },
        ];
        var STORAGE_KEY = 'kb-country';

        // Strip whitespace/punctuation, drop a leading + and matching country
        // code (so "+60123" works even if MY is already selected), drop the
        // leading 0 (a near-universal MY-typing habit). What remains is the
        // candidate national number.
        function normalizeNational(raw, code) {
          var s = String(raw || '').replace(/[\s\-()]/g, '');
          if (s.charAt(0) === '+') {
            var codeDigits = (code || '').slice(1);
            if (codeDigits && s.indexOf('+' + codeDigits) === 0) s = s.slice(codeDigits.length + 1);
            else s = s.slice(1);
          }
          return s.replace(/^0+/, '');
        }

        function buildAndValidate(countrySel, phoneInput) {
          if (!countrySel || !phoneInput) return { valid: false, error: 'Phone fields not found' };
          var code = countrySel.value;
          var country = null;
          for (var i = 0; i < COUNTRIES.length; i++) {
            if (COUNTRIES[i].code === code) { country = COUNTRIES[i]; break; }
          }
          if (!country) return { valid: false, error: 'Please pick a country' };
          var national = normalizeNational(phoneInput.value, code);
          if (!national) return { valid: false, error: 'Please enter your phone number' };
          if (!country.re.test(national)) {
            return { valid: false, error: "That doesn't look like a valid " + country.name + " mobile number" };
          }
          return { valid: true, e164: code + national, code: code, national: national };
        }

        // Same fuzzy match as the backend — used by client-side phone lookups
        // (e.g. the auto-fill-name feature on the registration form).
        function phoneMatches(a, b) {
          var da = String(a || '').replace(/\D/g, '');
          var db = String(b || '').replace(/\D/g, '');
          if (da.length < 7 || db.length < 7) return false;
          if (da === db) return true;
          var shorter = da.length < db.length ? da : db;
          var longer = da.length < db.length ? db : da;
          return longer.lastIndexOf(shorter) === longer.length - shorter.length;
        }

        // Turn a stored phone (any format we've seen historically) into the
        // bare digits a wa.me link wants. Used by admin pages.
        function toWaNumber(stored) {
          if (!stored) return '';
          var s = String(stored).replace(/^['"\s]+/, '').trim();
          if (s.charAt(0) === '+') return s.slice(1);
          var digits = s.replace(/\D/g, '');
          if (!digits) return '';
          if (digits.charAt(0) === '0') return '60' + digits.slice(1); // legacy MY local
          return digits; // already international, or a foreign legacy number
        }

        function initSelectors() {
          var saved = '+60';
          try { saved = localStorage.getItem(STORAGE_KEY) || '+60'; } catch (_) {}
          var optionsHtml = COUNTRIES.map(function (c) {
            return '<option value="' + c.code + '" data-example="' + c.example + '">' + c.flag + ' ' + c.code + '</option>';
          }).join('');

          var selects = document.querySelectorAll('select[data-kb-country]');
          for (var i = 0; i < selects.length; i++) {
            (function (sel) {
              sel.innerHTML = optionsHtml;
              sel.value = saved;
              var targetId = sel.getAttribute('data-target');
              var input = targetId ? document.getElementById(targetId) : null;
              function updatePlaceholder() {
                var opt = sel.options[sel.selectedIndex];
                if (input && opt) input.placeholder = opt.getAttribute('data-example') || 'Phone number';
              }
              sel.addEventListener('change', function () {
                try { localStorage.setItem(STORAGE_KEY, sel.value); } catch (_) {}
                updatePlaceholder();
              });
              updatePlaceholder();
            })(selects[i]);
          }
        }

        window.KB_PHONE = {
          COUNTRIES: COUNTRIES,
          buildAndValidate: buildAndValidate,
          phoneMatches: phoneMatches,
          toWaNumber: toWaNumber,
          normalizeNational: normalizeNational,
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initSelectors);
        } else {
          initSelectors();
        }
      })();
    </script>

    <!-- Install KroniBola banner — shows after the user's 2nd visit -->
    <div id="installBanner" class="install-banner" role="dialog" aria-label="Install KroniBola">
      <img src="/logo-v2.png" alt="" class="install-banner__icon" />
